@using DonationApp.Models
@using DonationApp.Services
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var user = ViewBag.ProfileUser as ApplicationUser;
    var totalDonasi = (int)(ViewBag.TotalDonasi ?? 0);
    var totalRequest = (int)(ViewBag.TotalRequest ?? 0);
    var avgRating = (double)(ViewBag.AvgRating ?? 0.0);
    var totalReviews = (int)(ViewBag.TotalReviews ?? 0);
    var reviews = ViewBag.Reviews as List<Feedback> ?? new List<Feedback>();
    var activeDonations = ViewBag.ActiveDonations as List<Item> ?? new List<Item>();
    var activeRequests = ViewBag.ActiveRequests as List<ItemRequest> ?? new List<ItemRequest>();
    var avatarLetter = user?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
    var memberSince = user?.CreatedAt.ToString("MMMM yyyy") ?? "";
}

<div class="pubprof">

    <div class="pubprof-card">
        <div class="pubprof-head">
            <div class="pubprof-avatar">
                @avatarLetter
            </div>
            <div class="flex-1">
                <h1 class="pubprof-name">
                    @user?.NamaDepan @user?.NamaBelakang
                </h1>
                <div class="pubprof-meta">
                    @if (!string.IsNullOrEmpty(user?.Kota) || !string.IsNullOrEmpty(user?.Provinsi))
                    {
                        <span class="pubprof-meta-item">
                            <i class="ti ti-map-pin icon-15" aria-hidden="true"></i>
                            @user?.Kota@(!string.IsNullOrEmpty(user?.Provinsi) ? ", " + user?.Provinsi : "")
                        </span>
                    }
                    <span class="pubprof-meta-item pubprof-meta-item--dim">
                        <i class="ti ti-calendar icon-15" aria-hidden="true"></i>
                        Bergabung @memberSince
                    </span>
                </div>
            </div>
        </div>

        <div class="pubprof-stats">
            <div class="pubprof-stat">
                <div class="pubprof-stat-num">@totalDonasi</div>
                <div class="pubprof-stat-lbl">Donasi</div>
            </div>
            <div class="pubprof-stat">
                <div class="pubprof-stat-num">@totalRequest</div>
                <div class="pubprof-stat-lbl">Request</div>
            </div>
            <div class="pubprof-stat">
                <div class="pubprof-stat-rating">
                    <span class="pubprof-stat-num">@avgRating.ToString("0.0")</span>
                    <span class="icon-star" style="font-size:16px;">★</span>
                </div>
                <div class="pubprof-stat-lbl">@totalReviews ulasan</div>
            </div>
        </div>
    </div>

    @if (activeDonations.Any())
    {
        <div class="pubprof-section">
            <h2 class="pubprof-h2">
                <i class="ti ti-gift icon-blue" aria-hidden="true"></i> Donasi Aktif
            </h2>
            <div class="pubprof-grid">
                @foreach (var d in activeDonations)
                {
                    <a href="/Item/Detail/@d.Id" class="pubprof-item">
                        @if (d.Images.Any())
                        {
                            <img src="@d.Images.First().FilePath" class="pubprof-item-img" />
                        }
                        else
                        {
                            <div class="pubprof-item-ph"><i class="ti ti-gift icon-28" aria-hidden="true"></i></div>
                        }
                        <div class="pubprof-item-body">
                            <div class="pubprof-item-name">@d.NamaBarang</div>
                            <div class="pubprof-item-cat">@CategoryHelper.DisplayName(d.Kategori)</div>
                        </div>
                    </a>
                }
            </div>
        </div>
    }

    @if (activeRequests.Any())
    {
        <div class="pubprof-section">
            <h2 class="pubprof-h2">
                <i class="ti ti-list-search icon-blue" aria-hidden="true"></i> Request Aktif
            </h2>
            <div class="pubprof-grid">
                @foreach (var r in activeRequests)
                {
                    <a href="/Request/Detail/@r.Id" class="pubprof-item">
                        @if (r.Images.Any())
                        {
                            <img src="@r.Images.First().FilePath" class="pubprof-item-img" />
                        }
                        else
                        {
                            <div class="pubprof-item-ph"><i class="ti ti-list-search icon-28" aria-hidden="true"></i></div>
                        }
                        <div class="pubprof-item-body">
                            <div class="pubprof-item-name">@r.Title</div>
                            <div class="pubprof-item-cat">@CategoryHelper.DisplayName(r.Kategori)</div>
                        </div>
                    </a>
                }
            </div>
        </div>
    }

    <div class="pubprof-section pubprof-section--last">
        <h2 class="pubprof-h2">
            <i class="ti ti-star icon-star" aria-hidden="true"></i> Ulasan (@totalReviews)
        </h2>
        @if (!reviews.Any())
        {
            <p class="pubprof-empty">Belum ada ulasan.</p>
        }
        else
        {
            <div class="pubprof-reviews">
                @foreach (var f in reviews)
                {
                    var rInitial = f.Reviewer?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
                    var rName = f.Reviewer != null ? f.Reviewer.NamaDepan + " " + f.Reviewer.NamaBelakang : "Anonim";
                    var contextLabel = "";
                    if (f.ClaimRequest?.Item != null) contextLabel = f.ClaimRequest.Item.NamaBarang;
                    else if (f.ItemRequest != null) contextLabel = f.ItemRequest.Title;

                    <div class="review-card">
                        <div class="review-head">
                            <a href="/Profile/View/@f.ReviewerId" class="review-avatar">@rInitial</a>
                            <div class="flex-1">
                                <a href="/Profile/View/@f.ReviewerId" class="review-name">@rName</a>
                                @if (!string.IsNullOrEmpty(contextLabel))
                                {
                                    <div class="review-ctx">@contextLabel</div>
                                }
                            </div>
                            <span class="review-date">@f.CreatedAt.ToString("dd MMM yyyy")</span>
                        </div>
                        <div class="review-stars">
                            @for (int s = 1; s <= 5; s++)
                            {
                                <span style="font-size:16px;color:@(s <= f.Rating ? "#EF9F27" : "#cbd5e1");">★</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(f.Komentar))
                        {
                            <p class="review-text">@f.Komentar</p>
                        }
                        @if (!string.IsNullOrEmpty(f.FotoPath))
                        {
                            <div style="margin-top:8px;">
                                <img src="@f.FotoPath" class="review-img" onclick="window.open(this.src)" />
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>
