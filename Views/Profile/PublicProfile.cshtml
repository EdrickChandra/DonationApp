@using DonationApp.Models
@using DonationApp.Services
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var user = ViewBag.ProfileUser as ApplicationUser;
    var totalDonasi = (int)(ViewBag.TotalDonasi ?? 0);
    var totalRequest = (int)(ViewBag.TotalRequest ?? 0);
    var avgRating = (double)(ViewBag.AvgRating ?? 0.0);
    var totalReviews = (int)(ViewBag.TotalReviews ?? 0);
    var reviews = ViewBag.Reviews as List<Feedback> ?? new List<Feedback>();
    var activeDonations = ViewBag.ActiveDonations as List<Item> ?? new List<Item>();
    var activeRequests = ViewBag.ActiveRequests as List<ItemRequest> ?? new List<ItemRequest>();
    var avatarLetter = user?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
    var memberSince = user?.CreatedAt.ToString("MMMM yyyy") ?? "";
}

<div style="max-width:720px;margin:0 auto;padding:24px 16px;">

    <div style="background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:28px;margin-bottom:16px;">
        <div style="display:flex;align-items:center;gap:18px;">
            <div style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,#1e40af,#3b82f6);display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:700;color:#fff;flex-shrink:0;">
                @avatarLetter
            </div>
            <div style="flex:1;">
                <h1 style="font-size:20px;font-weight:700;color:#0f172a;margin:0 0 4px;font-family:'Plus Jakarta Sans',sans-serif;">
                    @user?.NamaDepan @user?.NamaBelakang
                </h1>
                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                    @if (!string.IsNullOrEmpty(user?.Kota) || !string.IsNullOrEmpty(user?.Provinsi))
                    {
                        <span style="font-size:12px;color:#64748b;display:flex;align-items:center;gap:3px;">
                            <i class="ti ti-map-pin" style="font-size:13px;" aria-hidden="true"></i>
                            @user?.Kota@(!string.IsNullOrEmpty(user?.Provinsi) ? ", " + user?.Provinsi : "")
                        </span>
                    }
                    <span style="font-size:12px;color:#94a3b8;display:flex;align-items:center;gap:3px;">
                        <i class="ti ti-calendar" style="font-size:13px;" aria-hidden="true"></i>
                        Bergabung @memberSince
                    </span>
                </div>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:20px;">
            <div style="text-align:center;padding:12px;background:#f8fafc;border-radius:10px;">
                <div style="font-size:22px;font-weight:700;color:#0f172a;">@totalDonasi</div>
                <div style="font-size:11px;color:#64748b;font-weight:500;">Donasi</div>
            </div>
            <div style="text-align:center;padding:12px;background:#f8fafc;border-radius:10px;">
                <div style="font-size:22px;font-weight:700;color:#0f172a;">@totalRequest</div>
                <div style="font-size:11px;color:#64748b;font-weight:500;">Request</div>
            </div>
            <div style="text-align:center;padding:12px;background:#f8fafc;border-radius:10px;">
                <div style="display:flex;align-items:center;justify-content:center;gap:4px;">
                    <span style="font-size:22px;font-weight:700;color:#0f172a;">@avgRating.ToString("0.0")</span>
                    <span style="color:#EF9F27;font-size:16px;">★</span>
                </div>
                <div style="font-size:11px;color:#64748b;font-weight:500;">@totalReviews ulasan</div>
            </div>
        </div>
    </div>

    @if (activeDonations.Any())
    {
        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:20px;margin-bottom:16px;">
            <h2 style="font-size:14px;font-weight:700;color:#0f172a;margin:0 0 14px;font-family:'Plus Jakarta Sans',sans-serif;">
                <i class="ti ti-gift" style="color:#3b82f6;" aria-hidden="true"></i> Donasi Aktif
            </h2>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px;">
                @foreach (var d in activeDonations)
                {
                    <a href="/Item/Detail/@d.Id" style="text-decoration:none;display:block;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;transition:box-shadow 0.15s;">
                        @if (d.Images.Any())
                        {
                            <img src="@d.Images.First().FilePath" style="width:100%;height:120px;object-fit:cover;display:block;" />
                        }
                        else
                        {
                            <div style="width:100%;height:120px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;color:#94a3b8;"><i class="ti ti-gift" style="font-size:28px;" aria-hidden="true"></i></div>
                        }
                        <div style="padding:10px;">
                            <div style="font-size:13px;font-weight:600;color:#0f172a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@d.NamaBarang</div>
                            <div style="font-size:11px;color:#64748b;">@CategoryHelper.DisplayName(d.Kategori)</div>
                        </div>
                    </a>
                }
            </div>
        </div>
    }

    @if (activeRequests.Any())
    {
        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:20px;margin-bottom:16px;">
            <h2 style="font-size:14px;font-weight:700;color:#0f172a;margin:0 0 14px;font-family:'Plus Jakarta Sans',sans-serif;">
                <i class="ti ti-list-search" style="color:#3b82f6;" aria-hidden="true"></i> Request Aktif
            </h2>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px;">
                @foreach (var r in activeRequests)
                {
                    <a href="/Request/Detail/@r.Id" style="text-decoration:none;display:block;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden;transition:box-shadow 0.15s;">
                        @if (r.Images.Any())
                        {
                            <img src="@r.Images.First().FilePath" style="width:100%;height:120px;object-fit:cover;display:block;" />
                        }
                        else
                        {
                            <div style="width:100%;height:120px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;color:#94a3b8;"><i class="ti ti-list-search" style="font-size:28px;" aria-hidden="true"></i></div>
                        }
                        <div style="padding:10px;">
                            <div style="font-size:13px;font-weight:600;color:#0f172a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@r.Title</div>
                            <div style="font-size:11px;color:#64748b;">@CategoryHelper.DisplayName(r.Kategori)</div>
                        </div>
                    </a>
                }
            </div>
        </div>
    }

    <div style="background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:20px;">
        <h2 style="font-size:14px;font-weight:700;color:#0f172a;margin:0 0 14px;font-family:'Plus Jakarta Sans',sans-serif;">
            <i class="ti ti-star" style="color:#EF9F27;" aria-hidden="true"></i> Ulasan (@totalReviews)
        </h2>
        @if (!reviews.Any())
        {
            <p style="font-size:13px;color:#94a3b8;text-align:center;padding:20px 0;">Belum ada ulasan.</p>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:10px;">
                @foreach (var f in reviews)
                {
                    var rInitial = f.Reviewer?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
                    var rName = f.Reviewer != null ? f.Reviewer.NamaDepan + " " + f.Reviewer.NamaBelakang : "Anonim";
                    var contextLabel = "";
                    if (f.ClaimRequest?.Item != null) contextLabel = f.ClaimRequest.Item.NamaBarang;
                    else if (f.ItemRequest != null) contextLabel = f.ItemRequest.Title;

                    <div style="padding:14px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;">
                        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                            <a href="/Profile/View/@f.ReviewerId" style="width:28px;height:28px;border-radius:50%;background:#3b82f6;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0;text-decoration:none;">@rInitial</a>
                            <div style="flex:1;">
                                <a href="/Profile/View/@f.ReviewerId" style="font-size:13px;font-weight:600;color:#0f172a;text-decoration:none;">@rName</a>
                                @if (!string.IsNullOrEmpty(contextLabel))
                                {
                                    <div style="font-size:11px;color:#94a3b8;">@contextLabel</div>
                                }
                            </div>
                            <span style="font-size:11px;color:#94a3b8;">@f.CreatedAt.ToString("dd MMM yyyy")</span>
                        </div>
                        <div style="display:flex;gap:2px;margin-bottom:6px;">
                            @for (int s = 1; s <= 5; s++)
                            {
                                <span style="font-size:14px;color:@(s <= f.Rating ? "#EF9F27" : "#cbd5e1");">★</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(f.Komentar))
                        {
                            <p style="font-size:13px;color:#334155;line-height:1.5;margin:0;">@f.Komentar</p>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>
