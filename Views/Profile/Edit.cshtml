@model DonationApp.Models.ApplicationUser

<div class="ppage">
    <div class="ppage-inner" style="max-width:560px;">

        <div class="ppage-header">
            <h1 class="ppage-title">Edit Profil</h1>
        </div>

        @if (TempData["EditSuccess"] != null)
        {
            <div style="background:var(--color-background-success);border:0.5px solid var(--color-border-success);color:var(--color-text-success);padding:10px 14px;border-radius:var(--border-radius-md);margin-bottom:16px;font-size:13px;">
                @TempData["EditSuccess"]
            </div>
        }

        <div class="preview-card" style="padding:20px;">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label class="form-label">Nama Depan</label>
                        <input class="form-input" name="NamaDepan" value="@Model.NamaDepan" required />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Nama Belakang</label>
                        <input class="form-input" name="NamaBelakang" value="@Model.NamaBelakang" />
                    </div>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <input class="form-input" value="@Model.Email" disabled />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Nomor Telepon</label>
                        <input class="form-input" name="PhoneNumber" value="@Model.PhoneNumber" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Alamat</label>
                    <input class="form-input" name="Alamat" value="@Model.Alamat" placeholder="Jl. Contoh No. 1" />
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="form-group">
                        <label class="form-label">Provinsi</label>
                        <select class="form-input" name="Provinsi" id="edit-provinsi" onchange="updateEditKota(this.value)">
                            <option value="">Pilih Provinsi</option>
                            @foreach (var prov in new[] { "Aceh","Bali","Banten","Bengkulu","DI Yogyakarta","DKI Jakarta","Gorontalo","Jambi","Jawa Barat","Jawa Tengah","Jawa Timur","Kalimantan Barat","Kalimantan Selatan","Kalimantan Tengah","Kalimantan Timur","Kalimantan Utara","Kepulauan Bangka Belitung","Kepulauan Riau","Lampung","Maluku","Maluku Utara","Nusa Tenggara Barat","Nusa Tenggara Timur","Papua","Papua Barat","Riau","Sulawesi Barat","Sulawesi Selatan","Sulawesi Tengah","Sulawesi Tenggara","Sulawesi Utara","Sumatera Barat","Sumatera Selatan","Sumatera Utara" })
                            {
                                <option selected="@(Model.Provinsi == prov)">@prov</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Kota</label>
                        <select class="form-input" name="Kota" id="edit-kota">
                            <option value="">Pilih Provinsi dulu</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Kode Pos <span style="font-weight:400;color:#94a3b8;">(opsional)</span></label>
                    <input class="form-input" name="KodePos" value="@Model.KodePos" maxlength="5" />
                </div>

                <button type="submit" class="btn btn-primary btn-block" style="margin-top:8px;">Simpan Perubahan</button>
            </form>
        </div>

    </div>
</div>

<script>
    (function() {
        var existingProvinsi = '@Model.Provinsi';
        var existingKota = '@Model.Kota';

        function updateEditKota(provinsi) {
            populateKota(provinsi, document.getElementById('edit-kota'), existingKota);
        }

        window.updateEditKota = updateEditKota;

        // Auto-populate kota on load if provinsi already set
        if (existingProvinsi) {
            var provSel = document.getElementById('edit-provinsi');
            if (provSel) provSel.value = existingProvinsi;
            updateEditKota(existingProvinsi);
        }
    })();
</script>
