@using DonationApp.Models
@using DonationApp.Services
@using System.Text.Json
@{
    var editItem = ViewBag.EditItem as Item;
    var isEdit = editItem != null;
    var pageTitle = isEdit ? "Edit Donasi" : "Buat Donasi";
    var userProvinsi = ViewBag.UserProvinsi as string ?? "";
    var userKota = ViewBag.UserKota as string ?? "";

    // For edit: use saved values; for create: fall back to user profile values
    var defaultProvinsi = isEdit ? (editItem!.Provinsi) : userProvinsi;
    var defaultKota = isEdit ? (editItem!.Lokasi) : userKota;

    Dictionary<string, string>? existingDetails = null;
    if (isEdit && !string.IsNullOrWhiteSpace(editItem!.DetailTambahan))
    {
        try { existingDetails = JsonSerializer.Deserialize<Dictionary<string, string>>(editItem.DetailTambahan!); } catch { }
    }
}

<div class="ppage">

    <div style="display:flex;align-items:center;padding:16px 20px;border-bottom:0.5px solid var(--color-border-tertiary, #cbd5e1);">
        <div class="ptab-bar" style="margin:0;border:none;">
            <a asp-controller="Donasi" asp-action="Index" class="ptab">Donasi Saya</a>
            <a asp-controller="Donasi" asp-action="PenawaranDonasi" class="ptab">Penawaran Donasi</a>
            <a asp-controller="Donasi" asp-action="Create" class="ptab @(!isEdit ? "active" : "")">Buat Donasi</a>
            @if (isEdit)
            {
                <span class="ptab active">Edit Donasi</span>
            }
        </div>
    </div>

    <div class="ppage-inner" style="max-width:600px;">

        <div class="ppage-header">
            <h1 class="ppage-title">@pageTitle</h1>
            <a asp-controller="Donasi" asp-action="Index" class="pbtn" style="font-size:12px;">
                <i class="ti ti-arrow-left" aria-hidden="true"></i> Kembali
            </a>
        </div>

        @if (TempData["DonasiError"] != null)
        {
            <div class="pform-error-banner">@TempData["DonasiError"]</div>
        }
        @if (TempData["DonasiSuccess"] != null)
        {
            <div style="background:var(--color-background-success);border:0.5px solid var(--color-border-success);color:var(--color-text-success);padding:10px 14px;border-radius:var(--border-radius-md);margin-bottom:16px;font-size:13px;">
                @TempData["DonasiSuccess"]
            </div>
        }

        <div class="preview-card" style="padding:20px;">
            <form id="donasi-form"
                  asp-controller="Donasi"
                  asp-action="@(isEdit ? "EditPost" : "Create")"
                  method="post" enctype="multipart/form-data" novalidate>
                @Html.AntiForgeryToken()
                @if (isEdit)
                {
                    <input type="hidden" name="id" value="@editItem!.Id" />
                }
                <input type="hidden" id="DetailTambahanJson" name="DetailTambahanJson" />

                <div class="pform-group">
                    <label class="pform-label">Nama Barang</label>
                    <input class="pform-input" name="NamaBarang" value="@editItem?.NamaBarang" placeholder="Masukkan nama barang..." required />
                    <span class="pform-error" data-for="NamaBarang">Nama barang wajib diisi.</span>
                </div>

                <div class="pform-group">
                    <label class="pform-label">Kategori</label>
                    <select class="pform-input" name="Kategori" id="donasi-kategori" onchange="showDonasFields(this.value)" required>
                        <option value="">Pilih Kategori</option>
                        @foreach (var cat in CategoryHelper.AllCategories())
                        {
                            <option value="@((int)cat)" selected="@(editItem != null && editItem.Kategori == cat)">@CategoryHelper.DisplayName(cat)</option>
                        }
                    </select>
                    <span class="pform-error" data-for="Kategori">Kategori wajib dipilih.</span>
                </div>

                <div id="donasi-detail-fields"></div>

                <div class="pform-group">
                    <label class="pform-label">Kondisi Barang</label>
                    <input type="hidden" id="kondisiInput" name="Kondisi" value="@((int)(editItem?.Kondisi ?? ItemCondition.Baru))" />
                    <div class="pcond-group">
                        <button type="button" class="pcond-btn @(editItem == null || editItem.Kondisi == ItemCondition.Baru ? "selected" : "")" data-value="@((int)ItemCondition.Baru)">Baru</button>
                        <button type="button" class="pcond-btn @(editItem?.Kondisi == ItemCondition.Bekas ? "selected" : "")" data-value="@((int)ItemCondition.Bekas)">Bekas</button>
                    </div>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                    <div class="pform-group">
                        <label class="pform-label">Provinsi</label>
                        <select class="pform-input" name="Provinsi" id="donasi-provinsi" onchange="updateDonasiKota(this.value)" required>
                            <option value="">Pilih Provinsi</option>
                            @foreach (var prov in new[] { "Aceh","Bali","Banten","Bengkulu","DI Yogyakarta","DKI Jakarta","Gorontalo","Jambi","Jawa Barat","Jawa Tengah","Jawa Timur","Kalimantan Barat","Kalimantan Selatan","Kalimantan Tengah","Kalimantan Timur","Kalimantan Utara","Kepulauan Bangka Belitung","Kepulauan Riau","Lampung","Maluku","Maluku Utara","Nusa Tenggara Barat","Nusa Tenggara Timur","Papua","Papua Barat","Riau","Sulawesi Barat","Sulawesi Selatan","Sulawesi Tengah","Sulawesi Tenggara","Sulawesi Utara","Sumatera Barat","Sumatera Selatan","Sumatera Utara" })
                            {
                                <option selected="@(defaultProvinsi == prov)">@prov</option>
                            }
                        </select>
                        <span class="pform-error" data-for="Provinsi">Provinsi wajib dipilih.</span>
                    </div>
                    <div class="pform-group">
                        <label class="pform-label">Kota</label>
                        <select class="pform-input" name="Lokasi" id="donasi-kota" required>
                            <option value="">Pilih Provinsi dulu</option>
                        </select>
                        <span class="pform-error" data-for="Lokasi">Kota wajib dipilih.</span>
                    </div>
                </div>

                <div class="pform-group">
                    <label class="pform-label">Jumlah Barang</label>
                    <input class="pform-input" name="Jumlah" type="number" min="1" max="99" value="@(editItem?.Jumlah ?? 1)" style="width:120px;" />
                </div>

                <div class="pform-group">
                    <label class="pform-label">Deskripsi</label>
                    <textarea class="pform-input" name="Deskripsi" rows="4" placeholder="Ceritakan kondisi barang secara detail..." required style="resize:vertical;">@editItem?.Deskripsi</textarea>
                    <span class="pform-error" data-for="Deskripsi">Deskripsi wajib diisi.</span>
                </div>

                @if (isEdit && editItem!.Images.Any())
                {
                    <div class="pform-group">
                        <label class="pform-label">Foto Saat Ini</label>
                        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:6px;">
                            @foreach (var img in editItem.Images)
                            {
                                <div style="position:relative;width:88px;height:88px;">
                                    <img src="@img.FilePath" style="width:88px;height:88px;border-radius:8px;object-fit:cover;" />
                                    <form asp-controller="Donasi" asp-action="DeleteImage" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="imageId" value="@img.Id" />
                                        <input type="hidden" name="itemId" value="@editItem.Id" />
                                        <button type="submit" style="position:absolute;top:-6px;right:-6px;width:20px;height:20px;border-radius:50%;background:#ef4444;color:#fff;border:none;cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center;">✕</button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="pform-group">
                    <label class="pform-label">
                        @(isEdit ? "Tambah Foto Baru" : "Foto Barang")
                        <span class="pform-hint">(maks. 5, 5MB, JPG/PNG)</span>
                    </label>
                    <input type="file" id="donasi-file-input" name="Images" multiple accept=".jpg,.jpeg,.png" style="display:none;" />
                    @if (!isEdit)
                    {
                        <span class="pform-error" id="donasi-image-error">Minimal 1 foto harus diunggah.</span>
                    }
                    <div id="donasi-preview" style="display:flex;flex-wrap:wrap;gap:8px;margin-top:8px;"></div>
                </div>

                <button type="submit" class="pbtn pbtn-primary pbtn-block" onclick="return validateDonasi()">
                    @(isEdit ? "Simpan Perubahan" : "Posting Donasi")
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    var isEdit = @(isEdit ? "true" : "false");
    var defaultProvinsi = '@defaultProvinsi';
    var defaultKota = '@defaultKota';
    var existingDetails = @Html.Raw(existingDetails != null ? JsonSerializer.Serialize(existingDetails) : "{}");

    function updateDonasiKota(provinsi) {
        populateKota(provinsi, document.getElementById('donasi-kota'), defaultKota);
    }

    // Auto-fill provinsi and kota on load
    (function() {
        if (defaultProvinsi) {
            var provSel = document.getElementById('donasi-provinsi');
            if (provSel) provSel.value = defaultProvinsi;
            updateDonasiKota(defaultProvinsi);
        }
    })();

    var categoryFields = {
        "@((int)ItemCategory.Pakaian)": [
            { key:"Ukuran", label:"Ukuran", type:"select", options:["XS","S","M","L","XL","XXL"] },
            { key:"JenisKelamin", label:"Jenis Kelamin", type:"select", options:["Pria","Wanita","Unisex"] }
        ],
        "@((int)ItemCategory.Elektronik)": [
            { key:"Jenis", label:"Jenis Perangkat", type:"select", options:["Laptop","Smartphone","Tablet","Kamera","TV","Printer","Lainnya"] },
            { key:"Merk", label:"Merk", type:"text", placeholder:"e.g. Samsung, Apple, Asus" }
        ],
        "@((int)ItemCategory.Buku)": [
            { key:"Jenjang", label:"Jenjang", type:"select", options:["SD","SMP","SMA","Kuliah","Umum"] },
            { key:"Subjek", label:"Subjek / Mata Pelajaran", type:"select", options:["Matematika","IPA","IPS","Bahasa","Agama","Umum","Lainnya"] }
        ],
        "@((int)ItemCategory.MainanHobi)": [
            { key:"UsiaRekomendasi", label:"Usia Rekomendasi", type:"select", options:["0-1 tahun","1-3 tahun","3-5 tahun","5-12 tahun","12+ tahun"] },
            { key:"Jenis", label:"Jenis Mainan", type:"select", options:["Edukatif","Action Figure","Boneka","Puzzle","Kendaraan","Lainnya"] }
        ],
        "@((int)ItemCategory.AlatMusik)": [
            { key:"JenisInstrumen", label:"Jenis Instrumen", type:"select", options:["Gitar","Bass","Piano/Keyboard","Drum/Perkusi","Biola/String","Tiup Kayu","Tiup Logam","Vokal/Mikrofon","DJ/Elektronik","Lainnya"] },
            { key:"Merk", label:"Merk", type:"text", placeholder:"e.g. Yamaha, Roland" }
        ]
    };

    function showDonasFields(val) {
        var container = document.getElementById('donasi-detail-fields');
        container.innerHTML = '';
        var fields = categoryFields[val];
        if (!fields) return;
        fields.forEach(function(f) {
            var div = document.createElement('div');
            div.className = 'pform-group';
            var label = document.createElement('label');
            label.className = 'pform-label';
            label.textContent = f.label;
            div.appendChild(label);
            var input;
            if (f.type === 'select') {
                input = document.createElement('select');
                input.className = 'pform-input';
                input.dataset.key = f.key;
                input.id = 'donasi-field-' + f.key;
                var empty = document.createElement('option');
                empty.value = ''; empty.textContent = 'Pilih ' + f.label;
                input.appendChild(empty);
                f.options.forEach(function(o) {
                    var opt = document.createElement('option');
                    opt.value = o; opt.textContent = o;
                    if (existingDetails && existingDetails[f.key] === o) opt.selected = true;
                    input.appendChild(opt);
                });
            } else {
                input = document.createElement('input');
                input.className = 'pform-input';
                input.type = 'text';
                input.placeholder = f.placeholder || '';
                input.dataset.key = f.key;
                input.id = 'donasi-field-' + f.key;
                if (existingDetails && existingDetails[f.key]) input.value = existingDetails[f.key];
            }
            div.appendChild(input);
            container.appendChild(div);
        });
    }

    var katEl = document.getElementById('donasi-kategori');
    if (katEl && katEl.value) showDonasFields(katEl.value);

    document.querySelectorAll('.pcond-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.pcond-btn').forEach(function(b) { b.classList.remove('selected'); });
            this.classList.add('selected');
            document.getElementById('kondisiInput').value = this.dataset.value;
        });
    });

    var imageStore = [];

    document.getElementById('donasi-file-input').addEventListener('change', function() {
        Array.from(this.files).forEach(function(f) { if (imageStore.length < 5) imageStore.push(f); });
        this.value = '';
        renderPreviews();
        syncInput();
    });

    renderPreviews();

    function renderPreviews() {
        var container = document.getElementById('donasi-preview');
        container.innerHTML = '';
        imageStore.forEach(function(file, i) {
            var reader = new FileReader();
            reader.onload = function(e) {
                var wrap = document.createElement('div');
                wrap.style.cssText = 'position:relative;width:88px;height:88px;border-radius:10px;overflow:hidden;flex-shrink:0;';
                var img = document.createElement('img');
                img.src = e.target.result;
                img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
                var del = document.createElement('button');
                del.type = 'button';
                del.style.cssText = 'position:absolute;top:4px;right:4px;width:22px;height:22px;border-radius:50%;background:rgba(0,0,0,0.55);color:#fff;border:none;cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center;line-height:1;';
                del.innerHTML = '✕';
                del.onclick = (function(idx) { return function() { imageStore.splice(idx, 1); renderPreviews(); syncInput(); }; })(i);
                wrap.appendChild(img);
                wrap.appendChild(del);
                container.appendChild(wrap);
                if (imageStore.length < 5) appendAddTile(container);
            };
            reader.readAsDataURL(file);
        });
        if (imageStore.length === 0) appendAddTile(container);
    }

    function appendAddTile(container) {
        var existing = container.querySelector('.donasi-add-tile');
        if (existing) existing.remove();
        var tile = document.createElement('div');
        tile.className = 'donasi-add-tile';
        tile.style.cssText = 'width:88px;height:88px;border-radius:10px;border:2px dashed #cbd5e1;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;color:#94a3b8;gap:4px;background:#f8fafc;flex-shrink:0;transition:all 0.15s;';
        tile.innerHTML = '<i class="ti ti-plus" style="font-size:22px;"></i><span style="font-size:10px;font-family:Plus Jakarta Sans,sans-serif;font-weight:600;">Tambah</span>';
        tile.onmouseenter = function() { tile.style.borderColor = 'var(--blue)'; tile.style.color = 'var(--blue)'; tile.style.background = '#eff6ff'; };
        tile.onmouseleave = function() { tile.style.borderColor = '#cbd5e1'; tile.style.color = '#94a3b8'; tile.style.background = '#f8fafc'; };
        tile.onclick = function() { document.getElementById('donasi-file-input').click(); };
        container.appendChild(tile);
    }

    function syncInput() {
        var dt = new DataTransfer();
        imageStore.forEach(function(f) { dt.items.add(f); });
        document.getElementById('donasi-file-input').files = dt.files;
    }

    function validateDonasi() {
        var valid = true;
        var required = [
            { name: 'NamaBarang' },
            { name: 'Kategori' },
            { name: 'Lokasi' },
            { name: 'Provinsi' },
            { name: 'Deskripsi' }
        ];
        required.forEach(function(f) {
            var el = document.querySelector('#donasi-form [name="' + f.name + '"]');
            var err = document.querySelector('#donasi-form [data-for="' + f.name + '"]');
            if (el && !el.value.trim()) {
                el.classList.add('error');
                if (err) err.style.display = 'block';
                valid = false;
            } else {
                if (el) el.classList.remove('error');
                if (err) err.style.display = 'none';
            }
        });
        if (!isEdit) {
            var imgErr = document.getElementById('donasi-image-error');
            if (imgErr && imageStore.length === 0) {
                imgErr.style.display = 'block';
                valid = false;
            } else if (imgErr) {
                imgErr.style.display = 'none';
            }
        }
        if (valid) {
            var kat = document.getElementById('donasi-kategori');
            var fields = categoryFields[kat.value];
            var result = {};
            if (fields) {
                fields.forEach(function(f) {
                    var el = document.getElementById('donasi-field-' + f.key);
                    if (el && el.value) result[f.key] = el.value;
                });
            }
            document.getElementById('DetailTambahanJson').value = Object.keys(result).length > 0 ? JSON.stringify(result) : '';
        }
        return valid;
    }
</script>
