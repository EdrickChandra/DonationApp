@using DonationApp.Models
@using DonationApp.Services
@using System.Text.Json
@{
    var editItem = ViewBag.EditItem as Item;
    var isEdit = editItem != null;
    var pageTitle = isEdit ? "Edit Donasi" : "Buat Donasi";
    var userProvinsi = ViewBag.UserProvinsi as string ?? "";
    var userKota = ViewBag.UserKota as string ?? "";
    var defaultProvinsi = isEdit ? (editItem!.Provinsi) : userProvinsi;
    var defaultKota = isEdit ? (editItem!.Lokasi) : userKota;

    Dictionary<string, string>? existingDetails = null;
    if (isEdit && !string.IsNullOrWhiteSpace(editItem!.DetailTambahan))
    {
        try { existingDetails = JsonSerializer.Deserialize<Dictionary<string, string>>(editItem.DetailTambahan!); } catch { }
    }
}

<div class="ppage">

    <div style="display:flex;align-items:center;padding:16px 20px;border-bottom:0.5px solid var(--color-border-tertiary, #cbd5e1);">
        <div class="ptab-bar" style="margin:0;border:none;">
            <a asp-controller="Donasi" asp-action="Index" class="ptab">Donasi Saya</a>
            <a asp-controller="Donasi" asp-action="PenawaranDonasi" class="ptab">Penawaran Donasi</a>
            <a asp-controller="Donasi" asp-action="Create" class="ptab @(!isEdit ? "active" : "")">Buat Donasi</a>
            @if (isEdit)
            {
                <span class="ptab active">Edit Donasi</span>
            }
        </div>
    </div>

    <div class="ppage-inner" style="max-width:600px;">

        <div class="ppage-header">
            <h1 class="ppage-title">@pageTitle</h1>
            <a asp-controller="Donasi" asp-action="Index" class="btn btn-secondary btn-sm">
                <i class="ti ti-arrow-left" aria-hidden="true"></i> Kembali
            </a>
        </div>

        @if (TempData["DonasiError"] != null)
        {
            <div class="form-error-banner">@TempData["DonasiError"]</div>
        }
        @if (TempData["DonasiSuccess"] != null)
        {
            <div class="alert-success">
                @TempData["DonasiSuccess"]
            </div>
        }

        <div class="preview-card" style="padding:20px;">
            <form id="donasi-form"
                  asp-controller="Donasi"
                  asp-action="@(isEdit ? "EditPost" : "Create")"
                  method="post" enctype="multipart/form-data" novalidate>
                @Html.AntiForgeryToken()
                @if (isEdit)
                {
                    <input type="hidden" name="id" value="@editItem!.Id" />
                }
                <input type="hidden" id="DetailTambahanJson" name="DetailTambahanJson" />

                <div class="form-group">
                    <label class="form-label">Nama Barang</label>
                    <input class="form-input" name="NamaBarang" value="@editItem?.NamaBarang" placeholder="Masukkan nama barang..." required />
                    <span class="form-error" data-for="NamaBarang">Nama barang wajib diisi.</span>
                </div>

                <div class="form-group">
                    <label class="form-label">Kategori</label>
                    <select class="form-input" name="Kategori" id="donasi-kategori" onchange="showDonasFields(this.value)" required>
                        <option value="">Pilih Kategori</option>
                        @foreach (var cat in CategoryHelper.AllCategories())
                        {
                            <option value="@((int)cat)" selected="@(editItem != null && editItem.Kategori == cat)">@CategoryHelper.DisplayName(cat)</option>
                        }
                    </select>
                    <span class="form-error" data-for="Kategori">Kategori wajib dipilih.</span>
                </div>

                <div id="donasi-detail-fields"></div>

                <div class="form-group">
                    <label class="form-label">Kondisi Barang</label>
                    <input type="hidden" id="kondisiInput" name="Kondisi" value="@((int)(editItem?.Kondisi ?? ItemCondition.Baru))" />
                    <div class="pcond-group">
                        <button type="button" class="btn-condition @(editItem == null || editItem.Kondisi == ItemCondition.Baru ? "selected" : "")" data-value="@((int)ItemCondition.Baru)">Baru</button>
                        <button type="button" class="btn-condition @(editItem?.Kondisi == ItemCondition.Bekas ? "selected" : "")" data-value="@((int)ItemCondition.Bekas)">Bekas</button>
                    </div>
                </div>

                <div class="input-row">
                    <div class="form-group">
                        <label class="form-label">Provinsi</label>
                        <select class="form-input" name="Provinsi" id="donasi-provinsi" required>
                            <option value="">Pilih Provinsi</option>
                        </select>
                        <span class="form-error" data-for="Provinsi">Provinsi wajib dipilih.</span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Kota</label>
                        <select class="form-input" name="Lokasi" id="donasi-kota" required>
                            <option value="">Pilih Provinsi dulu</option>
                        </select>
                        <span class="form-error" data-for="Lokasi">Kota wajib dipilih.</span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Jumlah Barang</label>
                    <input class="form-input" name="Jumlah" type="number" min="1" max="99" value="@(editItem?.Jumlah ?? 1)" style="width:120px;" />
                </div>

                <div class="form-group">
                    <label class="form-label">Deskripsi</label>
                    <textarea class="form-input" name="Deskripsi" rows="4" placeholder="Ceritakan kondisi barang secara detail..." required style="resize:vertical;">@editItem?.Deskripsi</textarea>
                    <span class="form-error" data-for="Deskripsi">Deskripsi wajib diisi.</span>
                </div>

                @if (isEdit && editItem!.Images.Any())
                {
                    <div class="form-group">
                        <label class="form-label">Foto Saat Ini</label>
                        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:6px;">
                            @foreach (var img in editItem.Images)
                            {
                                <div style="position:relative;width:88px;height:88px;">
                                    <img src="@img.FilePath" class="img-88" />
                                    <form asp-controller="Donasi" asp-action="DeleteImage" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="imageId" value="@img.Id" />
                                        <input type="hidden" name="itemId" value="@editItem.Id" />
                                        <button type="submit" class="img-del">✕</button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="form-group">
                    <label class="form-label">
                        @(isEdit ? "Tambah Foto Baru" : "Foto Barang")
                        <span class="form-hint">(maks. 5, 5MB, JPG/PNG)</span>
                    </label>
                    <input type="file" id="donasi-file-input" name="Images" multiple accept=".jpg,.jpeg,.png" style="display:none;" />
                    @if (!isEdit)
                    {
                        <span class="form-error" id="donasi-image-error">Minimal 1 foto harus diunggah.</span>
                    }
                    <div id="donasi-preview" style="display:flex;flex-wrap:wrap;gap:8px;margin-top:8px;"></div>
                </div>

                <button type="submit" class="btn btn-primary btn-block" onclick="return validateDonasi()">
                    @(isEdit ? "Simpan Perubahan" : "Posting Donasi")
                </button>
            </form>
        </div>
    </div>
</div>

<partial name="_CategoryFieldsScript" />
<script src="~/js/form-helpers.js" asp-append-version="true"></script>
<script>
    var isEdit = @(isEdit ? "true" : "false");
    var defaultProvinsi = '@defaultProvinsi';
    var defaultKota = '@defaultKota';
    var existingDetails = @Html.Raw(existingDetails != null ? JsonSerializer.Serialize(existingDetails) : "{}");

    initLocation('donasi-provinsi', 'donasi-kota', defaultProvinsi, defaultKota);

    function showDonasFields(val) {
        renderCategoryFields('donasi-detail-fields', 'donasi-field-', val, existingDetails);
    }

    var katEl = document.getElementById('donasi-kategori');
    if (katEl && katEl.value) showDonasFields(katEl.value);

    initConditionButtons('kondisiInput');

    var donasiUploader = initImageUploader({
        inputId: 'donasi-file-input',
        previewId: 'donasi-preview',
        max: 5,
        variant: 'grid',
        addTileClass: 'donasi-add-tile',
        renderOnInit: true
    });

    function validateDonasi() {
        var valid = true;
        var required = [
            { name: 'NamaBarang' },
            { name: 'Kategori' },
            { name: 'Lokasi' },
            { name: 'Provinsi' },
            { name: 'Deskripsi' }
        ];
        required.forEach(function(f) {
            var el = document.querySelector('#donasi-form [name="' + f.name + '"]');
            var err = document.querySelector('#donasi-form [data-for="' + f.name + '"]');
            if (el && !el.value.trim()) {
                el.classList.add('error');
                if (err) err.style.display = 'block';
                valid = false;
            } else {
                if (el) el.classList.remove('error');
                if (err) err.style.display = 'none';
            }
        });
        if (!isEdit) {
            var imgErr = document.getElementById('donasi-image-error');
            if (imgErr && donasiUploader.getCount() === 0) {
                imgErr.style.display = 'block';
                valid = false;
            } else if (imgErr) {
                imgErr.style.display = 'none';
            }
        }
        if (valid) {
            var kat = document.getElementById('donasi-kategori');
            var fields = categoryFields[kat.value];
            var result = {};
            if (fields) {
                fields.forEach(function(f) {
                    var el = document.getElementById('donasi-field-' + f.key);
                    if (el && el.value) result[f.key] = el.value;
                });
            }
            document.getElementById('DetailTambahanJson').value = Object.keys(result).length > 0 ? JSON.stringify(result) : '';
        }
        return valid;
    }
</script>
