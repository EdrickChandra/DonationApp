@using DonationApp.Models
@using DonationApp.Services
@{
    var donations = ViewBag.Donations as List<Item>;
    var selected = ViewBag.Selected as Item;
    var matchesJson = ViewBag.Matches as string;
    var matchCount = ViewBag.MatchCount as int? ?? 0;
    var matchContext = ViewBag.MatchContext as string ?? "";
    var sourceId = selected?.Id.ToString() ?? "";

    var visibleDonations = donations?
        .Where(d => d.Status != ItemStatus.Available || d.ExpiresAt > DateTime.UtcNow)
        .ToList();
}

<div class="ppage">
    <div class="ppage-inner" style="max-width:100%;padding:0;">

        <div style="display:flex;align-items:center;padding:16px 20px;border-bottom:0.5px solid var(--color-border-tertiary, #cbd5e1);">
            <div class="ptab-bar" style="margin:0;border:none;">
                <a asp-controller="Donasi" asp-action="Index" class="ptab active">Donasi Saya</a>
                <a asp-controller="Donasi" asp-action="PenawaranDonasi" class="ptab">Penawaran Donasi</a>
                <a asp-controller="Donasi" asp-action="Create" class="ptab">Buat Donasi</a>
            </div>
        </div>

        @if (TempData["DonasiSuccess"] != null)
        {
            <div style="margin:12px 16px 0;background:var(--color-background-success);border:0.5px solid var(--color-border-success);color:var(--color-text-success);padding:10px 14px;border-radius:var(--border-radius-md);font-size:15px;">
                @TempData["DonasiSuccess"]
            </div>
        }
        @if (TempData["DonasiError"] != null)
        {
            <div style="margin:12px 16px 0;" class="form-error-banner">@TempData["DonasiError"]</div>
        }

        @if (visibleDonations == null || !visibleDonations.Any())
        {
            <div class="empty-state">
                Belum ada donasi.
                <a asp-controller="Donasi" asp-action="Create" class="btn btn-primary" style="display:inline-flex;margin-top:12px;">Buat Donasi Pertama</a>
            </div>
        }
        else
        {
            <div class="psplit" style="border:none;border-radius:0;min-height:calc(100vh - 120px);">

                <div class="plist" id="donasi-list">
                    @foreach (var d in visibleDonations)
                    {
                        var activeRequests = d.ClaimRequests.Where(r =>
                            r.Status == TransactionStatus.Accepted ||
                            r.Status == TransactionStatus.Shipped ||
                            r.Status == TransactionStatus.Delivered).ToList();

                        string statusLabel;
                        string statusClass;

                        if (activeRequests.Any(r => r.Status == TransactionStatus.Shipped))
                        { statusLabel = "Dikirim"; statusClass = "badge-pending"; }
                        else if (activeRequests.Any(r => r.Status == TransactionStatus.Accepted))
                        { statusLabel = "Diterima"; statusClass = "badge-claimed"; }
                        else if (activeRequests.Any(r => r.Status == TransactionStatus.Delivered))
                        { statusLabel = "Selesai"; statusClass = "badge-available"; }
                        else
                        { statusLabel = d.Status == ItemStatus.Available ? "Tersedia" : "Diambil"; statusClass = d.Status == ItemStatus.Available ? "badge-available" : "badge-claimed"; }

                        var daysLeft = (d.ExpiresAt - DateTime.UtcNow).Days;

                        <a class="plist-item @(selected?.Id == d.Id ? "active" : "")"
                           href="/Donasi/Index?selectedId=@d.Id">
                            @if (d.Images.Any())
                            {
                                <img src="@d.Images.First().FilePath" class="plist-thumb" style="object-fit:cover;" />
                            }
                            else
                            {
                                <div class="plist-thumb"><i class="ti ti-gift" aria-hidden="true"></i></div>
                            }
                            <div class="flex-min">
                                <div class="plist-name">@d.NamaBarang</div>
                                <div class="plist-sub">
                                    @CategoryHelper.DisplayName(d.Kategori)
                                    @if (d.Status == ItemStatus.Available && !activeRequests.Any())
                                    {
                                        <span>· @daysLeft hari lagi</span>
                                    }
                                    @if (activeRequests.Any())
                                    {
                                        <span>· @activeRequests.Count penerima</span>
                                    }
                                </div>
                            </div>
                            <span class="badge @statusClass">@statusLabel</span>
                        </a>
                    }
                </div>

                <div class="pdetail" id="donasi-detail">
                    @if (selected == null || (selected.Status == ItemStatus.Available && selected.ExpiresAt <= DateTime.UtcNow))
                    {
                        <div class="pdetail-empty">Pilih donasi untuk melihat detail.</div>
                    }
                    else
                    {
                        var activeRequests = selected.ClaimRequests.Where(r =>
                            r.Status == TransactionStatus.Accepted ||
                            r.Status == TransactionStatus.Shipped ||
                            r.Status == TransactionStatus.Delivered).ToList();

                        var pendingRequests = selected.ClaimRequests.Where(r => r.Status == TransactionStatus.Pending).ToList();
                        var hasAnyActive = activeRequests.Any();

                        <div class="pdetail-header" style="display:flex;align-items:flex-start;gap:14px;margin-bottom:16px;">
                            @if (selected.Images.Any())
                            {
                                <img src="@selected.Images.First().FilePath" class="img-60" />
                            }
                            <div class="flex-1">
                                <div class="pdetail-title" style="margin-bottom:8px;">@selected.NamaBarang</div>
                                <div style="display:flex;gap:6px;flex-wrap:wrap;">
                                    <span class="badge badge-claimed">@CategoryHelper.DisplayName(selected.Kategori)</span>
                                    <span class="badge badge-muted">@selected.Kondisi</span>
                                    <span class="badge badge-muted">Sisa @selected.Jumlah pcs</span>
                                    <span class="badge badge-muted">@selected.Lokasi</span>
                                </div>
                            </div>
                            <div style="display:flex;gap:6px;flex-shrink:0;flex-wrap:wrap;justify-content:flex-end;">
                                <button onclick="runMatch(@selected.Id, this)" class="btn btn-secondary btn-sm" style="background:linear-gradient(135deg,#1e40af,#2563eb);color:#fff;border-color:#2563eb;">
                                    <i class="ti ti-search" aria-hidden="true"></i> Cari Kecocokan
                                </button>
                                @if (!hasAnyActive)
                                {
                                    <a href="/Donasi/Edit/@selected.Id" class="btn btn-secondary btn-sm">
                                        <i class="ti ti-edit" aria-hidden="true"></i> Edit
                                    </a>
                                    <form asp-controller="Donasi" asp-action="Delete" method="post" onsubmit="return confirm('Hapus donasi ini?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@selected.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="ti ti-trash" aria-hidden="true"></i> Hapus
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                        @if (hasAnyActive)
                        {
                            <div class="psec">
                                <div class="psec-label">Penerima (@activeRequests.Count)</div>
                                <div style="display:flex;flex-direction:column;gap:6px;">
                                    @foreach (var r in activeRequests)
                                    {
                                        var rAvatar = r.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
                                        var rName = r.User != null ? r.User.NamaDepan + " " + r.User.NamaBelakang : "Unknown";
                                        var rIsPickup = r.MetodePengiriman == MetodePengiriman.Pickup;
                                        var rHasFeedback = r.Feedbacks.Any(f => f.ReviewerId == r.UserId);
                                        var rStatusLabel = r.Status switch
                                        {
                                            TransactionStatus.Accepted  => "Menunggu Kirim",
                                            TransactionStatus.Shipped   => "Dikirim",
                                            TransactionStatus.Delivered => "Selesai",
                                            _ => ""
                                        };
                                        var rStatusClass = r.Status switch
                                        {
                                            TransactionStatus.Accepted  => "badge-claimed",
                                            TransactionStatus.Shipped   => "badge-pending",
                                            TransactionStatus.Delivered => "badge-available",
                                            _ => "badge-muted"
                                        };
                                        <div>
                                            <div class="penerima-row" onclick="togglePenerima('penerima-detail-@r.Id')"
                                                 style="display:flex;align-items:center;gap:10px;padding:10px 12px;background:#e2e8f0;border-radius:8px;cursor:pointer;border:1px solid #c4c9d4;transition:background 0.15s;">
                                                <a href="/Profile/View/@r.UserId" class="avatar avatar-sm" style="text-decoration:none;color:#fff;" onclick="event.stopPropagation();">@rAvatar</a>
                                                <div class="flex-1">
                                                    <a href="/Profile/View/@r.UserId" class="text-strong" style="text-decoration:none;" onclick="event.stopPropagation();">@rName</a>
                                                    <div class="text-xs-muted">@r.Jumlah pcs · @r.User?.Kota - @r.User?.Provinsi</div>
                                                </div>
                                                <span class="badge @rStatusClass" style="font-size:12px;">@rStatusLabel</span>
                                                <i class="ti ti-chevron-down" id="chevron-@r.Id" style="font-size:16px;color:#64748b;transition:transform 0.2s;" aria-hidden="true"></i>
                                            </div>
                                            <div id="penerima-detail-@r.Id" style="display:none;padding:12px;background:#f8fafc;border:1px solid #c4c9d4;border-top:none;border-radius:0 0 8px 8px;margin-bottom:2px;">
                                                <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                                                    <form asp-controller="Donasi" asp-action="Chat" method="post" style="margin-left:auto;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="itemId" value="@selected.Id" />
                                                        <input type="hidden" name="otherUserId" value="@r.UserId" />
                                                        <button type="submit" class="btn btn-primary btn-sm">
                                                            <i class="ti ti-message-2" aria-hidden="true"></i> Chat
                                                        </button>
                                                    </form>
                                                </div>
                                                <div class="pstepper" style="margin-bottom:10px;">
                                                    <div class="pstep @(r.Status >= TransactionStatus.Accepted ? "done" : "")">
                                                        <div class="pstep-dot @(r.Status >= TransactionStatus.Accepted ? "done" : "")"><i class="ti ti-check" aria-hidden="true"></i></div>
                                                        <div class="pstep-label">Disetujui</div>
                                                    </div>
                                                    <div class="pstep-line @(r.Status >= TransactionStatus.Shipped ? "done" : "")"></div>
                                                    <div class="pstep @(r.Status >= TransactionStatus.Shipped ? "done" : "")">
                                                        <div class="pstep-dot @(r.Status >= TransactionStatus.Shipped ? "done" : "")"><i class="ti @(rIsPickup ? "ti-walk" : "ti-truck")" aria-hidden="true"></i></div>
                                                        <div class="pstep-label">@(rIsPickup ? "Pickup" : "Dikirim")</div>
                                                    </div>
                                                    <div class="pstep-line @(r.Status >= TransactionStatus.Delivered ? "done" : "")"></div>
                                                    <div class="pstep @(r.Status >= TransactionStatus.Delivered ? "done" : "")">
                                                        <div class="pstep-dot @(r.Status >= TransactionStatus.Delivered ? "done" : "")"><i class="ti ti-package" aria-hidden="true"></i></div>
                                                        <div class="pstep-label">@(rIsPickup ? "Selesai" : "Diterima")</div>
                                                    </div>
                                                    <div class="pstep-line @(rHasFeedback ? "done" : "")"></div>
                                                    <div class="pstep @(rHasFeedback ? "done" : "")">
                                                        <div class="pstep-dot @(rHasFeedback ? "done" : "")"><i class="ti ti-star" aria-hidden="true"></i></div>
                                                        <div class="pstep-label">Feedback</div>
                                                    </div>
                                                </div>
                                                @if (r.Status == TransactionStatus.Accepted && r.MetodePengiriman == MetodePengiriman.BelumDipilih)
                                                {
                                                    <p style="font-size:14px;color:#64748b;text-align:center;">Menunggu penerima memilih metode pengiriman...</p>
                                                }
                                                else if (r.Status == TransactionStatus.Accepted)
                                                {
                                                    <div style="text-align:center;margin-bottom:8px;">
                                                        <span style="font-size:14px;color:#3b82f6;font-weight:600;">
                                                            <i class="ti @(rIsPickup ? "ti-walk" : "ti-truck")" aria-hidden="true"></i>
                                                            @(rIsPickup ? "Pickup" : "Kurir")
                                                        </span>
                                                        @if (rIsPickup)
                                                        {
                                                            <p style="font-size:14px;color:#64748b;margin-top:4px;">Chat dengan penerima untuk mengatur penjemputan</p>
                                                        }
                                                        else
                                                        {
                                                            <div style="background:#f0f9ff;border:1px solid #bae6fd;border-radius:8px;padding:10px 14px;margin-top:8px;text-align:left;">
                                                                <div style="font-size:13px;color:#0369a1;font-weight:600;margin-bottom:4px;">
                                                                    <i class="ti ti-map-pin" aria-hidden="true"></i> Alamat Penerima
                                                                </div>
                                                                <div style="font-size:15px;color:#0c4a6e;">@r.User?.Alamat</div>
                                                                <div style="font-size:14px;color:#0369a1;">@r.User?.Kota - @r.User?.Provinsi</div>
                                                            </div>
                                                        }
                                                    </div>
                                                    <form asp-controller="Donasi" asp-action="MarkShipped" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="claimRequestId" value="@r.Id" />
                                                        <button type="submit" class="btn btn-primary btn-block">
                                                            <i class="ti @(rIsPickup ? "ti-walk" : "ti-truck")" aria-hidden="true"></i>
                                                            @(rIsPickup ? "Tandai Sudah Di-pickup" : "Tandai Sudah Dikirim")
                                                        </button>
                                                    </form>
                                                }
                                                else if (r.Status == TransactionStatus.Shipped)
                                                {
                                                    <p style="font-size:14px;color:#64748b;text-align:center;">Menunggu konfirmasi penerima...</p>
                                                }
                                                else if (r.Status == TransactionStatus.Delivered)
                                                {
                                                    <p class="text-success-center"><i class="ti ti-check" aria-hidden="true"></i> Barang telah diterima</p>
                                                    var claimFeedback = r.Feedbacks
                                                        .FirstOrDefault(f => f.ReviewerId == r.UserId);
                                                    @if (claimFeedback != null)
                                                    {
                                                        <div style="padding:12px;background:#f1f5f9;border-radius:8px;margin-top:10px;">
                                                            <div style="font-size:13px;color:#94a3b8;font-weight:600;margin-bottom:4px;">Feedback dari Penerima</div>
                                                            <div style="display:flex;gap:2px;margin-bottom:4px;">
                                                                @for (int s = 1; s <= 5; s++)
                                                                {
                                                                    <span style="font-size:16px;color:@(s <= claimFeedback.Rating ? "#EF9F27" : "#cbd5e1");">★</span>
                                                                }
                                                            </div>
                                                            @if (!string.IsNullOrEmpty(claimFeedback.Komentar))
                                                            {
                                                                <p style="font-size:14px;color:#64748b;margin:0;">@claimFeedback.Komentar</p>
                                                            }
                                                            @if (!string.IsNullOrEmpty(claimFeedback.FotoPath))
                                                            {
                                                                <div style="margin-top:6px;">
                                                                    <img src="@claimFeedback.FotoPath" style="max-width:120px;max-height:120px;border-radius:6px;object-fit:cover;cursor:pointer;" onclick="window.open(this.src)" />
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @if (selected.Jumlah <= 0 && !hasAnyActive)
                        {
                            <div class="psec">
                                <div style="display:flex;align-items:center;gap:8px;padding:4px 0;">
                                    <span class="badge badge-muted">Stok Habis</span>
                                    <span style="font-size:14px;color:#64748b;">Tidak dapat menerima permintaan baru.</span>
                                </div>
                            </div>
                        }

                        <div class="psec">
                            <div class="psec-label">Permintaan Masuk (@pendingRequests.Count)</div>
                            @if (!pendingRequests.Any())
                            {
                                <p style="font-size:15px;color:#64748b;text-align:center;padding:12px 0;">Belum ada permintaan.</p>
                            }
                            @foreach (var r in pendingRequests)
                            {
                                var rAvatar = r.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
                                var rName = r.User != null ? r.User.NamaDepan + " " + r.User.NamaBelakang : "Unknown";
                                <div class="preq-row">
                                    <a href="/Profile/View/@r.UserId" class="avatar avatar-sm" style="text-decoration:none;color:#fff;">@rAvatar</a>
                                    <div class="flex-1">
                                        <a href="/Profile/View/@r.UserId" class="preq-name" style="text-decoration:none;">@rName</a>
                                        <div class="text-xs-muted">Minta @r.Jumlah pcs</div>
                                    </div>
                                    <div class="preq-actions">
                                        @if (selected.Jumlah > 0)
                                        {
                                            <form asp-controller="Donasi" asp-action="Accept" method="post" style="display:inline;" onsubmit="return confirm('Terima permintaan dari @rName?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="requestId" value="@r.Id" />
                                                <button type="submit" class="btn btn-success btn-sm">Terima</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button class="btn btn-secondary btn-sm" style="opacity:0.5;" disabled>Stok Habis</button>
                                        }
                                        <form asp-controller="Donasi" asp-action="Reject" method="post" style="display:inline;" onsubmit="return confirm('Tolak permintaan dari @rName?')">

                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="requestId" value="@r.Id" />
                                            <button type="submit" class="btn btn-danger btn-sm">Tolak</button>
                                        </form>
                                        <form asp-controller="Donasi" asp-action="Chat" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="itemId" value="@selected.Id" />
                                            <input type="hidden" name="otherUserId" value="@r.UserId" />
                                            <button type="submit" class="btn btn-primary btn-sm">Chat</button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@await Html.PartialAsync("~/Views/Profile/Bar/_MatchModal.cshtml", new ViewDataDictionary(Html.MetadataProvider, Html.ViewData.ModelState) {
    { "MatchesJson", matchesJson },
    { "MatchCount", matchCount },
    { "MatchContext", matchContext },
    { "SourceId", sourceId }
})

<script>
    function togglePenerima(detailId) {
        var el = document.getElementById(detailId);
        if (!el) return;
        var isOpen = el.style.display !== 'none';
        var requestId = detailId.replace('penerima-detail-', '');
        var chevron = document.getElementById('chevron-' + requestId);
        el.style.display = isOpen ? 'none' : 'block';
        if (chevron) chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
    }

    (function() {
        var forms = document.querySelectorAll('#donasi-detail form[method="post"]');
        forms.forEach(function(form) {
            form.addEventListener('submit', function() {
                var panel = form.closest('[id^="penerima-detail-"]');
                if (panel) {
                    sessionStorage.setItem('expandPanel', panel.id);
                }
            });
        });

        var panelId = sessionStorage.getItem('expandPanel');
        if (panelId) {
            sessionStorage.removeItem('expandPanel');
            var el = document.getElementById(panelId);
            if (el) {
                el.style.display = 'block';
                var reqId = panelId.replace('penerima-detail-', '');
                var chevron = document.getElementById('chevron-' + reqId);
                if (chevron) chevron.style.transform = 'rotate(180deg)';
                el.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }
    })();

    function runMatch(itemId, btn) {
        var orig = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="ti ti-loader-2" aria-hidden="true" style="animation:spin 0.6s linear infinite;display:inline-block;"></i>';

        fetch('/Donasi/FindMatches?itemId=' + itemId)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            btn.disabled = false;
            btn.innerHTML = orig;
            if (data.success) {
                window.openMatchModal(data.matches, data.context, data.sourceId);
            } else {
                alert(data.error || 'Gagal mencari kecocokan.');
            }
        })
        .catch(function() {
            btn.disabled = false;
            btn.innerHTML = orig;
            alert('Terjadi kesalahan. Coba lagi.');
        });
    }
</script>
