@using DonationApp.Models
@using DonationApp.Services
@{
    var myOffers = ViewBag.MyOffers as List<RequestOffer>;
    var selected = ViewBag.Selected as RequestOffer;
}

<div class="ppage">
    <div class="ppage-inner ppage-inner--flush">

        <div class="ptab-header">
            <div class="ptab-bar ptab-bar--flush">
                <a asp-controller="Donasi" asp-action="Index" class="ptab">Donasi Saya</a>
                <a asp-controller="Donasi" asp-action="PenawaranDonasi" class="ptab active">Penawaran Donasi</a>
                <a asp-controller="Donasi" asp-action="Create" class="ptab">Buat Donasi</a>
            </div>
        </div>

        @if (myOffers == null || !myOffers.Any())
        {
            <div class="empty-state">
                <i class="ti ti-package-off empty-icon" aria-hidden="true"></i>
                <p class="pempty-text">Belum ada penawaran yang dibuat.</p>
                <a asp-controller="Request" asp-action="Index" class="btn btn-primary">Lihat Request Barang</a>
            </div>
        }
        else
        {
            <div class="psplit psplit--flush">

                <div class="plist" id="penawaran-list">
                    @foreach (var offer in myOffers)
                    {
                        var req = offer.ItemRequest;
                        var firstReqImg = req?.Images.FirstOrDefault();

                        string statusLabel;
                        string statusClass;
                        switch (offer.Status)
                        {
                            case TransactionStatus.Accepted:
                                statusLabel = "Diterima"; statusClass = "badge-claimed"; break;
                            case TransactionStatus.Shipped:
                                statusLabel = "Dikirim"; statusClass = "badge-pending"; break;
                            case TransactionStatus.Delivered:
                                statusLabel = "Selesai"; statusClass = "badge-available"; break;
                            case TransactionStatus.Rejected:
                                statusLabel = "Ditolak"; statusClass = "badge-rejected"; break;
                            default:
                                statusLabel = "Menunggu"; statusClass = "badge-muted"; break;
                        }

                        <a class="plist-item @(selected?.Id == offer.Id ? "active" : "")"
                           href="/Donasi/PenawaranDonasi?selectedId=@offer.Id">
                            @if (firstReqImg != null)
                            {
                                <img src="@firstReqImg.FilePath" class="plist-thumb img-cover-fill" />
                            }
                            else
                            {
                                <div class="plist-thumb"><i class="ti ti-list-search" aria-hidden="true"></i></div>
                            }
                            <div class="flex-min">
                                <div class="plist-name">@(req?.Title ?? "Request dihapus")</div>
                                <div class="plist-sub">@offer.NamaBarang · @offer.Jumlah pcs</div>
                            </div>
                            <span class="badge @statusClass">@statusLabel</span>
                        </a>
                    }
                </div>

                <div class="pdetail" id="penawaran-detail">
                    @if (selected == null)
                    {
                        <div class="pdetail-empty">Pilih penawaran untuk melihat detail.</div>
                    }
                    else
                    {
                        var req = selected.ItemRequest;
                        var firstReqImg = req?.Images.FirstOrDefault();
                        var reqOwnerInitial = req?.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
                        var reqOwnerName = req?.User != null ? req.User.NamaDepan + " " + req.User.NamaBelakang : "Unknown";

                        string statusLabel; string statusClass; string statusDesc; string dotColor;
                        switch (selected.Status)
                        {
                            case TransactionStatus.Accepted:
                                statusLabel = "Diterima"; statusClass = "badge-claimed";
                                statusDesc = "Penawaran Anda diterima — siap untuk dikirim.";
                                dotColor = "#2563eb"; break;
                            case TransactionStatus.Shipped:
                                statusLabel = "Dikirim"; statusClass = "badge-pending";
                                statusDesc = "Barang sudah ditandai dikirim. Menunggu konfirmasi penerimaan.";
                                dotColor = "#f59e0b"; break;
                            case TransactionStatus.Delivered:
                                statusLabel = "Selesai"; statusClass = "badge-available";
                                statusDesc = "Barang telah diterima. Transaksi selesai.";
                                dotColor = "#22c55e"; break;
                            case TransactionStatus.Rejected:
                                statusLabel = "Ditolak"; statusClass = "badge-rejected";
                                statusDesc = "Penawaran Anda tidak dipilih kali ini.";
                                dotColor = "#ef4444"; break;
                            default:
                                statusLabel = "Menunggu"; statusClass = "badge-muted";
                                statusDesc = "Menunggu konfirmasi dari peminta.";
                                dotColor = "#f59e0b"; break;
                        }

                        <div class="pdetail-head-row">
                            @if (firstReqImg != null)
                            {
                                <img src="@firstReqImg.FilePath" class="img-60" />
                            }
                            else
                            {
                                <div class="plist-thumb plist-thumb--60"><i class="ti ti-list-search icon-22" aria-hidden="true"></i></div>
                            }
                            <div class="flex-1">
                                <div class="plabel-up">Request dari</div>
                                <div class="pdetail-title" style="margin-bottom:8px;">@(req?.Title ?? "Request dihapus")</div>
                                <a href="/Profile/View/@req?.UserId" class="powner-link" onclick="event.stopPropagation();">
                                    <div class="pmini-avatar">@reqOwnerInitial</div>
                                    <span class="text-sm-muted">@reqOwnerName</span>
                                </a>
                            </div>
                            <div class="pdetail-side">
                                <span class="badge @statusClass">@statusLabel</span>
                                @if (req != null)
                                {
                                    <a asp-controller="Request" asp-action="Detail" asp-route-id="@req.Id" class="plink-sm">Lihat request →</a>
                                }
                                @if (selected.Status >= TransactionStatus.Accepted && selected.Status <= TransactionStatus.Delivered)
                                {
                                    <form asp-controller="Request" asp-action="Chat" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="offerId" value="@selected.Id" />
                                        <button type="submit" class="btn btn-primary btn-sm" style="font-size:13px;">
                                            <i class="ti ti-message-2" aria-hidden="true"></i> Chat
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                        <div class="psec">
                            <div class="psec-label">Penawaran Anda</div>
                            <div class="prow-top">
                                @if (selected.Images.Any())
                                {
                                    <img src="@selected.Images.First().FilePath" class="img-64" />
                                }
                                <div class="flex-1">
                                    <div class="poffer-itemname">@selected.NamaBarang</div>
                                    <div class="poffer-badges">
                                        <span class="badge badge-muted">@selected.Kondisi</span>
                                        <span class="badge badge-muted">@selected.Jumlah pcs</span>
                                        @if (!string.IsNullOrEmpty(selected.Lokasi))
                                        {
                                            <span class="badge badge-muted">
                                                <i class="ti ti-map-pin icon-12" aria-hidden="true"></i>
                                                @selected.Lokasi@(!string.IsNullOrEmpty(selected.Provinsi) ? ", " + selected.Provinsi : "")
                                            </span>
                                        }
                                    </div>
                                    <div class="poffer-desc">@selected.Deskripsi</div>
                                </div>
                            </div>
                        </div>

                        @if (selected.Status != TransactionStatus.Pending && selected.Status != TransactionStatus.Rejected)
                        {
                            var poIsPickup = selected.ItemRequest.MetodePengiriman == MetodePengiriman.Pickup;
                            var poHasFeedback = selected.ItemRequest.Feedbacks.Any(f => f.ReviewerId == selected.ItemRequest.UserId && f.ReviewedUserId == selected.UserId);
                            <div class="psec">
                                <div class="psec-label">Status Pengiriman</div>
                                <div class="pstepper" style="margin-bottom:14px;">
                                    <div class="pstep done">
                                        <div class="pstep-dot done"><i class="ti ti-check" aria-hidden="true"></i></div>
                                        <div class="pstep-label">Diterima</div>
                                    </div>
                                    <div class="pstep-line @(selected.Status >= TransactionStatus.Shipped ? "done" : "")"></div>
                                    <div class="pstep @(selected.Status >= TransactionStatus.Shipped ? "done" : "")">
                                        <div class="pstep-dot @(selected.Status >= TransactionStatus.Shipped ? "done" : "")"><i class="ti @(poIsPickup ? "ti-walk" : "ti-truck")" aria-hidden="true"></i></div>
                                        <div class="pstep-label">@(poIsPickup ? "Pickup" : "Dikirim")</div>
                                    </div>
                                    <div class="pstep-line @(selected.Status == TransactionStatus.Delivered ? "done" : "")"></div>
                                    <div class="pstep @(selected.Status == TransactionStatus.Delivered ? "done" : "")">
                                        <div class="pstep-dot @(selected.Status == TransactionStatus.Delivered ? "done" : "")"><i class="ti ti-package" aria-hidden="true"></i></div>
                                        <div class="pstep-label">@(poIsPickup ? "Selesai" : "Diterima")</div>
                                    </div>
                                    <div class="pstep-line @(poHasFeedback ? "done" : "")"></div>
                                    <div class="pstep @(poHasFeedback ? "done" : "")">
                                        <div class="pstep-dot @(poHasFeedback ? "done" : "")"><i class="ti ti-star" aria-hidden="true"></i></div>
                                        <div class="pstep-label">Feedback</div>
                                    </div>
                                </div>

                                @if (selected.Status == TransactionStatus.Accepted && selected.ItemRequest.MetodePengiriman == MetodePengiriman.BelumDipilih)
                                {
                                    <p class="ptext-center-sm">Menunggu peminta memilih metode pengiriman...</p>
                                }
                                else if (selected.Status == TransactionStatus.Accepted)
                                {
                                    <div style="text-align:center;margin-bottom:8px;">
                                        <span class="pmethod-tag">
                                            <i class="ti @(poIsPickup ? "ti-walk" : "ti-truck")" aria-hidden="true"></i>
                                            @(poIsPickup ? "Pickup" : "Kurir")
                                        </span>
                                        @if (poIsPickup)
                                        {
                                            <p class="ptext-note">Chat dengan peminta untuk mengatur penjemputan</p>
                                        }
                                        else
                                        {
                                            <div class="ppickup-box">
                                                <div class="ppickup-title">
                                                    <i class="ti ti-map-pin" aria-hidden="true"></i> Alamat Penerima
                                                </div>
                                                <div class="ppickup-addr">@selected.ItemRequest?.User?.Alamat</div>
                                                <div class="ppickup-loc">@selected.ItemRequest?.User?.Kota - @selected.ItemRequest?.User?.Provinsi</div>
                                            </div>
                                        }
                                    </div>
                                    <form asp-controller="Request" asp-action="MarkOfferShipped" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="offerId" value="@selected.Id" />
                                        <button type="submit" class="btn btn-primary btn-block" style="font-size:14px;">
                                            <i class="ti @(poIsPickup ? "ti-walk" : "ti-truck")" aria-hidden="true"></i>
                                            @(poIsPickup ? "Tandai Sudah Di-pickup" : "Tandai Sudah Dikirim")
                                        </button>
                                    </form>
                                }
                                else if (selected.Status == TransactionStatus.Shipped)
                                {
                                    <p class="ptext-center-sm">Menunggu konfirmasi penerima...</p>
                                }
                                else if (selected.Status == TransactionStatus.Delivered)
                                {
                                    <p class="text-success-center"><i class="ti ti-check" aria-hidden="true"></i> Barang telah dikonfirmasi diterima</p>
                                    var requesterFeedback = selected.ItemRequest?.Feedbacks
                                        .FirstOrDefault(f => f.ReviewerId == selected.ItemRequest.UserId && f.ReviewedUserId == selected.UserId);
                                    @if (requesterFeedback != null)
                                    {
                                        <div class="pfeedback-box" style="padding:12px;margin-top:10px;">
                                            <div class="pfeedback-label">Feedback dari Peminta</div>
                                            <div class="pfeedback-stars">
                                                @for (int s = 1; s <= 5; s++)
                                                {
                                                    <span style="font-size:16px;color:@(s <= requesterFeedback.Rating ? "#EF9F27" : "#cbd5e1");">★</span>
                                                }
                                            </div>
                                            @if (!string.IsNullOrEmpty(requesterFeedback.Komentar))
                                            {
                                                <p class="penerima-meta" style="margin:0;">@requesterFeedback.Komentar</p>
                                            }
                                            @if (!string.IsNullOrEmpty(requesterFeedback.FotoPath))
                                            {
                                                <div style="margin-top:6px;">
                                                    <img src="@requesterFeedback.FotoPath" class="pfeedback-img" onclick="window.open(this.src)" />
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        }
                        else
                        {
                            <div class="psec">
                                <div class="psec-label">Status</div>
                                <div class="pstock-row">
                                    <div class="pstatus-dot" style="background:@dotColor;"></div>
                                    <span class="ptext-desc">@statusDesc</span>
                                </div>
                                <div class="ptext-ago">Ditawarkan @((DateTime.UtcNow - selected.CreatedAt).Days) hari lalu</div>
                            </div>
                        }

                    }
                </div>

            </div>
        }
    </div>
</div>
