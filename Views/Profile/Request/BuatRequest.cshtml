@using DonationApp.Models
@using DonationApp.Services
@using System.Text.Json
@{
    var userAlamat = ViewBag.UserAlamat as string ?? "";
    var userProvinsi = ViewBag.UserProvinsi as string ?? "";
    var editRequest = ViewBag.EditRequest as ItemRequest;
    var isEdit = editRequest != null;
    var pageTitle = isEdit ? "Edit Request" : "Buat Request";

    Dictionary<string, string>? existingDetails = null;
    if (isEdit && !string.IsNullOrWhiteSpace(editRequest!.DetailTambahan))
    {
        try { existingDetails = JsonSerializer.Deserialize<Dictionary<string, string>>(editRequest.DetailTambahan!); } catch { }
    }
}

<div class="ppage">

    <div style="padding:16px 20px 0;border-bottom:0.5px solid #cbd5e1;">
        <div class="ptab-bar" style="margin:0;border:none;">
            <a asp-controller="Request" asp-action="MyRequests" class="ptab">Request Saya</a>
            <a asp-controller="Request" asp-action="Permintaan" class="ptab">Permintaan Donasi</a>
            <a asp-controller="Request" asp-action="CreateView" class="ptab @(!isEdit ? "active" : "")">Buat Request</a>
            @if (isEdit)
            {
                <span class="ptab active">Edit Request</span>
            }
        </div>
    </div>

    <div class="ppage-inner" style="max-width:600px;">

        <div class="ppage-header">
            <h1 class="ppage-title">@pageTitle</h1>
            <a asp-controller="Request" asp-action="MyRequests" class="btn btn-secondary btn-sm">
                <i class="ti ti-arrow-left" aria-hidden="true"></i> Kembali
            </a>
        </div>

        @if (TempData["RequestError"] != null)
        {
            <div class="form-error-banner">@TempData["RequestError"]</div>
        }
        @if (TempData["RequestSuccess"] != null)
        {
            <div style="background:var(--color-background-success);border:0.5px solid var(--color-border-success);color:var(--color-text-success);padding:10px 14px;border-radius:var(--border-radius-md);margin-bottom:16px;font-size:13px;">
                @TempData["RequestSuccess"]
            </div>
        }

        <div class="preview-card" style="padding:20px;">
            <form id="req-form"
                  asp-controller="Request"
                  asp-action="@(isEdit ? "EditPost" : "Create")"
                  method="post" enctype="multipart/form-data" novalidate>
                @Html.AntiForgeryToken()
                @if (isEdit)
                {
                    <input type="hidden" name="id" value="@editRequest!.Id" />
                }
                <input type="hidden" id="ReqDetailTambahanJson" name="DetailTambahanJson" />

                <div class="form-group">
                    <label class="form-label">Judul Request</label>
                    <input class="form-input" name="Title" value="@editRequest?.Title" placeholder="Cari sepatu ukuran 42..." required />
                    <span class="form-error" data-for="Title">Judul request wajib diisi.</span>
                </div>

                <div class="form-group">
                    <label class="form-label">Kategori</label>
                    <select class="form-input" name="Kategori" id="req-kategori" onchange="showReqFields(this.value)" required>
                        <option value="">Pilih Kategori</option>
                        @foreach (var cat in CategoryHelper.AllCategories())
                        {
                            <option value="@((int)cat)" selected="@(editRequest != null && editRequest.Kategori == cat)">@CategoryHelper.DisplayName(cat)</option>
                        }
                    </select>
                    <span class="form-error" data-for="Kategori">Kategori wajib dipilih.</span>
                </div>

                <div id="req-detail-fields"></div>

                <div class="form-group">
                    <label class="form-label">Kondisi Minimum</label>
                    <button type="button" class="btn-condition" data-value="0">Baru</button>
                    <button type="button" class="btn-condition" data-value="1">Bekas</button>
                </div>

                <div class="form-group">
                    <label class="form-label">Jumlah yang Dibutuhkan</label>
                    <input class="form-input" name="Jumlah" type="number" min="1" max="99" value="@(editRequest?.Jumlah ?? 1)" style="width:120px;" />
                </div>

                <div class="input-row">
                    <div class="form-group">
                        <label class="form-label">Provinsi</label>
                        <select class="form-input" name="Provinsi" id="req-provinsi" onchange="updateReqKota(this.value)" required>
                            <option value="">Pilih Provinsi</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Kota</label>
                        <select class="form-input" name="Lokasi" id="req-kota" required>
                            <option value="">Pilih Provinsi dulu</option>
                        </select>
                        <span class="form-error" data-for="Lokasi">Kota wajib dipilih.</span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Deskripsi</label>
                    <textarea class="form-input" name="Deskripsi" rows="4" placeholder="Jelaskan barang yang Anda cari secara detail..." required style="resize:vertical;">@editRequest?.Deskripsi</textarea>
                    <span class="form-error" data-for="Deskripsi">Deskripsi wajib diisi.</span>
                </div>

                @if (isEdit && editRequest!.Images.Any())
                {
                    <div class="form-group">
                        <label class="form-label">Foto Saat Ini</label>
                        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:6px;">
                            @foreach (var img in editRequest.Images)
                            {
                                <div style="position:relative;width:88px;height:88px;">
                                    <img src="@img.FilePath" class="img-88" />
                                    <form asp-controller="Request" asp-action="DeleteRequestImage" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="imageId" value="@img.Id" />
                                        <input type="hidden" name="requestId" value="@editRequest.Id" />
                                        <button type="submit" style="position:absolute;top:-6px;right:-6px;width:20px;height:20px;border-radius:50%;background:#ef4444;color:#fff;border:none;cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center;">✕</button>
                                    </form>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="form-group">
                    <label class="form-label">
                        @(isEdit ? "Tambah Foto Baru" : "Foto Referensi")
                        <span class="form-hint">(opsional, maks. 5, 5MB, JPG/PNG)</span>
                    </label>
                    <input type="file" id="req-file-input" name="Images" multiple accept=".jpg,.jpeg,.png" style="display:none;" />
                    <div id="req-preview" style="display:flex;flex-wrap:wrap;gap:8px;margin-top:8px;"></div>
                </div>

                <button type="submit" class="btn btn-primary btn-block" onclick="return validateReq()">
                    @(isEdit ? "Simpan Perubahan" : "Post Request")
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    var isEdit = @(isEdit ? "true" : "false");
    var existingProvinsi = '@(editRequest?.Provinsi ?? userProvinsi)';
    var existingLokasi = '@(editRequest?.Lokasi ?? "")';
    var existingDetails = @Html.Raw(existingDetails != null ? JsonSerializer.Serialize(existingDetails) : "{}");

    var categoryFields = {
        "@((int)ItemCategory.Pakaian)": [
            { key:"Ukuran", label:"Ukuran", type:"select", options:["XS","S","M","L","XL","XXL"] },
            { key:"JenisKelamin", label:"Jenis Kelamin", type:"select", options:["Pria","Wanita","Unisex"] }
        ],
        "@((int)ItemCategory.Elektronik)": [
            { key:"Jenis", label:"Jenis Perangkat", type:"select", options:["Laptop","Smartphone","Tablet","Kamera","TV","Printer","Lainnya"] },
            { key:"Merk", label:"Merk", type:"text", placeholder:"e.g. Samsung, Apple, Asus" }
        ],
        "@((int)ItemCategory.Buku)": [
            { key:"Jenjang", label:"Jenjang", type:"select", options:["SD","SMP","SMA","Kuliah","Umum"] },
            { key:"Subjek", label:"Subjek / Mata Pelajaran", type:"select", options:["Matematika","IPA","IPS","Bahasa","Agama","Umum","Lainnya"] }
        ],
        "@((int)ItemCategory.MainanHobi)": [
            { key:"UsiaRekomendasi", label:"Usia Rekomendasi", type:"select", options:["0-1 tahun","1-3 tahun","3-5 tahun","5-12 tahun","12+ tahun"] },
            { key:"Jenis", label:"Jenis Mainan", type:"select", options:["Edukatif","Action Figure","Boneka","Puzzle","Kendaraan","Lainnya"] }
        ],
        "@((int)ItemCategory.AlatMusik)": [
            { key:"JenisInstrumen", label:"Jenis Instrumen", type:"select", options:["Gitar","Bass","Piano/Keyboard","Drum/Perkusi","Biola/String","Tiup Kayu","Tiup Logam","Vokal/Mikrofon","DJ/Elektronik","Lainnya"] },
            { key:"Merk", label:"Merk", type:"text", placeholder:"e.g. Yamaha, Roland" }
        ]
    };

    function showReqFields(val) {
        var container = document.getElementById('req-detail-fields');
        container.innerHTML = '';
        var fields = categoryFields[val];
        if (!fields) return;
        fields.forEach(function(f) {
            var div = document.createElement('div');
            div.className = 'form-group';
            var label = document.createElement('label');
            label.className = 'form-label';
            label.textContent = f.label;
            div.appendChild(label);
            var input;
            if (f.type === 'select') {
                input = document.createElement('select');
                input.className = 'form-input';
                input.id = 'req-field-' + f.key;
                input.dataset.key = f.key;
                var empty = document.createElement('option');
                empty.value = ''; empty.textContent = 'Pilih ' + f.label;
                input.appendChild(empty);
                f.options.forEach(function(o) {
                    var opt = document.createElement('option');
                    opt.value = o; opt.textContent = o;
                    if (existingDetails && existingDetails[f.key] === o) opt.selected = true;
                    input.appendChild(opt);
                });
            } else {
                input = document.createElement('input');
                input.className = 'form-input';
                input.type = 'text';
                input.placeholder = f.placeholder || '';
                input.id = 'req-field-' + f.key;
                input.dataset.key = f.key;
                if (existingDetails && existingDetails[f.key]) input.value = existingDetails[f.key];
            }
            div.appendChild(input);
            container.appendChild(div);
        });
    }

    var katEl = document.getElementById('req-kategori');
    if (katEl && katEl.value) showReqFields(katEl.value);

    function updateReqKota(provinsi) {
        populateKota(provinsi, document.getElementById('req-kota'), existingLokasi);
    }

    var provSelect = document.getElementById('req-provinsi');
    if (provSelect) populateProvinsi(provSelect, existingProvinsi);
    if (existingProvinsi) updateReqKota(existingProvinsi);

    var reqImageStore = [];

    document.getElementById('req-file-input').addEventListener('change', function() {
        Array.from(this.files).forEach(function(f) { if (reqImageStore.length < 5) reqImageStore.push(f); });
        this.value = '';
        renderReqPreviews();
        syncReqInput();
    });

    renderReqPreviews();

    function renderReqPreviews() {
        var container = document.getElementById('req-preview');
        container.innerHTML = '';
        reqImageStore.forEach(function(file, i) {
            var reader = new FileReader();
            reader.onload = function(e) {
                var wrap = document.createElement('div');
                wrap.style.cssText = 'position:relative;width:88px;height:88px;border-radius:10px;overflow:hidden;flex-shrink:0;';
                var img = document.createElement('img');
                img.src = e.target.result;
                img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
                var del = document.createElement('button');
                del.type = 'button';
                del.style.cssText = 'position:absolute;top:4px;right:4px;width:22px;height:22px;border-radius:50%;background:rgba(0,0,0,0.55);color:#fff;border:none;cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center;line-height:1;';
                del.innerHTML = '✕';
                del.onclick = (function(idx) { return function() { reqImageStore.splice(idx, 1); renderReqPreviews(); syncReqInput(); }; })(i);
                wrap.appendChild(img);
                wrap.appendChild(del);
                container.appendChild(wrap);
                if (reqImageStore.length < 5) appendReqAddTile(container);
            };
            reader.readAsDataURL(file);
        });
        if (reqImageStore.length === 0) appendReqAddTile(container);
    }

    function appendReqAddTile(container) {
        var existing = container.querySelector('.req-add-tile');
        if (existing) existing.remove();
        var tile = document.createElement('div');
        tile.className = 'req-add-tile';
        tile.style.cssText = 'width:88px;height:88px;border-radius:10px;border:2px dashed #cbd5e1;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;color:#94a3b8;gap:4px;background:#f8fafc;flex-shrink:0;transition:all 0.15s;';
        tile.innerHTML = '<i class="ti ti-plus" style="font-size:22px;"></i><span style="font-size:10px;font-family:Plus Jakarta Sans,sans-serif;font-weight:600;">Tambah</span>';
        tile.onmouseenter = function() { tile.style.borderColor = 'var(--blue)'; tile.style.color = 'var(--blue)'; tile.style.background = '#eff6ff'; };
        tile.onmouseleave = function() { tile.style.borderColor = '#cbd5e1'; tile.style.color = '#94a3b8'; tile.style.background = '#f8fafc'; };
        tile.onclick = function() { document.getElementById('req-file-input').click(); };
        container.appendChild(tile);
    }

    function syncReqInput() {
        var dt = new DataTransfer();
        reqImageStore.forEach(function(f) { dt.items.add(f); });
        document.getElementById('req-file-input').files = dt.files;
    }

    function validateReq() {
        var valid = true;
        var required = [
            { name:'Title', for:'Title' },
            { name:'Kategori', for:'Kategori' },
            { name:'Lokasi', for:'Lokasi' },
            { name:'Deskripsi', for:'Deskripsi' }
        ];
        required.forEach(function(f) {
            var el = document.querySelector('#req-form [name="' + f.name + '"]');
            var err = document.querySelector('#req-form [data-for="' + f.for + '"]');
            if (el && !el.value.trim()) {
                el.classList.add('error');
                if (err) err.style.display = 'block';
                valid = false;
            } else {
                if (el) el.classList.remove('error');
                if (err) err.style.display = 'none';
            }
        });
        if (valid) {
            var katEl = document.getElementById('req-kategori');
            var fields = categoryFields[katEl.value];
            var result = {};
            if (fields) {
                fields.forEach(function(f) {
                    var el = document.getElementById('req-field-' + f.key);
                    if (el && el.value) result[f.key] = el.value;
                });
            }
            document.getElementById('ReqDetailTambahanJson').value = Object.keys(result).length > 0 ? JSON.stringify(result) : '';
        }
        return valid;
    }

        document.querySelectorAll('.btn-condition').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.btn-condition').forEach(function(b) { b.classList.remove('selected'); });
            this.classList.add('selected');
            document.getElementById('kondisiMinInput').value = this.dataset.value;
        });
    });
</script>
