@using DonationApp.Models
@using DonationApp.Services
@{
    var myRequests = ViewBag.MyRequests as List<ItemRequest>;
    var selected = ViewBag.Selected as ItemRequest;
    var matchesJson = ViewBag.Matches as string;
    var matchCount = ViewBag.MatchCount as int? ?? 0;
    var matchContext = ViewBag.MatchContext as string ?? "";
    var sourceId = selected?.Id.ToString() ?? "";
}

<div class="ppage">
    <div class="ppage-inner ppage-inner--flush">

        <div class="ptab-header">
            <div class="ptab-bar ptab-bar--flush">
                <a asp-controller="Request" asp-action="MyRequests" class="ptab active">Request Saya</a>
                <a asp-controller="Request" asp-action="Permintaan" class="ptab">Permintaan Donasi</a>
                <a asp-controller="Request" asp-action="CreateView" class="ptab">Buat Request</a>
            </div>
        </div>

        @if (TempData["RequestSuccess"] != null)
        {
            <div class="palert-success">
                @TempData["RequestSuccess"]
            </div>
        }
        @if (TempData["RequestError"] != null)
        {
            <div class="palert-error-wrap pform-error-banner">@TempData["RequestError"]</div>
        }

        @if (myRequests == null || !myRequests.Any())
        {
            <div class="pempty">
                <i class="ti ti-list-search pempty-icon" aria-hidden="true"></i>
                <p class="pempty-text">Belum ada request.</p>
                <a asp-controller="Request" asp-action="CreateView" class="btn btn-secondary">Buat Request Pertama</a>
            </div>
        }
        else
        {
            <div class="psplit psplit--flush">

                <div class="plist" id="request-list">
                    @foreach (var r in myRequests)
                    {
                        var firstImg = r.Images.FirstOrDefault();
                        var daysLeft = (r.ExpiresAt - DateTime.UtcNow).Days;
                        var offerCount = r.Offers.Count;

                        var (statusLabel, statusClass) = r.Status switch
                        {
                            ItemRequestStatus.Open => ("Aktif", "badge-available"),
                            ItemRequestStatus.Fulfilled => ("Terpenuhi", "badge-claimed"),
                            ItemRequestStatus.Expired => ("Kedaluwarsa", "badge-muted"),
                            ItemRequestStatus.Closed => ("Ditutup", "badge-rejected"),
                            _ => ("Unknown", "badge-muted")
                        };

                        <a class="plist-item @(selected?.Id == r.Id ? "active" : "")"
                           href="/Request/MyRequests?selectedId=@r.Id">
                            @if (firstImg != null)
                            {
                                <img src="@firstImg.FilePath" class="plist-thumb img-cover-fill" />
                            }
                            else
                            {
                                <div class="plist-thumb"><i class="ti ti-list-search" aria-hidden="true"></i></div>
                            }
                            <div class="flex-1" style="min-width:0;">
                                <div class="plist-name">@r.Title</div>
                                <div class="plist-sub">
                                    @CategoryHelper.DisplayName(r.Kategori)
                                    @if (r.Status == ItemRequestStatus.Open)
                                    {
                                        <span>· @daysLeft hari lagi</span>
                                    }
                                    @if (offerCount > 0)
                                    {
                                        <span>· @offerCount penawaran</span>
                                    }
                                </div>
                            </div>
                            <span class="badge @statusClass">@statusLabel</span>
                        </a>
                    }
                </div>

                <div class="pdetail" id="request-detail">
                    @if (selected == null)
                    {
                        <div class="pdetail-empty">Pilih request untuk melihat detail.</div>
                    }
                    else
                    {
                        var pendingOffers = selected.Offers.Where(o => o.Status == TransactionStatus.Pending).ToList();
                        var activeOffers = selected.Offers.Where(o =>
                            o.Status == TransactionStatus.Accepted ||
                            o.Status == TransactionStatus.Shipped ||
                            o.Status == TransactionStatus.Delivered).ToList();

                        <div class="pdetail-header pdetail-head-row">
                            @if (selected.Images.Any())
                            {
                                <img src="@selected.Images.First().FilePath" class="pthumb-60" />
                            }
                            <div class="flex-1">
                                <div class="pdetail-title" style="margin-bottom:8px;">@selected.Title</div>
                                <div class="pbadge-row">
                                    <span class="badge badge-claimed">@CategoryHelper.DisplayName(selected.Kategori)</span>
                                    <span class="badge badge-muted">@selected.Jumlah pcs</span>
                                    @if (!string.IsNullOrEmpty(selected.Lokasi))
                                    {
                                        <span class="badge badge-muted">
                                            <i class="ti ti-map-pin icon-12" aria-hidden="true"></i>
                                            @selected.Lokasi@(!string.IsNullOrEmpty(selected.Provinsi) ? ", " + selected.Provinsi : "")
                                        </span>
                                    }
                                </div>
                            </div>
                            <div class="pdetail-actions">
                                <button onclick="runRequestMatch(@selected.Id, this)" class="btn btn-secondary btn-xs btn-match-grad">
                                    <i class="ti ti-search" aria-hidden="true"></i> Cari Kecocokan
                                </button>
                                @if (!activeOffers.Any())
                                {
                                    <a href="/Request/EditView/@selected.Id" class="btn btn-secondary btn-xs">
                                        <i class="ti ti-edit" aria-hidden="true"></i> Edit
                                    </a>
                                    <form asp-controller="Request" asp-action="DeleteRequest" method="post" onsubmit="return confirm('Hapus request ini?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@selected.Id" />
                                        <button type="submit" class="btn btn-danger btn-xs">
                                            <i class="ti ti-trash" aria-hidden="true"></i> Hapus
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(selected.Deskripsi))
                        {
                            <div class="psec">
                                <div class="psec-label">Deskripsi</div>
                                <p class="psec-text">@selected.Deskripsi</p>
                            </div>
                        }

                        @if (activeOffers.Any())
                        {
                            <div class="psec">
                                <div class="psec-label">Penawaran Diterima (@activeOffers.Count)</div>
                                <div class="poffer-list">
                                    @foreach (var o in activeOffers)
                                    {
                                        var oAvatar = o.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
                                        var oName = o.User != null ? o.User.NamaDepan + " " + o.User.NamaBelakang : "Unknown";
                                        var oHasFeedback = selected.Feedbacks.Any(f => f.ReviewerId == selected.UserId && f.ReviewedUserId == o.UserId);
                                        var activeOfferImg = o.Images.FirstOrDefault();
                                        var isPickup = selected.MetodePengiriman == MetodePengiriman.Pickup;
                                        var oStatusLabel = o.Status switch
                                        {
                                            TransactionStatus.Accepted  => "Menunggu Kirim",
                                            TransactionStatus.Shipped   => "Dikirim",
                                            TransactionStatus.Delivered => "Selesai",
                                            _ => ""
                                        };
                                        var oStatusClass = o.Status switch
                                        {
                                            TransactionStatus.Accepted  => "badge-claimed",
                                            TransactionStatus.Shipped   => "badge-pending",
                                            TransactionStatus.Delivered => "badge-available",
                                            _ => "badge-muted"
                                        };
                                        <div>
                                            <div class="penerima-row" onclick="togglePenerima('offer-detail-@o.Id')">
                                                <a href="/Profile/View/@o.UserId" class="penerima-link" onclick="event.stopPropagation();">
                                                    <div class="avatar avatar-sm avatar-xs">@oAvatar</div>
                                                    <div class="flex-1">
                                                        <div class="penerima-name">@oName</div>
                                                        <div class="penerima-meta">@o.NamaBarang · @o.Jumlah pcs</div>
                                                    </div>
                                                </a>
                                                <span class="badge @oStatusClass" style="font-size:12px;">@oStatusLabel</span>
                                                <i class="ti ti-chevron-down penerima-chevron" id="chevron-@o.Id" aria-hidden="true"></i>
                                            </div>
                                            <div id="offer-detail-@o.Id" class="poffer-detail">
                                                <div class="poffer-chat-row">
                                                    <form asp-controller="Request" asp-action="Chat" method="post" class="ml-auto">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="offerId" value="@o.Id" />
                                                        <button type="submit" class="btn btn-primary btn-sm">
                                                            <i class="ti ti-message-2" aria-hidden="true"></i> Chat
                                                        </button>
                                                    </form>
                                                </div>
                                                <div class="poffer-itemrow">
                                                    @if (activeOfferImg != null)
                                                    {
                                                        <img src="@activeOfferImg.FilePath" class="poffer-thumb" />
                                                    }
                                                    <div class="flex-1">
                                                        <div class="poffer-itemname">@o.NamaBarang</div>
                                                        <div class="poffer-badges">
                                                            <span class="badge badge-muted">@o.Kondisi</span>
                                                            <span class="badge badge-muted">@o.Jumlah pcs</span>
                                                            @if (!string.IsNullOrEmpty(o.Lokasi))
                                                            {
                                                                <span class="badge badge-muted">
                                                                    <i class="ti ti-map-pin icon-12" aria-hidden="true"></i>
                                                                    @o.Lokasi@(!string.IsNullOrEmpty(o.Provinsi) ? ", " + o.Provinsi : "")
                                                                </span>
                                                            }
                                                        </div>
                                                        @if (!string.IsNullOrEmpty(o.Deskripsi))
                                                        {
                                                            <div class="poffer-desc">@o.Deskripsi</div>
                                                        }
                                                    </div>
                                                </div>
                                                <div class="pstepper" style="margin-bottom:10px;">
                                                    <div class="pstep @(o.Status >= TransactionStatus.Accepted ? "done" : "")">
                                                        <div class="pstep-dot @(o.Status >= TransactionStatus.Accepted ? "done" : "")"><i class="ti ti-check" aria-hidden="true"></i></div>
                                                        <div class="pstep-label">Diterima</div>
                                                    </div>
                                                    <div class="pstep-line @(o.Status >= TransactionStatus.Shipped ? "done" : "")"></div>
                                                    <div class="pstep @(o.Status >= TransactionStatus.Shipped ? "done" : "")">
                                                        <div class="pstep-dot @(o.Status >= TransactionStatus.Shipped ? "done" : "")"><i class="ti @(isPickup ? "ti-walk" : "ti-truck")" aria-hidden="true"></i></div>
                                                        <div class="pstep-label">@(isPickup ? "Pickup" : "Dikirim")</div>
                                                    </div>
                                                    <div class="pstep-line @(o.Status >= TransactionStatus.Delivered ? "done" : "")"></div>
                                                    <div class="pstep @(o.Status >= TransactionStatus.Delivered ? "done" : "")">
                                                        <div class="pstep-dot @(o.Status >= TransactionStatus.Delivered ? "done" : "")"><i class="ti ti-package" aria-hidden="true"></i></div>
                                                        <div class="pstep-label">@(isPickup ? "Selesai" : "Diterima")</div>
                                                    </div>
                                                    <div class="pstep-line @(oHasFeedback ? "done" : "")"></div>
                                                    <div class="pstep @(oHasFeedback ? "done" : "")">
                                                        <div class="pstep-dot @(oHasFeedback ? "done" : "")"><i class="ti ti-star" aria-hidden="true"></i></div>
                                                        <div class="pstep-label">Feedback</div>
                                                    </div>
                                                </div>
                                                @if (o.Status == TransactionStatus.Accepted && selected.MetodePengiriman == MetodePengiriman.BelumDipilih)
                                                {
                                                    <div class="pdelivery-pick">
                                                        <p class="pdelivery-hint">Pilih metode pengiriman:</p>
                                                        <div class="pdelivery-btns">
                                                            <form asp-controller="Request" asp-action="ChooseOfferDeliveryMethod" method="post" class="flex-1">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="offerId" value="@o.Id" />
                                                                <input type="hidden" name="metode" value="@((int)MetodePengiriman.Kurir)" />
                                                                <button type="submit" class="btn btn-primary btn-block" style="font-size:14px;">
                                                                    <i class="ti ti-truck" aria-hidden="true"></i> Kurir
                                                                </button>
                                                            </form>
                                                            <form asp-controller="Request" asp-action="ChooseOfferDeliveryMethod" method="post" class="flex-1">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="offerId" value="@o.Id" />
                                                                <input type="hidden" name="metode" value="@((int)MetodePengiriman.Pickup)" />
                                                                <button type="submit" class="btn btn-secondary btn-block" style="font-size:14px;">
                                                                    <i class="ti ti-walk" aria-hidden="true"></i> Pickup
                                                                </button>
                                                            </form>
                                                        </div>
                                                    </div>
                                                }
                                                else if (o.Status == TransactionStatus.Accepted)
                                                {
                                                    <div style="text-align:center;">
                                                        <span class="pmethod-tag">
                                                            <i class="ti @(isPickup ? "ti-walk" : "ti-truck")" aria-hidden="true"></i>
                                                            @(isPickup ? "Pickup" : "Kurir")
                                                        </span>
                                                        @if (isPickup)
                                                        {
                                                            <div class="ppickup-box">
                                                                <div class="ppickup-title">
                                                                    <i class="ti ti-map-pin" aria-hidden="true"></i> Alamat Donor
                                                                </div>
                                                                <div class="ppickup-addr">@o.User?.Alamat</div>
                                                                <div class="ppickup-loc">@o.User?.Kota - @o.User?.Provinsi</div>
                                                            </div>
                                                            <p class="ptext-note">Chat dengan donor untuk mengatur penjemputan</p>
                                                            <form asp-controller="Request" asp-action="Chat" method="post" style="margin-top:8px;">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="offerId" value="@o.Id" />
                                                                <button type="submit" class="btn btn-primary btn-block" style="font-size:14px;">
                                                                    <i class="ti ti-message-2" aria-hidden="true"></i> Chat dengan Donor
                                                                </button>
                                                            </form>
                                                        }
                                                        else
                                                        {
                                                            <p class="ptext-note">Menunggu pengirim mengirim barang...</p>
                                                        }
                                                    </div>
                                                }
                                                else if (o.Status == TransactionStatus.Shipped)
                                                {
                                                    <form asp-controller="Request" asp-action="MarkOfferDelivered" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="offerId" value="@o.Id" />
                                                        <button type="submit" class="btn btn-success btn-block" style="font-size:14px;">
                                                            <i class="ti ti-package" aria-hidden="true"></i>
                                                            @(selected.MetodePengiriman == MetodePengiriman.Pickup ? "Konfirmasi Sudah Di-pickup" : "Konfirmasi Barang Diterima")
                                                        </button>
                                                    </form>
                                                }
                                                else if (o.Status == TransactionStatus.Delivered)
                                                {
                                                    var requesterReviewed = selected.Feedbacks.Any(f => f.ReviewerId == selected.UserId && f.ReviewedUserId == o.UserId);
                                                    <p class="ptext-done"><i class="ti ti-check" aria-hidden="true"></i> Barang telah diterima</p>
                                                    if (requesterReviewed)
                                                    {
                                                        var myReview = selected.Feedbacks.First(f => f.ReviewerId == selected.UserId && f.ReviewedUserId == o.UserId);
                                                        <div class="pfeedback-box">
                                                            <div class="pfeedback-label">Feedback Anda</div>
                                                            <div class="pfeedback-stars">
                                                                @await Html.PartialAsync("_RatingStars", ((double)myReview.Rating, 16))
                                                            </div>
                                                            @if (!string.IsNullOrEmpty(myReview.Komentar))
                                                            {
                                                                <p class="penerima-meta" style="margin:0;">@myReview.Komentar</p>
                                                            }
                                                            @if (!string.IsNullOrEmpty(myReview.FotoPath))
                                                            {
                                                                <div style="margin-top:6px;">
                                                                    <img src="@myReview.FotoPath" class="pfeedback-img" onclick="window.open(this.src)" />
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="pfeedback-form-box">
                                                            <div class="pfeedback-label pfeedback-label--mb8">Beri Feedback untuk Pengirim</div>
                                                            <form asp-controller="Reputation" asp-action="Submit" method="post" enctype="multipart/form-data">
                                                                @Html.AntiForgeryToken()
                                                                <input type="hidden" name="requestOfferId" value="@o.Id" />
                                                                <input type="hidden" name="rating" id="ratingValue-@o.Id" value="0" />
                                                                <div style="display:flex;gap:4px;margin-bottom:8px;">
                                                                    @for (int star = 1; star <= 5; star++)
                                                                    {
                                                                        <button type="button" class="btn-star" data-group="@o.Id" data-value="@star">★</button>
                                                                    }
                                                                </div>
                                                                <textarea class="form-input" name="komentar" rows="2" placeholder="Ceritakan pengalaman Anda..." style="resize:vertical;font-size:14px;margin-bottom:8px;"></textarea>
                                                                <div class="pfeedback-filerow">
                                                                    <label class="pfeedback-filelbl">Foto (opsional)</label>
                                                                    <input type="file" name="foto" id="fbFotoInput-@o.Id" class="fb-foto-input" data-preview="fbFotoPreview-@o.Id" accept="image/*" style="font-size:13px;" />
                                                                </div>
                                                                <div id="fbFotoPreview-@o.Id" style="display:flex;flex-wrap:wrap;gap:8px;margin-top:6px;"></div>
                                                                <button type="submit" class="btn btn-secondary btn-block" style="font-size:14px;">Kirim Feedback</button>
                                                            </form>
                                                        </div>
                                                    }
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <div class="psec">
                            <div class="psec-label">Penawaran Masuk (@pendingOffers.Count)</div>
                            @if (!pendingOffers.Any())
                            {
                                <p class="ptext-center-muted">Belum ada penawaran.</p>
                            }
                            <div class="poffer-list">
                            @foreach (var o in pendingOffers)
                            {
                                var oAvatar = o.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
                                var oName = o.User != null ? o.User.NamaDepan + " " + o.User.NamaBelakang : "Unknown";
                                var firstOfferImg = o.Images.FirstOrDefault();
                                <div>
                                    <div class="penerima-row" onclick="togglePenawaran('pending-detail-@o.Id')">
                                        <a href="/Profile/View/@o.UserId" class="avatar avatar-sm avatar-xs" style="text-decoration:none;color:#fff;" onclick="event.stopPropagation();">@oAvatar</a>
                                        <div class="penerima-info">
                                            <a href="/Profile/View/@o.UserId" class="penerima-name" onclick="event.stopPropagation();">@oName</a>
                                            <div class="penerima-meta">@o.NamaBarang · @o.Jumlah pcs</div>
                                        </div>
                                        <span class="badge badge-muted" style="font-size:12px;">Menunggu</span>
                                        <i class="ti ti-chevron-down penerima-chevron" id="chevron-pending-@o.Id" aria-hidden="true"></i>
                                    </div>
                                    <div id="pending-detail-@o.Id" class="poffer-detail">
                                        <div class="poffer-itemrow">
                                            @if (firstOfferImg != null)
                                            {
                                                <img src="@firstOfferImg.FilePath" class="poffer-thumb" />
                                            }
                                            <div class="flex-1">
                                                <div class="poffer-itemname">@o.NamaBarang</div>
                                                <div class="poffer-badges">
                                                    <span class="badge badge-muted">@o.Kondisi</span>
                                                    <span class="badge badge-muted">@o.Jumlah pcs</span>
                                                    @if (!string.IsNullOrEmpty(o.Lokasi))
                                                    {
                                                        <span class="badge badge-muted">
                                                            <i class="ti ti-map-pin icon-12" aria-hidden="true"></i>
                                                            @o.Lokasi@(!string.IsNullOrEmpty(o.Provinsi) ? ", " + o.Provinsi : "")
                                                        </span>
                                                    }
                                                </div>
                                                @if (!string.IsNullOrEmpty(o.Deskripsi))
                                                {
                                                    <div class="poffer-desc">@o.Deskripsi</div>
                                                }
                                            </div>
                                        </div>
                                        <div class="poffer-actions-end">
                                            <form asp-controller="Request" asp-action="AcceptOffer" method="post" style="display:inline;" onsubmit="return confirm('Terima penawaran dari @oName?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="offerId" value="@o.Id" />
                                                <button type="submit" class="btn btn-success btn-xs">Terima</button>
                                            </form>
                                            <form asp-controller="Request" asp-action="RejectOffer" method="post" style="display:inline;" onsubmit="return confirm('Tolak penawaran dari @oName?')">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="offerId" value="@o.Id" />
                                                <button type="submit" class="btn btn-danger btn-xs">Tolak</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                            </div>
                        </div>
                    }
                </div>

            </div>
        }
    </div>
</div>

@await Html.PartialAsync("~/Views/Profile/Bar/_MatchModal.cshtml", new ViewDataDictionary(Html.MetadataProvider, Html.ViewData.ModelState) {
    { "MatchesJson", matchesJson },
    { "MatchCount", matchCount },
    { "MatchContext", matchContext },
    { "SourceId", sourceId }
})

<script src="~/js/form-helpers.js" asp-append-version="true"></script>
<script>
    if (window.initSimpleImagePreview) {
        document.querySelectorAll('.fb-foto-input').forEach(function (inp) {
            initSimpleImagePreview(inp.id, inp.dataset.preview, 1);
        });
    }

    function togglePenerima(detailId) {
        var el = document.getElementById(detailId);
        if (!el) return;
        var isOpen = el.style.display !== 'none';
        var offerId = detailId.replace('offer-detail-', '');
        var chevron = document.getElementById('chevron-' + offerId);
        el.style.display = isOpen ? 'none' : 'block';
        if (chevron) chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
    }

    function togglePenawaran(detailId) {
        var el = document.getElementById(detailId);
        if (!el) return;
        var isOpen = el.style.display !== 'none';
        var offerId = detailId.replace('pending-detail-', '');
        var chevron = document.getElementById('chevron-pending-' + offerId);
        el.style.display = isOpen ? 'none' : 'block';
        if (chevron) chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
    }

    (function() {
        var forms = document.querySelectorAll('#request-detail form[method="post"]');
        forms.forEach(function(form) {
            form.addEventListener('submit', function() {
                var panel = form.closest('[id^="offer-detail-"], [id^="pending-detail-"]');
                if (panel) {
                    sessionStorage.setItem('expandPanel', panel.id);
                }
            });
        });

        var panelId = sessionStorage.getItem('expandPanel');
        if (panelId) {
            sessionStorage.removeItem('expandPanel');
            var el = document.getElementById(panelId);
            if (el) {
                el.style.display = 'block';
                var offerId = panelId.replace('offer-detail-', '').replace('pending-detail-', '');
                var chevron = document.getElementById('chevron-' + offerId) || document.getElementById('chevron-pending-' + offerId);
                if (chevron) chevron.style.transform = 'rotate(180deg)';
                el.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }
    })();

    function runRequestMatch(requestId, btn) {
        var orig = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="ti ti-loader-2" aria-hidden="true" style="animation:spin 0.6s linear infinite;display:inline-block;"></i>';

        fetch('/Request/FindMatches?requestId=' + requestId)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            btn.disabled = false;
            btn.innerHTML = orig;
            if (data.success) {
                window.openMatchModal(data.matches, data.context, data.sourceId);
            } else {
                alert(data.error || 'Gagal mencari kecocokan.');
            }
        })
        .catch(function() {
            btn.disabled = false;
            btn.innerHTML = orig;
            alert('Terjadi kesalahan. Coba lagi.');
        });
    }

    document.querySelectorAll('.btn-star[data-group]').forEach(function(btn) {
        btn.addEventListener('mouseover', function() {
            var g = this.dataset.group, v = parseInt(this.dataset.value);
            document.querySelectorAll('.btn-star[data-group="'+g+'"]').forEach(function(s,i){ s.classList.toggle('active', i < v); });
        });
        btn.addEventListener('mouseout', function() {
            var g = this.dataset.group;
            var rv = document.getElementById('ratingValue-'+g);
            var sel = parseInt(rv ? rv.value : 0);
            document.querySelectorAll('.btn-star[data-group="'+g+'"]').forEach(function(s,i){ s.classList.toggle('active', i < sel); });
        });
        btn.addEventListener('click', function() {
            var g = this.dataset.group, v = parseInt(this.dataset.value);
            var rv = document.getElementById('ratingValue-'+g);
            if(rv) rv.value = v;
            document.querySelectorAll('.btn-star[data-group="'+g+'"]').forEach(function(s,i){ s.classList.toggle('active', i < v); });
        });
    });
</script>
