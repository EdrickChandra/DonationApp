@using DonationApp.Models
@using DonationApp.Services
@{
    var myOffers = ViewBag.MyOffers as List<RequestOffer>;
    var selected = ViewBag.Selected as RequestOffer;
}

<div class="ppage">
    <div class="ppage-inner" style="max-width:100%;padding:0;">

        <div style="display:flex;align-items:center;padding:16px 20px;border-bottom:0.5px solid #e2e8f0;">
            <div class="ptab-bar" style="margin:0;border:none;">
                <a asp-controller="Donasi" asp-action="Index" class="ptab">Donasi Saya</a>
                <a asp-controller="Donasi" asp-action="PenawaranDonasi" class="ptab active">Penawaran Donasi</a>
                <a asp-controller="Donasi" asp-action="Create" class="ptab">Buat Donasi</a>
            </div>
        </div>

        @if (myOffers == null || !myOffers.Any())
        {
            <div class="empty-state">
                <i class="ti ti-package-off" class="empty-icon" aria-hidden="true"></i>
                <p style="font-size:13px;color:#64748b;margin-bottom:12px;">Belum ada penawaran yang dibuat.</p>
                <a asp-controller="Request" asp-action="Index" class="btn btn-primary">Lihat Request Barang</a>
            </div>
        }
        else
        {
            <div class="psplit" style="border:none;border-radius:0;min-height:calc(100vh - 120px);">

                <div class="plist" id="penawaran-list">
                    @foreach (var offer in myOffers)
                    {
                        var req = offer.ItemRequest;
                        var firstReqImg = req?.Images.FirstOrDefault();

                        string statusLabel;
                        string statusClass;
                        switch (offer.Status)
                        {
                            case TransactionStatus.Accepted:
                                statusLabel = "Diterima"; statusClass = "badge-claimed"; break;
                            case TransactionStatus.Shipped:
                                statusLabel = "Dikirim"; statusClass = "badge-pending"; break;
                            case TransactionStatus.Delivered:
                                statusLabel = "Selesai"; statusClass = "badge-available"; break;
                            case TransactionStatus.Rejected:
                                statusLabel = "Ditolak"; statusClass = "badge-rejected"; break;
                            default:
                                statusLabel = "Menunggu"; statusClass = "badge-muted"; break;
                        }

                        <a class="plist-item @(selected?.Id == offer.Id ? "active" : "")"
                           href="/Donasi/PenawaranDonasi?selectedId=@offer.Id">
                            @if (firstReqImg != null)
                            {
                                <img src="@firstReqImg.FilePath" class="plist-thumb" style="object-fit:cover;" />
                            }
                            else
                            {
                                <div class="plist-thumb"><i class="ti ti-list-search" aria-hidden="true"></i></div>
                            }
                            <div class="flex-min">
                                <div class="plist-name">@(req?.Title ?? "Request dihapus")</div>
                                <div class="plist-sub">@offer.NamaBarang · @offer.Jumlah pcs</div>
                            </div>
                            <span class="badge @statusClass">@statusLabel</span>
                        </a>
                    }
                </div>

                <div class="pdetail" id="penawaran-detail">
                    @if (selected == null)
                    {
                        <div class="pdetail-empty">Pilih penawaran untuk melihat detail.</div>
                    }
                    else
                    {
                        var req = selected.ItemRequest;
                        var alreadyReviewed = selected.ItemRequest?.Feedbacks.Any() ?? false;
                        var firstReqImg = req?.Images.FirstOrDefault();
                        var reqOwnerInitial = req?.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
                        var reqOwnerName = req?.User != null ? req.User.NamaDepan + " " + req.User.NamaBelakang : "Unknown";

                        string statusLabel; string statusClass; string statusDesc; string dotColor;
                        switch (selected.Status)
                        {
                            case TransactionStatus.Accepted:
                                statusLabel = "Diterima"; statusClass = "badge-claimed";
                                statusDesc = "Penawaran Anda diterima — siap untuk dikirim.";
                                dotColor = "#2563eb"; break;
                            case TransactionStatus.Shipped:
                                statusLabel = "Dikirim"; statusClass = "badge-pending";
                                statusDesc = "Barang sudah ditandai dikirim. Menunggu konfirmasi penerimaan.";
                                dotColor = "#f59e0b"; break;
                            case TransactionStatus.Delivered:
                                statusLabel = "Selesai"; statusClass = "badge-available";
                                statusDesc = "Barang telah diterima. Transaksi selesai.";
                                dotColor = "#22c55e"; break;
                            case TransactionStatus.Rejected:
                                statusLabel = "Ditolak"; statusClass = "badge-rejected";
                                statusDesc = "Penawaran Anda tidak dipilih kali ini.";
                                dotColor = "#ef4444"; break;
                            default:
                                statusLabel = "Menunggu"; statusClass = "badge-muted";
                                statusDesc = "Menunggu konfirmasi dari peminta.";
                                dotColor = "#f59e0b"; break;
                        }

                        <div style="display:flex;align-items:flex-start;gap:14px;margin-bottom:16px;">
                            @if (firstReqImg != null)
                            {
                                <img src="@firstReqImg.FilePath" class="img-60" />
                            }
                            else
                            {
                                <div class="plist-thumb" style="width:60px;height:60px;flex-shrink:0;"><i class="ti ti-list-search" aria-hidden="true" style="font-size:22px;"></i></div>
                            }
                            <div class="flex-1">
                                <div style="font-size:11px;color:#94a3b8;font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin-bottom:3px;">Request dari</div>
                                <div class="pdetail-title" style="margin-bottom:8px;">@(req?.Title ?? "Request dihapus")</div>
                                <div style="display:flex;align-items:center;gap:6px;">
                                    <div style="width:20px;height:20px;border-radius:50%;background:#3b82f6;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff;">@reqOwnerInitial</div>
                                    <span class="text-sm-muted">@reqOwnerName</span>
                                </div>
                            </div>
                            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0;">
                                <span class="badge @statusClass">@statusLabel</span>
                                @if (req != null)
                                {
                                    <a asp-controller="Request" asp-action="Detail" asp-route-id="@req.Id" style="font-size:11px;color:#2563eb;text-decoration:none;">Lihat request →</a>
                                }
                            </div>
                        </div>

                        <div class="psec">
                            <div class="psec-label">Penawaran Anda</div>
                            <div style="display:flex;gap:12px;align-items:flex-start;">
                                @if (selected.Images.Any())
                                {
                                    <img src="@selected.Images.First().FilePath" class="img-64" />
                                }
                                <div class="flex-1">
                                    <div style="font-size:14px;font-weight:600;color:#0f172a;margin-bottom:4px;">@selected.NamaBarang</div>
                                    <div style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:6px;">
                                        <span class="badge badge-muted">@selected.Kondisi</span>
                                        <span class="badge badge-muted">@selected.Jumlah pcs</span>
                                        @if (!string.IsNullOrEmpty(selected.Lokasi))
                                        {
                                            <span class="badge badge-muted">
                                                <i class="ti ti-map-pin" style="font-size:10px;" aria-hidden="true"></i>
                                                @selected.Lokasi@(!string.IsNullOrEmpty(selected.Provinsi) ? ", " + selected.Provinsi : "")
                                            </span>
                                        }
                                    </div>
                                    <div style="font-size:13px;color:#64748b;line-height:1.5;">@selected.Deskripsi</div>
                                </div>
                            </div>
                        </div>

                        @if (selected.Status != TransactionStatus.Pending && selected.Status != TransactionStatus.Rejected)
                        {
                            <div class="psec">
                                <div class="psec-label">Status Pengiriman</div>
                                <div class="pstepper" style="margin-bottom:14px;">
                                    <div class="pstep done">
                                        <div class="pstep-dot done"><i class="ti ti-check" aria-hidden="true"></i></div>
                                        <div class="pstep-label">Diterima</div>
                                    </div>
                                    <div class="pstep-line @(selected.Status >= TransactionStatus.Shipped ? "done" : "")"></div>
                                    <div class="pstep @(selected.Status >= TransactionStatus.Shipped ? "done" : "")">
                                        <div class="pstep-dot @(selected.Status >= TransactionStatus.Shipped ? "done" : "")"><i class="ti ti-truck" aria-hidden="true"></i></div>
                                        <div class="pstep-label">Dikirim</div>
                                    </div>
                                    <div class="pstep-line @(selected.Status == TransactionStatus.Delivered ? "done" : "")"></div>
                                    <div class="pstep @(selected.Status == TransactionStatus.Delivered ? "done" : "")">
                                        <div class="pstep-dot @(selected.Status == TransactionStatus.Delivered ? "done" : "")"><i class="ti ti-package" aria-hidden="true"></i></div>
                                        <div class="pstep-label">Diterima</div>
                                    </div>
                                    <div class="pstep-line @(alreadyReviewed ? "done" : "")"></div>
                                    <div class="pstep @(alreadyReviewed ? "done" : "")">
                                        <div class="pstep-dot @(alreadyReviewed ? "done" : "")"><i class="ti ti-star" aria-hidden="true"></i></div>
                                        <div class="pstep-label">Feedback</div>
                                    </div>
                                </div>

                                @if (selected.Status == TransactionStatus.Accepted)
                                {
                                    <p style="font-size:12px;color:#64748b;text-align:center;">Menunggu peminta menandai barang dikirim...</p>
                                }
                                else if (selected.Status == TransactionStatus.Shipped)
                                {
                                    <form asp-controller="Request" asp-action="MarkOfferDelivered" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="offerId" value="@selected.Id" />
                                        <button type="submit" class="btn btn-success btn-block">
                                            <i class="ti ti-package" aria-hidden="true"></i> Konfirmasi Barang Diterima
                                        </button>
                                    </form>
                                }
                                else if (selected.Status == TransactionStatus.Delivered)
                                {
                                    <p class="text-success-center"><i class="ti ti-check" aria-hidden="true"></i> Barang telah dikonfirmasi diterima</p>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="psec">
                                <div class="psec-label">Status</div>
                                <div style="display:flex;align-items:center;gap:8px;padding:4px 0;">
                                    <div style="width:8px;height:8px;border-radius:50%;background:@dotColor;flex-shrink:0;"></div>
                                    <span style="font-size:13px;color:#334155;">@statusDesc</span>
                                </div>
                                <div style="font-size:11px;color:#94a3b8;margin-top:6px;">Ditawarkan @((DateTime.UtcNow - selected.CreatedAt).Days) hari lalu</div>
                            </div>
                        }

                        @if (selected.Status == TransactionStatus.Delivered)
                        {
                            <div class="psec">
                                @if (alreadyReviewed)
                                {
                                    var myReview = selected.ItemRequest!.Feedbacks.First();
                                    <div class="psec-label">Feedback Anda</div>
                                    <div style="display:flex;align-items:center;gap:8px;margin-top:4px;">
                                        <div style="display:flex;gap:2px;">
                                            @for (int star = 1; star <= 5; star++)
                                            {
                                                <span style="font-size:20px;color:@(star <= myReview.Rating ? "#EF9F27" : "#cbd5e1");">★</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(myReview.Komentar))
                                        {
                                            <span class="text-muted">— @myReview.Komentar</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="psec-label">Beri Feedback untuk Peminta</div>
                                    <form asp-controller="Reputation" asp-action="Submit" method="post" style="margin-top:10px;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="itemRequestId" value="@req?.Id" />
                                        <input type="hidden" name="rating" id="ratingValue" value="0" />
                                        <div style="display:flex;gap:4px;margin-bottom:12px;">
                                            @for (int star = 1; star <= 5; star++)
                                            {
                                                <button type="button" class="btn-star" data-value="@star">★</button>
                                            }
                                        </div>
                                        <div class="form-group">
                                            <textarea class="form-input" name="komentar" rows="3"
                                                      placeholder="Ceritakan pengalaman berdonasi..." style="resize:vertical;"></textarea>
                                        </div>
                                        <button type="submit" class="btn btn-primary btn-block">Kirim Feedback</button>
                                    </form>
                                }
                            </div>
                        }
                    }
                </div>

            </div>
        }
    </div>
</div>

<script>
    (function() {
        document.querySelectorAll('.pstar-btn').forEach(function(btn) {
            btn.addEventListener('mouseover', function() {
                var val = parseInt(this.dataset.value);
                document.querySelectorAll('.pstar-btn').forEach(function(s, i) { s.classList.toggle('active', i < val); });
            });
            btn.addEventListener('mouseout', function() {
                var sel = parseInt(document.getElementById('ratingValue')?.value || 0);
                document.querySelectorAll('.pstar-btn').forEach(function(s, i) { s.classList.toggle('active', i < sel); });
            });
            btn.addEventListener('click', function() {
                var val = parseInt(this.dataset.value);
                var rv = document.getElementById('ratingValue');
                if (rv) rv.value = val;
                document.querySelectorAll('.pstar-btn').forEach(function(s, i) { s.classList.toggle('active', i < val); });
            });
        });
    })();
</script>
