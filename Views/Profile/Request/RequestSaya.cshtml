@using DonationApp.Models
@using DonationApp.Services
@{
    var myRequests = ViewBag.MyRequests as List<ItemRequest>;
    var matchesJson = ViewBag.Matches as string;
    var matchCount = ViewBag.MatchCount as int? ?? 0;
    var matchContext = ViewBag.MatchContext as string ?? "";
    var sourceId = (myRequests?.FirstOrDefault()?.Id ?? 0).ToString();
}

<div class="ppage">
    <div class="ppage-inner">

        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
            <div class="ptab-bar" style="margin:0;border:none;">
                <a asp-controller="Request" asp-action="MyRequests" class="ptab active">Request Saya</a>
                <a asp-controller="Request" asp-action="Permintaan" class="ptab">Permintaan Donasi</a>
                <a asp-controller="Request" asp-action="CreateView" class="ptab">Buat Request</a>
            </div>
            <a asp-controller="Request" asp-action="CreateView" class="pbtn pbtn-primary" style="font-size:12px;padding:6px 14px;">
                <i class="ti ti-plus" aria-hidden="true" style="font-size:14px;"></i> Buat Request
            </a>
        </div>

        @if (TempData["RequestSuccess"] != null)
        {
            <div style="background:var(--color-background-success);border:0.5px solid var(--color-border-success);color:var(--color-text-success);padding:10px 14px;border-radius:var(--border-radius-md);margin-bottom:16px;font-size:13px;">
                @TempData["RequestSuccess"]
            </div>
        }
        @if (TempData["RequestError"] != null)
        {
            <div class="pform-error-banner">@TempData["RequestError"]</div>
        }

        @if (myRequests == null || !myRequests.Any())
        {
            <div class="preview-card" style="padding:48px;text-align:center;">
                <p style="font-size:13px;color:var(--color-text-secondary);margin-bottom:12px;">Belum ada request barang.</p>
                <a asp-controller="Request" asp-action="CreateView" class="pbtn pbtn-primary">Buat Request Pertama</a>
            </div>
        }
        else
        {
            @foreach (var r in myRequests)
            {
                var daysLeft = (r.ExpiresAt - DateTime.UtcNow).Days;
                var firstImg = r.Images.FirstOrDefault();
                var isOpen = r.Status == ItemRequestStatus.Open;
                <div class="preview-card" style="margin-bottom:12px;">
                    <div style="display:flex;align-items:flex-start;gap:12px;padding:14px 16px;border-bottom:@(r.Offers.Any() ? "0.5px solid var(--color-border-tertiary)" : "none");">
                        @if (firstImg != null)
                        {
                            <img src="@firstImg.FilePath" style="width:52px;height:52px;border-radius:var(--border-radius-md);object-fit:cover;flex-shrink:0;" />
                        }
                        else
                        {
                            <div class="plist-thumb" style="width:52px;height:52px;"><i class="ti ti-list-search" aria-hidden="true" style="font-size:22px;"></i></div>
                        }
                        <div style="flex:1;">
                            <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                                <span style="font-size:14px;font-weight:500;color:var(--color-text-primary);">@r.Title</span>
                                <span class="pbadge @(isOpen ? "pbadge-available" : "pbadge-muted")">@r.Status</span>
                            </div>
                            <div style="font-size:12px;color:var(--color-text-secondary);">@CategoryHelper.DisplayName(r.Kategori) · @daysLeft hari lagi · @r.Offers.Count penawaran</div>
                        </div>
                        <div style="display:flex;gap:4px;flex-shrink:0;align-items:center;">
                            @if (isOpen)
                            {
                                <button onclick="runMatch(@r.Id, this)" title="Cari Kecocokan"
                                    style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#1e40af,#2563eb);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;font-size:13px;flex-shrink:0;">
                                    <i class="ti ti-sparkles" aria-hidden="true"></i>
                                </button>
                            }
                            <a asp-controller="Request" asp-action="Detail" asp-route-id="@r.Id" class="pbtn" style="font-size:12px;padding:4px 10px;" title="Lihat">
                                <i class="ti ti-external-link" aria-hidden="true" style="font-size:13px;"></i>
                            </a>
                            @if (isOpen)
                            {
                                <a href="/Request/EditView/@r.Id" class="pbtn" style="font-size:12px;padding:4px 10px;" title="Edit">
                                    <i class="ti ti-edit" aria-hidden="true" style="font-size:13px;"></i>
                                </a>
                                <form asp-controller="Request" asp-action="DeleteRequest" method="post" onsubmit="return confirm('Hapus request ini?')" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <button type="submit" class="pbtn pbtn-danger" style="font-size:12px;padding:4px 10px;" title="Hapus">
                                        <i class="ti ti-trash" aria-hidden="true" style="font-size:13px;"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>

                    @if (r.Offers.Any())
                    {
                        <div style="padding:12px 16px;">
                            <div style="font-size:11px;font-weight:500;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px;">@r.Offers.Count Penawaran</div>
                            @foreach (var offer in r.Offers.OrderByDescending(o => o.CreatedAt))
                            {
                                var offerAvatar = offer.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
                                var offerName = offer.User != null ? offer.User.NamaDepan + " " + offer.User.NamaBelakang : "Unknown";
                                <div style="display:flex;align-items:flex-start;gap:10px;padding:10px;background:var(--color-background-secondary);border-radius:var(--border-radius-md);margin-bottom:6px;">
                                    <div class="preview-avatar" style="flex-shrink:0;width:26px;height:26px;font-size:11px;">@offerAvatar</div>
                                    <div style="flex:1;">
                                        <div style="font-size:12px;font-weight:500;color:var(--color-text-primary);margin-bottom:2px;">@offerName</div>
                                        @if (!string.IsNullOrEmpty(offer.NamaBarang))
                                        {
                                            <div style="font-size:12px;color:#334155;font-weight:600;margin-bottom:2px;">
                                                @offer.NamaBarang
                                                <span style="font-weight:400;color:#64748b;">· @offer.Kondisi · @offer.Jumlah pcs</span>
                                                @if (!string.IsNullOrEmpty(offer.Lokasi))
                                                {
                                                    <span style="font-weight:400;color:#64748b;"> · @offer.Lokasi</span>
                                                }
                                            </div>
                                        }
                                        <div style="font-size:12px;color:var(--color-text-secondary);">@offer.Deskripsi</div>
                                        @if (offer.Images.Any())
                                        {
                                            <img src="@offer.Images.First().FilePath" style="width:44px;height:44px;border-radius:var(--border-radius-md);object-fit:cover;margin-top:6px;" />
                                        }
                                    </div>
                                    <div style="display:flex;flex-direction:column;gap:4px;flex-shrink:0;">
                                        @if (offer.Status == RequestOfferStatus.Accepted)
                                        {
                                            <span class="pbadge pbadge-available">Diterima</span>
                                        }
                                        else if (offer.Status == RequestOfferStatus.Rejected)
                                        {
                                            <span class="pbadge pbadge-rejected">Ditolak</span>
                                        }
                                        else if (isOpen)
                                        {
                                            <form asp-controller="Request" asp-action="AcceptOffer" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="offerId" value="@offer.Id" />
                                                <button type="submit" class="pbtn pbtn-success" style="font-size:11px;padding:3px 8px;">Terima</button>
                                            </form>
                                            <form asp-controller="Request" asp-action="RejectOffer" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="offerId" value="@offer.Id" />
                                                <button type="submit" class="pbtn pbtn-danger" style="font-size:11px;padding:3px 8px;">Tolak</button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@await Html.PartialAsync("~/Views/Profile/Bar/_MatchModal.cshtml", new ViewDataDictionary(Html.MetadataProvider, Html.ViewData.ModelState) {
    { "MatchesJson", matchesJson },
    { "MatchCount", matchCount },
    { "MatchContext", matchContext },
    { "SourceId", sourceId }
})

<script>
    function runMatch(requestId, btn) {
        var orig = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="ti ti-loader-2" aria-hidden="true" style="animation:spin 0.6s linear infinite;display:inline-block;"></i>';

        fetch('/Request/FindMatches?requestId=' + requestId)
        .then(function(r) { return r.json(); })
        .then(function(data) {
            btn.disabled = false;
            btn.innerHTML = orig;
            if (data.success) {
                window.openMatchModal(data.matches, data.context, data.sourceId);
            } else {
                alert(data.error || 'Gagal mencari kecocokan.');
            }
        })
        .catch(function() {
            btn.disabled = false;
            btn.innerHTML = orig;
            alert('Terjadi kesalahan. Coba lagi.');
        });
    }
</script>
