@using DonationApp.Models
@using DonationApp.Services
@{
    var claimRequests = ViewBag.ClaimRequests as List<ClaimRequest>;
    var selected = ViewBag.Selected as ClaimRequest;
    var currentUserId = ViewBag.CurrentUserId as string ?? "";
}

<div class="ppage">
    <div class="ppage-inner" style="max-width:100%;padding:0;">

        <div style="padding:16px 20px 0;border-bottom:0.5px solid #cbd5e1;">
            <div class="ptab-bar" style="margin:0;border:none;">
                <a asp-controller="Request" asp-action="MyRequests" class="ptab">Request Saya</a>
                <a asp-controller="Request" asp-action="Permintaan" class="ptab active">Permintaan Donasi</a>
                <a asp-controller="Request" asp-action="CreateView" class="ptab">Buat Request</a>
            </div>
        </div>

        @if (claimRequests == null || !claimRequests.Any())
        {
            <div class="empty-state">Belum ada permintaan donasi.</div>
        }
        else
        {
            <div class="psplit" style="border:none;border-radius:0;min-height:calc(100vh - 120px);">

                <div class="plist" id="permintaan-list">
                    @foreach (var r in claimRequests)
                    {
                        var (statusLabel, statusClass) = r.Status switch
                        {
                            TransactionStatus.Pending   => ("Menunggu", "badge-muted"),
                            TransactionStatus.Accepted  => ("Diterima",  "badge-claimed"),
                            TransactionStatus.Rejected  => ("Ditolak",   "badge-rejected"),
                            TransactionStatus.Shipped   => ("Dikirim",   "badge-pending"),
                            TransactionStatus.Delivered => ("Selesai",   "badge-available"),
                            _                            => ("Unknown",   "badge-muted")
                        };
                        <a class="plist-item @(selected?.Id == r.Id ? "active" : "")"
                           href="/Request/Permintaan?selectedId=@r.Id">
                            @if (r.Item?.Images.Any() == true)
                            {
                                <img src="@r.Item.Images.First().FilePath" class="plist-thumb" style="object-fit:cover;" />
                            }
                            else
                            {
                                <div class="plist-thumb"><i class="ti ti-package" aria-hidden="true"></i></div>
                            }
                            <div class="flex-min">
                                <div class="plist-name">@r.Item?.NamaBarang</div>
                                <div class="plist-sub">@r.Jumlah pcs · @((DateTime.UtcNow - r.CreatedAt).Days) hari lalu</div>
                            </div>
                            <span class="badge @statusClass">@statusLabel</span>
                        </a>
                    }
                </div>

                <div class="pdetail" id="permintaan-detail">
                    @if (selected == null)
                    {
                        <div class="pdetail-empty">Pilih permintaan untuk melihat detail.</div>
                    }
                    else
                    {
                        var alreadyReviewed = selected.Feedbacks.Any(f => f.ReviewerId == currentUserId);
                        var permIsPickup = selected.MetodePengiriman == MetodePengiriman.Pickup;

                        <div style="display:flex;align-items:flex-start;gap:14px;margin-bottom:16px;">
                            @if (selected.Item?.Images.Any() == true)
                            {
                                <img src="@selected.Item.Images.First().FilePath" class="img-60" />
                            }
                            <div>
                                <div class="pdetail-title" style="margin-bottom:8px;">@selected.Item?.NamaBarang</div>
                                <div style="display:flex;gap:6px;flex-wrap:wrap;">
                                    <span class="badge badge-claimed">@CategoryHelper.DisplayName(selected.Item?.Kategori ?? ItemCategory.Pakaian)</span>
                                    <span class="badge badge-muted">@selected.Jumlah pcs diminta</span>
                                </div>
                            </div>
                        </div>

                        <div class="psec">
                            <div class="psec-label">Donor</div>
                            <div style="display:flex;align-items:center;gap:10px;">
                                <a href="/Profile/View/@selected.Item?.UserId" style="display:flex;align-items:center;gap:10px;text-decoration:none;color:inherit;flex:1;min-width:0;" onclick="event.stopPropagation();">
                                    <div class="avatar">@(selected.Item?.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?")</div>
                                    <div>
                                        <div class="text-strong">@selected.Item?.User?.NamaDepan @selected.Item?.User?.NamaBelakang</div>
                                        <div class="text-xs-muted">@selected.Item?.User?.Kota - @selected.Item?.User?.Provinsi</div>
                                    </div>
                                </a>
                                <form asp-controller="Donasi" asp-action="Chat" method="post" style="margin-left:auto;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="itemId" value="@selected.Item?.Id" />
                                    <input type="hidden" name="otherUserId" value="@selected.Item?.UserId" />
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <i class="ti ti-message-2" aria-hidden="true"></i> Chat
                                    </button>
                                </form>
                            </div>
                        </div>

                        <div class="psec">
                            <div class="psec-label">Status Pengiriman</div>
                            <div class="pstepper">
                                <div class="pstep @(selected.Status >= TransactionStatus.Accepted ? "done" : "")">
                                    <div class="pstep-dot @(selected.Status >= TransactionStatus.Accepted ? "done" : "")"><i class="ti ti-check" aria-hidden="true"></i></div>
                                    <div class="pstep-label">Disetujui</div>
                                </div>
                                <div class="pstep-line @(selected.Status >= TransactionStatus.Shipped ? "done" : "")"></div>
                                <div class="pstep @(selected.Status >= TransactionStatus.Shipped ? "done" : "")">
                                    <div class="pstep-dot @(selected.Status >= TransactionStatus.Shipped ? "done" : "")"><i class="ti @(permIsPickup ? "ti-walk" : "ti-truck")" aria-hidden="true"></i></div>
                                    <div class="pstep-label">@(permIsPickup ? "Pickup" : "Dikirim")</div>
                                </div>
                                <div class="pstep-line @(selected.Status >= TransactionStatus.Delivered ? "done" : "")"></div>
                                <div class="pstep @(selected.Status >= TransactionStatus.Delivered ? "done" : "")">
                                    <div class="pstep-dot @(selected.Status >= TransactionStatus.Delivered ? "done" : "")"><i class="ti ti-package" aria-hidden="true"></i></div>
                                    <div class="pstep-label">@(permIsPickup ? "Selesai" : "Diterima")</div>
                                </div>
                                <div class="pstep-line @(alreadyReviewed ? "done" : "")"></div>
                                <div class="pstep @(alreadyReviewed ? "done" : "")">
                                    <div class="pstep-dot @(alreadyReviewed ? "done" : "")"><i class="ti ti-star" aria-hidden="true"></i></div>
                                    <div class="pstep-label">Feedback</div>
                                </div>
                            </div>

                            @if (selected.Status == TransactionStatus.Shipped)
                            {
                                <form asp-controller="Donasi" asp-action="MarkDelivered" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="claimRequestId" value="@selected.Id" />
                                    <button type="submit" class="btn btn-success btn-block">
                                        <i class="ti ti-package" aria-hidden="true"></i>
                                        @(selected.MetodePengiriman == MetodePengiriman.Pickup ? "Tandai Sudah Di-pickup" : "Tandai Sudah Diterima")
                                    </button>
                                </form>
                            }
                            else if (selected.Status == TransactionStatus.Accepted && selected.MetodePengiriman == MetodePengiriman.BelumDipilih)
                            {
                                <div style="text-align:center;margin-top:8px;">
                                    <p style="font-size:14px;color:#64748b;margin-bottom:10px;">Pilih metode pengiriman:</p>
                                    <div style="display:flex;gap:8px;justify-content:center;">
                                        <form asp-controller="Donasi" asp-action="ChooseDeliveryMethod" method="post" style="flex:1;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="claimRequestId" value="@selected.Id" />
                                            <input type="hidden" name="metode" value="@((int)MetodePengiriman.Kurir)" />
                                            <button type="submit" class="btn btn-primary btn-block">
                                                <i class="ti ti-truck" aria-hidden="true"></i> Kurir
                                            </button>
                                        </form>
                                        <form asp-controller="Donasi" asp-action="ChooseDeliveryMethod" method="post" style="flex:1;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="claimRequestId" value="@selected.Id" />
                                            <input type="hidden" name="metode" value="@((int)MetodePengiriman.Pickup)" />
                                            <button type="submit" class="btn btn-secondary btn-block">
                                                <i class="ti ti-walk" aria-hidden="true"></i> Pickup
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                            else if (selected.Status == TransactionStatus.Accepted)
                            {
                                <div style="text-align:center;margin-top:8px;">
                                    <span style="font-size:14px;color:#3b82f6;font-weight:600;">
                                        <i class="ti @(selected.MetodePengiriman == MetodePengiriman.Pickup ? "ti-walk" : "ti-truck")" aria-hidden="true"></i>
                                        @(selected.MetodePengiriman == MetodePengiriman.Pickup ? "Pickup" : "Kurir")
                                    </span>
                                    @if (selected.MetodePengiriman == MetodePengiriman.Pickup)
                                    {
                                        <div style="background:#f0f9ff;border:1px solid #bae6fd;border-radius:8px;padding:10px 14px;margin-top:8px;text-align:left;">
                                            <div style="font-size:13px;color:#0369a1;font-weight:600;margin-bottom:4px;">
                                                <i class="ti ti-map-pin" aria-hidden="true"></i> Alamat Donor
                                            </div>
                                            <div style="font-size:15px;color:#0c4a6e;">@selected.Item?.User?.Alamat</div>
                                            <div style="font-size:14px;color:#0369a1;">@selected.Item?.User?.Kota - @selected.Item?.User?.Provinsi</div>
                                        </div>
                                    }
                                    <p style="font-size:14px;color:#64748b;margin-top:4px;">@(selected.MetodePengiriman == MetodePengiriman.Pickup ? "Menunggu donor mengonfirmasi penjemputan..." : "Menunggu donor mengirim barang...")</p>
                                </div>
                            }
                            else if (selected.Status == TransactionStatus.Pending)
                            {
                                <p style="font-size:14px;color:#64748b;text-align:center;margin-top:8px;">Menunggu konfirmasi donor...</p>
                            }
                        </div>

                        @if (selected.Status == TransactionStatus.Delivered && !alreadyReviewed)
                        {
                            <div class="psec">
                                <div class="psec-label">Feedback untuk Donasi</div>
                                <form asp-controller="Reputation" asp-action="Submit" method="post" enctype="multipart/form-data">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="claimRequestId" value="@selected.Id" />
                                    <input type="hidden" name="rating" id="ratingValue" value="0" />
                                    <div style="display:flex;gap:4px;margin-bottom:12px;">
                                        @for (int star = 1; star <= 5; star++)
                                        {
                                            <button type="button" class="btn-star" data-value="@star">★</button>
                                        }
                                    </div>
                                    <div class="form-group">
                                        <textarea class="form-input" name="komentar" rows="3" placeholder="Ceritakan pengalaman Anda..." style="resize:vertical;"></textarea>
                                    </div>
                                    <div class="form-group" style="margin-bottom:12px;">
                                        <label style="font-size:14px;color:#64748b;font-weight:600;margin-bottom:6px;display:block;">Foto (opsional)</label>
                                        <input type="file" name="foto" accept="image/*" style="font-size:14px;" />
                                    </div>
                                    <button type="submit" class="btn btn-primary btn-block">Kirim Feedback</button>
                                </form>
                            </div>
                        }
                        else if (alreadyReviewed)
                        {
                            var myReview = selected.Feedbacks.First(f => f.ReviewerId == currentUserId);
                            <div class="psec">
                                <div class="psec-label">Feedback Anda</div>
                                <div style="display:flex;gap:2px;margin-bottom:8px;">
                                    @for (int star = 1; star <= 5; star++)
                                    {
                                        <span style="font-size:20px;color:@(star <= myReview.Rating ? "#EF9F27" : "#cbd5e1");">★</span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(myReview.Komentar))
                                {
                                    <p class="text-muted">@myReview.Komentar</p>
                                }
                                @if (!string.IsNullOrEmpty(myReview.FotoPath))
                                {
                                    <div style="margin-top:8px;">
                                        <img src="@myReview.FotoPath" style="max-width:160px;max-height:160px;border-radius:8px;object-fit:cover;cursor:pointer;" onclick="window.open(this.src)" />
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        }
    </div>
</div>

<script>
    (function() {
        document.querySelectorAll('.btn-star').forEach(function(btn) {
            btn.addEventListener('mouseover', function() {
                var val = parseInt(this.dataset.value);
                document.querySelectorAll('.btn-star').forEach(function(s, i) { s.classList.toggle('active', i < val); });
            });
            btn.addEventListener('mouseout', function() {
                var sel = parseInt(document.getElementById('ratingValue')?.value || 0);
                document.querySelectorAll('.btn-star').forEach(function(s, i) { s.classList.toggle('active', i < sel); });
            });
            btn.addEventListener('click', function() {
                var val = parseInt(this.dataset.value);
                var rv = document.getElementById('ratingValue');
                if (rv) rv.value = val;
                document.querySelectorAll('.btn-star').forEach(function(s, i) { s.classList.toggle('active', i < val); });
            });
        });
    })();
</script>
