@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["HideSearch"] = true;
    var initialSection = ViewBag.InitialSection as string ?? "overview";
}

<link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />

<div id="profile-shell" style="min-height:calc(100vh - 52px);display:flex;flex-direction:column;">
    @await Html.PartialAsync("~/Views/Profile/Bar/_ProfileNav.cshtml")

    <div id="profile-content" style="flex:1;">
        <div id="profile-loading" style="display:none;padding:48px;text-align:center;">
            <div class="profile-spinner"></div>
        </div>
        <div id="profile-body"></div>
    </div>
</div>

@section Scripts {
    <style>
        #profile-shell {
            margin: 0;
        }

        @@media (max-width: 768px) {
            #profile-shell {
                margin: 0;
            }
        }

        .profile-spinner {
            width: 24px;
            height: 24px;
            border: 2px solid var(--color-border-tertiary, #cbd5e1);
            border-top-color: var(--blue, #2563eb);
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
            margin: 0 auto;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        #profile-body {
            animation: fadeIn 0.15s ease;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(4px); }
            to   { opacity: 1; transform: translateY(0); }
        }
    </style>

    <script>
        var currentUrl = null;

        // All paths that should load inside the shell via AJAX
        var profilePaths = [
            '/Profile',
            '/Donasi',
            '/Pesan',
            '/Request/MyRequests',
            '/Request/Permintaan',
            '/Request/CreateView',
            '/Request/EditView',
            '/Request/Detail',
            '/Donasi/PenawaranDonasi',
            '/Redeem' 
        ];

        // Map initialSection -> URL for initial load
        var sectionUrls = {
            'overview':    '/Profile/Overview',
            'donasi':      '/Donasi/Index',
            'request':     '/Request/MyRequests',
            'pesan':       '/Pesan/Index',
            'notifikasi':  '/Profile/Notifikasi',
            'profil':      '/Profile/Edit',
            'redeem':      '/Redeem/Index'
        };

        function isProfilePath(pathname) {
            return profilePaths.some(function(p) {
                return pathname === p ||
                       pathname.startsWith(p + '/') ||
                       pathname.startsWith(p + '?');
            });
        }

        function hoistModalToBody() {
            var modal = document.getElementById('matchModal');
            if (modal && modal.parentElement !== document.body) {
                document.body.appendChild(modal);
            }
            var noResultModal = document.getElementById('matchNoResultModal');
            if (noResultModal && noResultModal.parentElement !== document.body) {
                document.body.appendChild(noResultModal);
            }
        }

        function loadSection(url, pushState) {
            if (url === currentUrl) return;
            currentUrl = url;

            document.getElementById('profile-loading').style.display = 'block';
            var body = document.getElementById('profile-body');
            body.style.opacity = '0';

            var existingModal = document.getElementById('matchModal');
            if (existingModal) existingModal.remove();
            var existingNoResult = document.getElementById('matchNoResultModal');
            if (existingNoResult) existingNoResult.remove();

            fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function(r) {
                if (!r.ok) throw new Error('Failed');
                return r.text();
            })
            .then(function(html) {
                document.getElementById('profile-loading').style.display = 'none';
                body.innerHTML = html;
                body.style.opacity = '';

                if (pushState) {
                    window.history.pushState({ url: url }, '', url);
                }

                updateActiveNav(url);
                reinitScripts(body);
                injectBackButton();
                hoistModalToBody();
                bindFormSubmits(body);
            })
            .catch(function() {
                window.location.href = url;
            });
        }

        // Intercept form submits inside the shell so that after POST redirect
        // we reload the target page inside the shell instead of full-page reload.
        // Only intercept forms whose action targets a profile path.
        function bindFormSubmits(container) {
            container.querySelectorAll('form[method="post"], form[method="POST"]').forEach(function(form) {
                // Skip forms that already have a data-shell-bound attribute
                if (form.dataset.shellBound) return;
                form.dataset.shellBound = '1';

                // Only intercept if the form action (after redirect) would land in a profile path.
                // We intercept ALL profile forms so that after redirect the shell handles it.
                var action = form.getAttribute('action') || form.action || '';

                // Don't intercept file upload forms (enctype multipart) — let them be full-page
                // so the server can properly process files. After redirect, Shell init handles it.
                if (form.enctype === 'multipart/form-data' || form.getAttribute('enctype') === 'multipart/form-data') {
                    return;
                }

                // Don't intercept logout
                if (action.indexOf('Logout') !== -1 || action.indexOf('logout') !== -1) {
                    return;
                }

                form.addEventListener('submit', function(e) {
                    // Let native submit happen but after it completes, intercept the redirect
                    // We do this by fetching via AJAX instead
                    e.preventDefault();

                    var formData = new FormData(form);
                    var submitUrl = form.action || window.location.href;

                    fetch(submitUrl, {
                        method: 'POST',
                        body: formData,
                        redirect: 'follow',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(function(r) {
                        // After redirect, r.url is the final URL
                        var finalUrl = r.url;
                        var finalPath = new URL(finalUrl).pathname + new URL(finalUrl).search;

                        if (isProfilePath(new URL(finalUrl).pathname)) {
                            // Load the redirected page inside shell
                            currentUrl = null; // force reload
                            loadSection(finalPath, true);
                        } else {
                            // Non-profile redirect — do full page navigation
                            window.location.href = finalUrl;
                        }
                    })
                    .catch(function() {
                        // Fallback to native submit
                        form.removeEventListener('submit', arguments.callee);
                        form.submit();
                    });
                });
            });
        }

        function updateActiveNav(url) {
            document.querySelectorAll('.pnav-link').forEach(function(link) {
                link.classList.remove('active');
                var dataUrl = link.getAttribute('data-url');
                if (dataUrl && url.startsWith(dataUrl)) {
                    link.classList.add('active');
                }
            });
        }

        function reinitScripts(container) {
            container.querySelectorAll('script').forEach(function(oldScript) {
                var newScript = document.createElement('script');
                if (oldScript.src) {
                    newScript.src = oldScript.src;
                } else {
                    newScript.textContent = oldScript.textContent;
                }
                oldScript.parentNode.replaceChild(newScript, oldScript);
            });
        }

        function injectBackButton() {
            if (window.innerWidth > 768) return;
            var pdetail = document.querySelector('.pdetail');
            if (!pdetail) return;
            if (pdetail.querySelector('.pdetail-empty')) return;
            if (pdetail.querySelector('.pdetail-back-btn')) return;

            var backBtn = document.createElement('button');
            backBtn.className = 'pdetail-back-btn';
            backBtn.innerHTML = '<i class="ti ti-arrow-left" aria-hidden="true"></i> Kembali';
            backBtn.addEventListener('click', function() {
                var baseUrl = window.location.pathname;
                loadSection(baseUrl, true);
            });
            pdetail.insertBefore(backBtn, pdetail.firstChild);
        }

        // Intercept <a> clicks for profile paths
        document.addEventListener('click', function(e) {
            var link = e.target.closest('a[href]');
            if (!link) return;

            var pathname = link.pathname;
            var search = link.search || '';

            if (!pathname) return;
            if (link.target === '_blank') return;
            if (link.hostname !== window.location.hostname) return;

            if (!isProfilePath(pathname)) return;

            e.preventDefault();
            loadSection(pathname + search, true);
        });

        window.addEventListener('popstate', function(e) {
            if (e.state && e.state.url) {
                loadSection(e.state.url, false);
            }
        });

        // Determine initial URL: use actual current pathname if it's a profile path,
        // otherwise fall back to the sectionUrls mapping.
        (function() {
            var currentPath = window.location.pathname + window.location.search;
            var initialUrl;

            if (isProfilePath(window.location.pathname)) {
                initialUrl = currentPath;
            } else {
                initialUrl = sectionUrls['@initialSection'] || '/Profile/Overview';
            }

            window.history.replaceState({ url: initialUrl }, '', initialUrl);
            loadSection(initialUrl, false);
        })();
    </script>
}
