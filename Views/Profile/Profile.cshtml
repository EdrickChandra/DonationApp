@using DonationApp.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var user = ViewBag.User as ApplicationUser;
    var donations = ViewBag.Donations as List<Item>;
    var requests = ViewBag.Requests as List<ClaimRequest>;
    var notifications = ViewBag.Notifications as List<Notification>;
    var conversations = ViewBag.Conversations as List<Conversation>;
    var currentUserId = ViewBag.CurrentUserId as string ?? "";
    var section = ViewBag.Section as string ?? "overview";
    var initialConvId = ViewBag.InitialConvId as int?;
    var avatarLetter = user?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
    var unreadCount = ViewBag.UnreadCount as int? ?? 0;
    var unreadMessageCount = ViewBag.UnreadMessageCount as int? ?? 0;
}

<div class="profile-grid">

    <div class="profile-sidebar">
        <div class="profile-avatar-wrap">
            <div class="profile-avatar">@avatarLetter</div>
            <p class="profile-name">@user?.NamaDepan</p>
            <p class="profile-email">@user?.Email</p>
        </div>

        @foreach (var nav in new[] { ("overview", "Overview"), ("donasi", "Donasi"), ("permintaan", "Permintaan Masuk"), ("request", "Request"), ("pesan", "Pesan"), ("notifikasi", "Notifikasi"), ("profil", "Profil") })
        {
            <a asp-controller="Profile" asp-action="Index" asp-route-section="@nav.Item1"
               class="profile-nav-item @(section == nav.Item1 ? "active" : "")">
                @nav.Item2
                @if (nav.Item1 == "notifikasi" && unreadCount > 0)
                {
                    <span class="profile-nav-badge">@unreadCount</span>
                }
                @if (nav.Item1 == "pesan" && unreadMessageCount > 0)
                {
                    <span class="profile-nav-badge">@unreadMessageCount</span>
                }
            </a>
        }
    </div>

    <div class="profile-content">

        @if (section == "overview")
        {
            <div class="profile-inner">
                <p class="profile-section-title">Overview</p>
                <div class="profile-stat-grid">
                    <div class="profile-stat-card">
                        <p class="profile-stat-label">Total Donasi</p>
                        <p class="profile-stat-value">@(donations?.Count ?? 0)</p>
                    </div>
                    <div class="profile-stat-card">
                        <p class="profile-stat-label">Total Request</p>
                        <p class="profile-stat-value">@(requests?.Count ?? 0)</p>
                    </div>
                </div>

                <div class="profile-tab-bar">
                    <button onclick="switchOvTab('donasi')" id="ovTabDonasi" class="profile-tab active">Donasi</button>
                    <button onclick="switchOvTab('request')" id="ovTabRequest" class="profile-tab">Request</button>
                </div>

                <div id="ovDonasi">
                    @if (donations == null || !donations.Any())
                    {
                        <p class="empty-text">Belum ada donasi.</p>
                    }
                    else
                    {
                        @foreach (var d in donations)
                        {
                            var daysLeft = (d.ExpiresAt - DateTime.UtcNow).Days;
                            <div class="profile-item-row">
                                <img src="@d.Images.First().FilePath" class="img-44" />
                                <div class="flex-1">
                                    <p class="profile-item-name">@d.NamaBarang</p>
                                    <p class="profile-item-sub">@d.Kategori · @daysLeft hari lagi</p>
                                </div>
                                <span class="badge @(d.Status == ItemStatus.Available ? "badge-available" : "badge-claimed")">@d.Status</span>
                            </div>
                        }
                    }
                </div>

                <div id="ovRequest" style="display:none;">
                    @if (requests == null || !requests.Any())
                    {
                        <p class="empty-text">Belum ada request.</p>
                    }
                    else
                    {
                        @foreach (var r in requests)
                        {
                            <div class="profile-item-row">
                                @if (r.Item?.Images.Any() == true)
                                {
                                    <img src="@r.Item.Images.First().FilePath" class="img-44" />
                                }
                                <div class="flex-1">
                                    <p class="profile-item-name">@r.Item?.NamaBarang</p>
                                    <p class="profile-item-sub">Diminta @((DateTime.UtcNow - r.CreatedAt).Days) hari lalu</p>
                                </div>
                                <span class="badge @(r.Status == TransactionStatus.Accepted ? "badge-claimed" : r.Status == TransactionStatus.Rejected ? "badge-rejected" : "badge-pending")">@r.Status</span>
                            </div>
                        }
                    }
                </div>
            </div>
        }

        @if (section == "donasi")
        {
            <div class="profile-inner">
                <p class="profile-section-title">Buat Donasi</p>
                <div class="profile-card">
                    <form asp-controller="Item" asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div class="form-group">
                            <label class="form-label">Nama Barang</label>
                            <input class="form-input" name="NamaBarang" placeholder="Masukkan nama barang..." />
                        </div>

                        <div class="form-group">
                            <label class="form-label">Kategori</label>
                            <select class="form-input" name="Kategori">
                                <option value="">Pilih Kategori</option>
                                <option value="@((int)ItemCategory.Pakaian)">Pakaian</option>
                                <option value="@((int)ItemCategory.Elektronik)">Elektronik</option>
                                <option value="@((int)ItemCategory.Buku)">Buku</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Kondisi Barang</label>
                            <input type="hidden" id="kondisiInput" name="Kondisi" value="@((int)ItemCondition.Baru)" />
                            <div class="condition-group">
                                <button type="button" class="btn-condition selected" data-value="@((int)ItemCondition.Baru)">Baru</button>
                                <button type="button" class="btn-condition" data-value="@((int)ItemCondition.Bekas)">Bekas</button>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Lokasi</label>
                            <input class="form-input" name="Lokasi" placeholder="Kota / Kecamatan..." />
                        </div>

                        <div class="form-group">
                            <label class="form-label">Deskripsi</label>
                            <textarea class="form-input" name="Deskripsi" placeholder="Ceritakan kondisi barang secara detail..."></textarea>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Foto Barang <span style="font-weight:400;color:#94a3b8;">(maks. 5, 5MB, JPG/PNG)</span></label>
                            <input type="file" id="imageInput" name="Images" multiple accept=".jpg,.jpeg,.png" style="display:none;" />
                            <div class="upload-zone" onclick="document.getElementById('imageInput').click()">
                                <p style="font-size:12px;color:#64748b;margin:0;">Klik untuk unggah foto</p>
                            </div>
                            <span class="validation-message" id="imageError"></span>
                            <div id="previewContainer" style="display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;"></div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-block" onclick="return validateImages()">Posting Donasi</button>
                    </form>
                </div>
            </div>
        }

        @if (section == "permintaan")
        {
            var myDonations = donations?.Where(d => d.ClaimRequests.Any()).ToList();
            var firstItemId = myDonations?.FirstOrDefault()?.Id;
            var selectedIdStr = Context.Request.Query["itemId"].ToString();
            var selectedId = int.TryParse(selectedIdStr, out var parsedId) ? parsedId : firstItemId ?? 0;
            var selectedItem = myDonations?.FirstOrDefault(d => d.Id == selectedId);

            <div class="profile-inner" style="max-width:700px;">
                <p class="profile-section-title">Permintaan Masuk</p>
                @if (myDonations == null || !myDonations.Any())
                {
                    <p class="empty-text">Belum ada permintaan masuk.</p>
                }
                else
                {
                    <div class="permintaan-split">
                        <div class="permintaan-list">
                            @foreach (var d in myDonations)
                            {
                                <a asp-controller="Profile" asp-action="Index"
                                   asp-route-section="permintaan"
                                   asp-route-itemId="@d.Id"
                                   class="permintaan-list-item @(d.Id == selectedId ? "active" : "")">
                                    <img src="@d.Images.First().FilePath" class="permintaan-list-thumb" />
                                    <div>
                                        <p class="permintaan-list-name">@d.NamaBarang</p>
                                        <p class="permintaan-list-count">@d.ClaimRequests.Count permintaan</p>
                                    </div>
                                </a>
                            }
                        </div>

                        <div class="permintaan-detail">
                            @if (selectedItem != null)
                            {
                                <p class="permintaan-detail-title">Permintaan untuk @selectedItem.NamaBarang</p>
                                @foreach (var r in selectedItem.ClaimRequests)
                                {
                                    var requesterName = r.User != null ? r.User.NamaDepan + " " + r.User.NamaBelakang : "Unknown";
                                    var avatarLetter2 = r.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
                                    <div class="permintaan-req-row">
                                        <div class="permintaan-req-avatar">@avatarLetter2</div>
                                        <span class="permintaan-req-name">@requesterName</span>
                                        <div class="permintaan-req-actions">
                                            @if (r.Status == TransactionStatus.Accepted)
                                            {
                                                <span style="font-size:12px;color:#166534;font-weight:600;">Diterima</span>
                                            }
                                            else if (r.Status == TransactionStatus.Rejected)
                                            {
                                                <span style="font-size:12px;color:#991b1b;font-weight:600;">Ditolak</span>
                                            }
                                            else if (selectedItem.Status == ItemStatus.Available)
                                            {
                                                <form asp-controller="Item" asp-action="Accept" method="post" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="requestId" value="@r.Id" />
                                                    <button type="submit" class="permintaan-accept-btn">Terima</button>
                                                </form>
                                                <form asp-controller="Item" asp-action="Reject" method="post" style="display:inline; margin-left:6px;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="requestId" value="@r.Id" />
                                                    <button type="submit" class="permintaan-reject-btn">Tolak</button>
                                                </form>
                                            }
                                            <form asp-controller="Item" asp-action="Chat" method="post" style="display:inline; margin-left:6px;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="itemId" value="@selectedItem.Id" />
                                                <input type="hidden" name="otherUserId" value="@r.UserId" />
                                                <button type="submit" class="permintaan-accept-btn" style="background:#0ea5e9;">Chat</button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="permintaan-empty">Pilih item di sebelah kiri.</div>
                            }
                        </div>
                    </div>
                }
            </div>
        }

        @if (section == "request")
        {
            <div class="profile-inner">
                <p class="profile-section-title">Request Saya</p>
                @if (requests == null || !requests.Any())
                {
                    <p class="empty-text">Belum ada request.</p>
                }
                else
                {
                    @foreach (var r in requests)
                    {
                        <div class="profile-item-row">
                            @if (r.Item?.Images.Any() == true)
                            {
                                <img src="@r.Item.Images.First().FilePath" class="img-44" />
                            }
                            <div class="flex-1">
                                <p class="profile-item-name">@r.Item?.NamaBarang</p>
                                <p class="profile-item-sub">Diminta @((DateTime.UtcNow - r.CreatedAt).Days) hari lalu</p>
                            </div>
                            <span class="badge @(r.Status == TransactionStatus.Accepted ? "badge-claimed" : r.Status == TransactionStatus.Rejected ? "badge-rejected" : "badge-pending")">@r.Status</span>
                        </div>
                    }
                }
            </div>
        }

        @if (section == "pesan")
        {
            <div class="profile-inner" style="padding:0; overflow:hidden;">
                <div class="chat-shell">
                    <div class="chat-list">
                        <div class="chat-list-header">Percakapan</div>
                        @if (conversations == null || !conversations.Any())
                        {
                            <p style="font-size:12px;color:#94a3b8;text-align:center;padding:20px 12px;">Belum ada percakapan.</p>
                        }
                        else
                        {
                            @foreach (var conv in conversations)
                            {
                                var otherParty = conv.RequesterId == currentUserId ? conv.Donor : conv.Requester;
                                var otherName = otherParty != null ? otherParty.NamaDepan + " " + otherParty.NamaBelakang : "Unknown";
                                var thumb = conv.Item?.Images.FirstOrDefault()?.FilePath;
                                var lastMsg = conv.Messages.FirstOrDefault();
                                var lastPreview = lastMsg != null
                                    ? (lastMsg.SenderId == currentUserId ? "Anda: " : "") + lastMsg.Content
                                    : "Mulai percakapan";
                                var hasUnread = conv.Messages.Any(m => m.SenderId != currentUserId && !m.IsRead);

                                <div class="chat-list-item" data-conv-id="@conv.Id"
                                     data-item-name="@conv.Item?.NamaBarang"
                                     data-other-name="@otherName"
                                     data-thumb="@(thumb ?? "")"
                                     onclick="selectConversation(this)">
                                    @if (thumb != null)
                                    {
                                        <img src="@thumb" class="chat-list-thumb" />
                                    }
                                    else
                                    {
                                        <div class="chat-list-thumb-placeholder"></div>
                                    }
                                    <div class="chat-list-meta">
                                        <p class="chat-list-name">@conv.Item?.NamaBarang</p>
                                        <p class="chat-list-preview">@lastPreview</p>
                                    </div>
                                    @if (hasUnread)
                                    {
                                        <div class="chat-list-unread-dot"></div>
                                    }
                                </div>
                            }
                        }
                    </div>

                    <div class="chat-window">
                        <div class="chat-window-header" id="chatHeader" style="display:none;">
                            <img id="chatHeaderThumb" src="" class="chat-window-header-thumb" style="display:none;" />
                            <div class="chat-window-header-info">
                                <p class="chat-window-header-name" id="chatHeaderName"></p>
                                <p class="chat-window-header-sub" id="chatHeaderSub"></p>
                            </div>
                        </div>

                        <div class="chat-messages" id="chatMessages">
                            <div class="chat-no-select" id="chatNoSelect">Pilih percakapan untuk memulai.</div>
                        </div>

                        <div class="chat-input-bar" id="chatInputBar" style="display:none;">
                            <textarea class="chat-input" id="chatInput" placeholder="Tulis pesan..." rows="1"></textarea>
                            <button class="btn btn-success" id="chatSendBtn" onclick="sendMessage()">Kirim</button>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (section == "notifikasi")
        {
            <div class="profile-inner">
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
                    <p class="profile-section-title" style="margin:0;">Notifikasi</p>
                    @if (notifications != null && notifications.Any(n => !n.IsRead))
                    {
                        <form asp-controller="Profile" asp-action="MarkAllRead" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="permintaan-accept-btn">Tandai semua dibaca</button>
                        </form>
                    }
                </div>

                @if (notifications == null || !notifications.Any())
                {
                    <p class="empty-text">Tidak ada notifikasi.</p>
                }
                else
                {
                    @foreach (var n in notifications)
                    {
                        <div class="notif-row @(n.IsRead ? "" : "notif-unread")">
                            <div class="flex-1">
                                <p class="notif-message">@n.Message</p>
                                <p class="notif-time">@((DateTime.UtcNow - n.CreatedAt).Days) hari lalu</p>
                            </div>
                            <div style="display:flex; gap:8px; align-items:center;">
                                @if (n.Link != null)
                                {
                                    <a href="@n.Link" class="notif-link-btn">Lihat</a>
                                }
                                @if (!n.IsRead)
                                {
                                    <form asp-controller="Profile" asp-action="MarkRead" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="notificationId" value="@n.Id" />
                                        <button type="submit" class="notif-read-btn">✓</button>
                                    </form>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        }

        @if (section == "profil")
        {
            <div class="profile-inner">
                <p class="profile-section-title">Profil Saya</p>
                <div class="profile-card">
                    <form asp-controller="Profile" asp-action="UpdateProfile" method="post">
                        @Html.AntiForgeryToken()

                        <div class="input-row">
                            <div class="form-group">
                                <label class="form-label">Nama Depan</label>
                                <input class="form-input" name="NamaDepan" value="@user?.NamaDepan" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Nama Belakang</label>
                                <input class="form-input" name="NamaBelakang" value="@user?.NamaBelakang" />
                            </div>
                        </div>

                        <div class="input-row">
                            <div class="form-group">
                                <label class="form-label">Email</label>
                                <input class="form-input" value="@user?.Email" disabled />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Nomor Telepon</label>
                                <input class="form-input" name="NomorTelepon" value="@user?.PhoneNumber" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Alamat</label>
                            <input class="form-input" name="Alamat" value="@user?.Alamat" />
                        </div>

                        <div class="input-row">
                            <div class="form-group">
                                <label class="form-label">Provinsi</label>
                                <select class="form-input" name="Provinsi">
                                    @foreach (var prov in new[] { "Aceh", "Bali", "Banten", "Bengkulu", "DI Yogyakarta", "DKI Jakarta", "Gorontalo", "Jambi", "Jawa Barat", "Jawa Tengah", "Jawa Timur", "Kalimantan Barat", "Kalimantan Selatan", "Kalimantan Tengah", "Kalimantan Timur", "Kalimantan Utara", "Kepulauan Bangka Belitung", "Kepulauan Riau", "Lampung", "Maluku", "Maluku Utara", "Nusa Tenggara Barat", "Nusa Tenggara Timur", "Papua", "Papua Barat", "Riau", "Sulawesi Barat", "Sulawesi Selatan", "Sulawesi Tengah", "Sulawesi Tenggara", "Sulawesi Utara", "Sumatera Barat", "Sumatera Selatan", "Sumatera Utara" })
                                    {
                                        <option selected="@(user?.Provinsi == prov)">@prov</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Kode Pos</label>
                                <input class="form-input" name="KodePos" value="@user?.KodePos" maxlength="5" />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-block">Simpan Perubahan</button>
                    </form>
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
    <script>
        function switchOvTab(tab) {
            document.getElementById('ovDonasi').style.display = tab === 'donasi' ? 'block' : 'none';
            document.getElementById('ovRequest').style.display = tab === 'request' ? 'block' : 'none';
            document.getElementById('ovTabDonasi').classList.toggle('active', tab === 'donasi');
            document.getElementById('ovTabRequest').classList.toggle('active', tab === 'request');
        }

        document.getElementById('imageInput')?.addEventListener('change', function () {
            var container = document.getElementById('previewContainer');
            container.innerHTML = '';
            Array.from(this.files).slice(0, 5).forEach(function(file) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    var div = document.createElement('div');
                    div.style.cssText = 'width:60px;height:60px;border-radius:6px;overflow:hidden;border:0.5px solid #cbd5e1;';
                    var img = document.createElement('img');
                    img.src = e.target.result;
                    img.style.cssText = 'width:100%;height:100%;object-fit:cover;';
                    div.appendChild(img);
                    container.appendChild(div);
                };
                reader.readAsDataURL(file);
            });
        });

        function validateImages() {
            var input = document.getElementById('imageInput');
            var error = document.getElementById('imageError');
            if (input && (!input.files || input.files.length === 0)) {
                error.textContent = 'Minimal 1 foto harus diunggah.';
                return false;
            }
            return true;
        }
    </script>

    @if (section == "pesan")
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
        <script>
            var currentUserId = '@currentUserId';
            var activeConvId = null;
            var connection = null;
            var initialConvId = @(initialConvId.HasValue ? initialConvId.Value.ToString() : "null");

            function initSignalR() {
            connection = new signalR.HubConnectionBuilder()
            .withUrl('/chatHub')
            .withAutomaticReconnect()
            .build();

            connection.on('ReceiveMessage', function (msg) {
            if (msg.conversationId === activeConvId) {
            appendMessage(msg);
            scrollToBottom();
            }
            });

            connection.start().then(function () {
            if (initialConvId !== null) {
            var target = document.querySelector('[data-conv-id="' + initialConvId + '"]');
            if (target) selectConversation(target);
            }
            }).catch(function (err) {
            console.error('SignalR error:', err);
            });
            }

            function selectConversation(el) {
            document.querySelectorAll('.chat-list-item').forEach(function (i) {
            i.classList.remove('active');
            });
            el.classList.add('active');

            var dot = el.querySelector('.chat-list-unread-dot');
            if (dot) dot.remove();

            var convId = parseInt(el.dataset.convId);
            var itemName = el.dataset.itemName;
            var otherName = el.dataset.otherName;
            var thumb = el.dataset.thumb;

            if (activeConvId !== null && connection) {
            connection.invoke('LeaveConversation', activeConvId).catch(function () {});
            }

            activeConvId = convId;

            var header = document.getElementById('chatHeader');
            var headerThumb = document.getElementById('chatHeaderThumb');
            var headerName = document.getElementById('chatHeaderName');
            var headerSub = document.getElementById('chatHeaderSub');

            header.style.display = 'flex';
            headerName.textContent = itemName;
            headerSub.textContent = 'dengan ' + otherName;

            if (thumb) {
            headerThumb.src = thumb;
            headerThumb.style.display = 'block';
            } else {
            headerThumb.style.display = 'none';
            }

            document.getElementById('chatNoSelect').style.display = 'none';
            document.getElementById('chatInputBar').style.display = 'flex';

            loadMessages(convId);

            if (connection && connection.state === signalR.HubConnectionState.Connected) {
            connection.invoke('JoinConversation', convId).catch(function (err) {
            console.error(err);
            });
            }
            }

            function loadMessages(convId) {
            var messagesEl = document.getElementById('chatMessages');
            messagesEl.innerHTML = '';

            fetch('/Chat/GetMessages?conversationId=' + convId)
            .then(function (r) { return r.json(); })
            .then(function (msgs) {
            msgs.forEach(function (m) { appendMessage(m); });
            scrollToBottom();
            });
            }

            function appendMessage(msg) {
            var messagesEl = document.getElementById('chatMessages');
            var isMine = msg.senderId === currentUserId;

            var row = document.createElement('div');
            row.className = 'chat-bubble-row ' + (isMine ? 'mine' : 'theirs');

            var bubble = document.createElement('div');
            bubble.className = 'chat-bubble';
            bubble.textContent = msg.content;

            var time = document.createElement('div');
            time.className = 'chat-bubble-time';
            var d = new Date(msg.sentAt);
            time.textContent = d.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });

            row.appendChild(bubble);
            row.appendChild(time);
            messagesEl.appendChild(row);
            }

            function scrollToBottom() {
            var el = document.getElementById('chatMessages');
            el.scrollTop = el.scrollHeight;
            }

            function sendMessage() {
            var input = document.getElementById('chatInput');
            var content = input.value.trim();
            if (!content || activeConvId === null) return;
            if (!connection || connection.state !== signalR.HubConnectionState.Connected) return;

            document.getElementById('chatSendBtn').disabled = true;

            connection.invoke('SendMessage', activeConvId, content)
            .then(function () {
            input.value = '';
            document.getElementById('chatSendBtn').disabled = false;
            })
            .catch(function (err) {
            console.error(err);
            document.getElementById('chatSendBtn').disabled = false;
            });
            }

            document.getElementById('chatInput')?.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
            }
            });

            initSignalR();
        </script>
    }
}
