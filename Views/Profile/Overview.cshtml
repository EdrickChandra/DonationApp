@using DonationApp.Models
@{
    var reviews = ViewBag.RecentReviews as List<Feedback>;
    var avgRating = (double)(ViewBag.AvgRating ?? 0.0);
    var totalReviews = (int)(ViewBag.TotalReviews ?? 0);
    var activeDonations = ViewBag.ActiveDonations as List<Item> ?? new List<Item>();
    var activeRequests = ViewBag.ActiveRequests as List<ItemRequest> ?? new List<ItemRequest>();
}

<div class="ppage">
    <div class="ppage-inner">

        <div class="pstat-grid">
            <div class="pstat-card">
                <div class="pstat-label">Donasi aktif</div>
                <div class="pstat-value">@ViewBag.ActiveDonasi</div>
            </div>
            <div class="pstat-card">
                <div class="pstat-label">Request aktif</div>
                <div class="pstat-value">@ViewBag.OpenRequest</div>
            </div>
            <div class="pstat-card">
                <div class="pstat-label">Rating donor</div>
                <div class="pstat-value">@(totalReviews > 0 ? avgRating.ToString("0.0") : "-")</div>
                @if (totalReviews > 0)
                {
                    <div class="pstars" style="margin-top:4px;">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span style="color:@(i <= Math.Round(avgRating) ? "#EF9F27" : "var(--color-border-tertiary)");">★</span>
                        }
                    </div>
                    <div class="pstat-sub">dari @totalReviews ulasan</div>
                }
                else
                {
                    <div class="pstat-sub">Belum ada ulasan</div>
                }
            </div>
        </div>

        <div class="pstat-grid" style="margin-top:12px;">
            <div class="pstat-card">
                <div class="pstat-label">Donasi selesai</div>
                <div class="pstat-value">@ViewBag.CompletedDonasi</div>
                <div class="pstat-sub">transaksi berhasil</div>
            </div>
            <div class="pstat-card">
                <div class="pstat-label">Orang terbantu</div>
                <div class="pstat-value">@ViewBag.PeopleHelped</div>
                <div class="pstat-sub">penerima donasi</div>
            </div>
            <div class="pstat-card">
                <div class="pstat-label">Total poin</div>
                <div class="pstat-value">@ViewBag.TotalPoin</div>
            </div>
        </div>

        <div class="preview-card" style="margin-top:16px;">
            <div class="preview-header">Donasi aktif</div>
            @if (activeDonations.Any())
            {
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px;">
                    @foreach (var item in activeDonations)
                    {
                        var img = item.Images.FirstOrDefault();
                        var daysLeft = (item.ExpiresAt - DateTime.UtcNow).Days;
                        <a href="/Donasi/Index?selectedId=@item.Id" style="text-decoration:none;display:block;">
                            <div style="border:1px solid var(--color-border-secondary);border-radius:10px;overflow:hidden;background:var(--color-bg-primary);">
                                <div style="aspect-ratio:1;overflow:hidden;background:#f1f5f9;">
                                    @if (img != null)
                                    {
                                        <img src="@img.FilePath" style="width:100%;height:100%;object-fit:cover;" />
                                    }
                                </div>
                                <div style="padding:8px;">
                                    <div style="font-size:14px;font-weight:600;color:var(--color-text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@item.NamaBarang</div>
                                    <div style="font-size:13px;color:var(--color-text-secondary);margin-top:2px;">
                                        <i class="ti ti-clock" style="font-size:13px;" aria-hidden="true"></i> @daysLeft hari lagi
                                    </div>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div style="padding:24px;text-align:center;font-size:15px;color:var(--color-text-secondary);">Belum ada donasi aktif. Mulai berdonasi sekarang!</div>
            }
        </div>

        <div class="preview-card" style="margin-top:12px;">
            <div class="preview-header">Request aktif</div>
            @if (activeRequests.Any())
            {
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px;">
                    @foreach (var req in activeRequests)
                    {
                        var img = req.Images.FirstOrDefault();
                        var daysLeft = (req.ExpiresAt - DateTime.UtcNow).Days;
                        <a href="/Request/MyRequests?selectedId=@req.Id" style="text-decoration:none;display:block;">
                            <div style="border:1px solid var(--color-border-secondary);border-radius:10px;overflow:hidden;background:var(--color-bg-primary);">
                                <div style="aspect-ratio:1;overflow:hidden;background:#f1f5f9;">
                                    @if (img != null)
                                    {
                                        <img src="@img.FilePath" style="width:100%;height:100%;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#94a3b8;">
                                            <i class="ti ti-list-search" style="font-size:24px;" aria-hidden="true"></i>
                                        </div>
                                    }
                                </div>
                                <div style="padding:8px;">
                                    <div style="font-size:14px;font-weight:600;color:var(--color-text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@req.Title</div>
                                    <div style="font-size:13px;color:var(--color-text-secondary);margin-top:2px;">
                                        <i class="ti ti-clock" style="font-size:13px;" aria-hidden="true"></i> @daysLeft hari lagi
                                    </div>
                                </div>
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <div style="padding:24px;text-align:center;font-size:15px;color:var(--color-text-secondary);">Belum ada request aktif. Buat request barang yang kamu butuhkan!</div>
            }
        </div>

        @if (reviews != null && reviews.Any())
        {
            <div class="preview-card" style="margin-top:12px;">
                <div class="preview-header">Ulasan terbaru</div>
                @foreach (var r in reviews)
                {
                    var rAvatar = r.Reviewer?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
                    var rName = r.Reviewer != null ? r.Reviewer.NamaDepan + " " + r.Reviewer.NamaBelakang : "Unknown";
                    var daysAgo = (DateTime.UtcNow - r.CreatedAt).Days;
                    var itemName = r.ClaimRequest?.Item?.NamaBarang ?? r.ItemRequest?.Title ?? "";
                    <div class="preview-item">
                        <div class="avatar">@rAvatar</div>
                        <div class="flex-1">
                            <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;">
                                <span class="preview-name">@rName</span>
                                <span class="pstars" style="font-size:14px;">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span style="color:@(i <= r.Rating ? "#EF9F27" : "var(--color-border-tertiary)");">★</span>
                                    }
                                </span>
                                <span class="preview-time">@daysAgo hari lalu</span>
                            </div>
                            @if (!string.IsNullOrEmpty(r.Komentar))
                            {
                                <div class="preview-text">@r.Komentar</div>
                            }
                            @if (!string.IsNullOrEmpty(r.FotoPath))
                            {
                                <div style="margin-top:6px;">
                                    <img src="@r.FotoPath" style="max-width:120px;max-height:120px;border-radius:6px;object-fit:cover;cursor:pointer;" onclick="window.open(this.src)" />
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(itemName))
                            {
                                <div style="font-size:13px;color:var(--color-text-secondary);margin-top:4px;">untuk "@itemName"</div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="preview-card" style="margin-top:12px;">
                <div class="preview-header">Ulasan terbaru</div>
                <div style="padding:32px;text-align:center;font-size:15px;color:var(--color-text-secondary);">Belum ada ulasan.</div>
            </div>
        }

    </div>
</div>
