@using DonationApp.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var query = ViewBag.Query as string ?? "";
    var activeTab = ViewBag.ActiveTab as string ?? "donasi";
    var donations = ViewBag.Donations as List<Item> ?? new List<Item>();
    var requests = ViewBag.Requests as List<ItemRequest> ?? new List<ItemRequest>();
    var selected = ViewBag.SelectedKategori as ItemCategory?;
}

<div class="page-header">
    <div class="page-header-inner">
        <div class="pills">
            <a class="pill @(selected == null ? "active" : "")"
               asp-controller="Request" asp-action="Index">
                <i class="ti ti-layout-grid" aria-hidden="true"></i>
                Semua
            </a>
            @foreach (var cat in CategoryHelper.AllCategories())
            {
                var icon = cat switch
                {
                    ItemCategory.Pakaian => "ti-shirt",
                    ItemCategory.Elektronik => "ti-device-laptop",
                    ItemCategory.PerabotRumah => "ti-armchair",
                    ItemCategory.Mainan => "ti-fidget-spinner",
                    ItemCategory.AlatMusik => "ti-guitar-pick",
                    _ => "ti-tag"
                };
                <a class="pill @(selected == cat ? "active" : "")"
                   asp-controller="Request" asp-action="Index" asp-route-kategori="@cat">
                    <i class="ti @icon" aria-hidden="true"></i>
                    @CategoryHelper.DisplayName(cat)
                </a>
            }
        </div>
    </div>
</div>

<div class="feed-wrap">
    <div style="display:flex;align-items:center;margin-bottom:16px;">
        <span class="feed-title" style="font-size:16px;">
            @if (!string.IsNullOrWhiteSpace(query))
            {
                <span>Hasil untuk "<strong>@query</strong>"</span>
            }
            else
            {
                <span>Semua barang</span>
            }
        </span>
    </div>

    <div class="feed-tabs">
        <a class="feed-tab @(activeTab == "donasi" ? "active" : "")"
           href="/Search?q=@Uri.EscapeDataString(query)&tab=donasi@(selected.HasValue ? $"&kategori={(int)selected.Value}" : "")">
            Donasi (@donations.Count)
        </a>
        <a class="feed-tab @(activeTab == "request" ? "active" : "")"
           href="/Search?q=@Uri.EscapeDataString(query)&tab=request@(selected.HasValue ? $"&kategori={(int)selected.Value}" : "")">
            Request (@requests.Count)
        </a>
    </div>

    @if (activeTab == "donasi")
    {
        @if (!donations.Any())
        {
            <p class="card-grid-empty">Tidak ada donasi ditemukan.</p>
        }
        else
        {
            <div class="card-grid">
                @foreach (var item in donations)
                {
                    var daysLeft = (item.ExpiresAt - DateTime.UtcNow).Days;
                    var images = item.Images.ToList();
                    var posterInitial = item.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
                    var posterName = item.User?.NamaDepan ?? "Unknown";
                    var kondisiBadgeClass = item.Kondisi == ItemCondition.Baru ? "card-kondisi-baru" : "card-kondisi-bekas";
                    var kondisiLabel = item.Kondisi == ItemCondition.Baru ? "Baru" : "Bekas";
                    var cardId = $"s-card-{item.Id}";
                    <div class="item-card" style="position:relative;">
                        <a asp-controller="Item" asp-action="Detail" asp-route-id="@item.Id" style="text-decoration:none;display:block;">
                            <div class="card-img">
                                <img src="@images.First().FilePath" class="card-img-fill" />
                                <span class="card-timer-badge">
                                    <i class="ti ti-clock" aria-hidden="true"></i>
                                    @daysLeft hari
                                </span>
                                <span class="@kondisiBadgeClass">@kondisiLabel</span>
                            </div>
                            <div class="card-body">
                                <div class="card-name">@item.NamaBarang</div>
                                <div class="card-meta">
                                    <span class="card-cat">@CategoryHelper.DisplayName(item.Kategori)</span>
                                    <span class="card-dot">·</span>
                                    <span class="card-loc">
                                        <i class="ti ti-map-pin" aria-hidden="true"></i>
                                        @item.Lokasi
                                    </span>
                                </div>
                            </div>
                            <div class="card-footer">
                                <a href="/Profile/View/@item.UserId" class="card-poster" style="text-decoration:none;color:inherit;" onclick="event.stopPropagation();">
                                    <div class="avatar avatar-xs">@posterInitial</div>
                                    <span class="card-poster-name">@posterName</span>
                                </a>
                            </div>
                        </a>
                        <button class="btn-card-menu" onclick="toggleCardMenu('@cardId', event)" aria-label="Opsi">
                            <i class="ti ti-dots-vertical" aria-hidden="true"></i>
                        </button>
                        <div class="card-menu-dropdown" id="@cardId">
                            <button class="card-menu-item" onclick="reportItem(@item.Id)">
                                <i class="ti ti-flag" aria-hidden="true"></i> Lapor
                            </button>
                            <button class="card-menu-item" onclick="copyLink('/Item/Detail/@item.Id')">
                                <i class="ti ti-copy" aria-hidden="true"></i> Salin Link
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    }
    else
    {
        @if (!requests.Any())
        {
            <p class="card-grid-empty">Tidak ada request ditemukan.</p>
        }
        else
        {
            <div class="card-grid">
                @foreach (var req in requests)
                {
                    var daysLeft = (req.ExpiresAt - DateTime.UtcNow).Days;
                    var firstImage = req.Images.FirstOrDefault();
                    var avatarLetter = req.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
                    var posterName = req.User?.NamaDepan ?? "Unknown";
                    var cardId = $"s-req-{req.Id}";
                    <div class="item-card" style="position:relative;">
                        <a asp-controller="Request" asp-action="Detail" asp-route-id="@req.Id" style="text-decoration:none;display:block;">
                            <div class="card-img">
                                @if (firstImage != null)
                                {
                                    <img src="@firstImage.FilePath" class="card-img-fill" />
                                }
                                else
                                {
                                    <div class="card-img-empty">
                                        <i class="ti ti-list-search" aria-hidden="true"></i>
                                    </div>
                                }
                                <span class="card-request-badge">Request</span>
                                <span class="card-timer-badge">
                                    <i class="ti ti-clock" aria-hidden="true"></i>
                                    @daysLeft hari
                                </span>
                            </div>
                            <div class="card-body">
                                <div class="card-name">@req.Title</div>
                                <div class="card-meta">
                                    <span class="card-cat">@CategoryHelper.DisplayName(req.Kategori)</span>
                                    @if (req.Offers.Any())
                                    {
                                        <span class="card-dot">·</span>
                                        <span class="card-offers">@req.Offers.Count penawaran</span>
                                    }
                                </div>
                            </div>
                            <div class="card-footer">
                                <a href="/Profile/View/@req.UserId" class="card-poster" style="text-decoration:none;color:inherit;" onclick="event.stopPropagation();">
                                    <div class="avatar avatar-xs">@avatarLetter</div>
                                    <span class="card-poster-name">@posterName</span>
                                </a>
                            </div>
                        </a>
                        <button class="btn-card-menu" onclick="toggleCardMenu('@cardId', event)" aria-label="Opsi">
                            <i class="ti ti-dots-vertical" aria-hidden="true"></i>
                        </button>
                        <div class="card-menu-dropdown" id="@cardId">
                            <button class="card-menu-item" onclick="reportRequest(@req.Id)">
                                <i class="ti ti-flag" aria-hidden="true"></i> Lapor
                            </button>
                            <button class="card-menu-item" onclick="copyLink('/Request/Detail/@req.Id')">
                                <i class="ti ti-copy" aria-hidden="true"></i> Salin Link
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

@section Scripts {
    <script src="~/js/card-menu.js" asp-append-version="true"></script>
}
