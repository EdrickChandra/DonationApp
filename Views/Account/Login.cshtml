@model DonationApp.Models.LoginViewModel
@{
    ViewData["HideSearch"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="display:flex; justify-content:center; padding: 32px 0;">
    <div class="auth-card">
        <div class="auth-title">Selamat Datang</div>
        <div class="auth-subtitle">Belum punya akun? <a asp-controller="Account" asp-action="Register">Daftar di sini</a></div>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <span class="validation-message" asp-validation-summary="ModelOnly"></span>

            <div class="form-group">
                <label class="form-label" asp-for="Email">Email</label>
                <input class="form-input" asp-for="Email" placeholder="email@contoh.com" />
                <span class="validation-message" asp-validation-for="Email"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Password">Password</label>
                <input class="form-input" asp-for="Password" type="password" placeholder="••••••••" />
                <span class="validation-message" asp-validation-for="Password"></span>
            </div>

            <button type="submit" class="submit-btn">Masuk</button>
        </form>
    </div>
</div>