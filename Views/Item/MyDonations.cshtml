@model IEnumerable<DonationApp.Models.Item>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<a class="back-btn" asp-controller="Home" asp-action="Index">← Kembali ke page sebelumnya</a>

<a class="add-btn" asp-controller="Item" asp-action="Create">+</a>

<div class="divider"></div>

<div class="card-grid">
    @foreach (var item in Model)
    {
        var daysLeft = (item.ExpiresAt - DateTime.UtcNow).Days;
        <div class="item-card" onclick="openRequesterModal('@item.NamaBarang')">
            <div class="card-image">
                <svg width="48" height="48" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24">
                    <rect x="3" y="3" width="18" height="18" rx="2" />
                    <path d="m3 9 4-4 4 4 4-4 4 4" />
                    <circle cx="8.5" cy="13.5" r="1.5" />
                    <path d="m21 15-5-5-5 5" />
                </svg>
            </div>
            <div class="card-info">
                <div class="card-row">
                    <span class="card-name">@item.NamaBarang</span>
                    <span class="card-lokasi">@item.Lokasi</span>
                </div>
                <div class="card-timer">⏱ @daysLeft hari lagi</div>
            </div>
        </div>
    }
</div>

<div class="modal-overlay" id="requesterModal">
    <div class="modal-box">
        <button class="modal-close" onclick="closeModal('requesterModal')">✕</button>
        <div class="modal-top">
            <div class="modal-image">
                <svg width="48" height="48" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24">
                    <rect x="3" y="3" width="18" height="18" rx="2" />
                    <path d="m3 9 4-4 4 4 4-4 4 4" />
                    <circle cx="8.5" cy="13.5" r="1.5" />
                    <path d="m21 15-5-5-5 5" />
                </svg>
            </div>
            <div class="requester-list">
                <div class="requester-item">
                    <div class="requester-avatar">A</div>
                    <span class="requester-name">Ahmad Fauzi</span>
                </div>
                <div class="requester-item">
                    <div class="requester-avatar">S</div>
                    <span class="requester-name">Siti Rahma</span>
                </div>
                <div class="requester-item">
                    <div class="requester-avatar">B</div>
                    <span class="requester-name">Budi Santoso</span>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="modal-btn">Terima</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openRequesterModal(nama) {
            document.getElementById('requesterModal').classList.add('open');
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove('open');
        }

        document.getElementById('requesterModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal('requesterModal');
        });
    </script>
}