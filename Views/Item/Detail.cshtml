@model DonationApp.Models.Item
@using DonationApp.Models
@using System.Text.Json
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var images = Model.Images.ToList();
    var daysLeft = (Model.ExpiresAt - DateTime.UtcNow).Days;
    var isOwner = (bool)ViewBag.IsOwner;
    var hasRequested = (bool)ViewBag.HasRequested;
    var posterInitial = Model.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
    var posterName = Model.User != null ? Model.User.NamaDepan + " " + Model.User.NamaBelakang : "Unknown";
    var avgRating = ViewBag.AverageRating as double? ?? 0;
    var totalReviews = ViewBag.TotalReviews as int? ?? 0;

    Dictionary<string, string>? detailTambahan = null;
    if (!string.IsNullOrWhiteSpace(Model.DetailTambahan))
    {
        try { detailTambahan = JsonSerializer.Deserialize<Dictionary<string, string>>(Model.DetailTambahan); } catch { }
    }
}

<div class="dpage">
    <a class="back-btn" asp-controller="Home" asp-action="Index">
        <i class="ti ti-arrow-left" aria-hidden="true"></i> Kembali
    </a>

    <div class="dpage-grid">

        <div class="dpage-left">
            <div class="dpage-img-wrap">
                <img id="mainImage" src="@images[0].FilePath" class="dpage-main-img" onclick="openZoom()" />
                <button onclick="slideImage(-1)" class="detail-slide-btn left">‹</button>
                <button onclick="slideImage(1)" class="detail-slide-btn right">›</button>
                <span id="imageCounter" class="detail-counter">1 / @images.Count</span>
            </div>
            <div class="detail-thumbs">
                @for (int i = 0; i < images.Count; i++)
                {
                    <div onclick="setImage(@i)" class="detail-thumb @(i == 0 ? "active" : "")" id="thumb-@i">
                        <img src="@images[i].FilePath" />
                    </div>
                }
            </div>
        </div>

        <div class="dpage-right">

            <div class="dcard">
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:10px;">
                    <div>
                        <div class="detail-badges" style="margin-bottom:8px;">
                            <span class="detail-badge-blue">@CategoryHelper.DisplayName(Model.Kategori)</span>
                        </div>
                        <h1 class="dpage-title">@Model.NamaBarang</h1>
                    </div>
                </div>

                <div class="duser-row">
                    <div class="detail-poster-av">@posterInitial</div>
                    <div style="flex:1;min-width:0;">
                        <div class="detail-poster-name">@posterName</div>
                        <div style="display:flex;align-items:center;gap:5px;margin-top:1px;">
                            @if (totalReviews > 0)
                            {
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <span style="color:@(s <= Math.Round(avgRating) ? "#EF9F27" : "#cbd5e1");font-size:11px;">★</span>
                                }
                                <span style="font-size:11px;color:#64748b;">@avgRating.ToString("0.0") · @totalReviews ulasan</span>
                            }
                            else
                            {
                                <span style="font-size:11px;color:#94a3b8;">Belum ada ulasan</span>
                            }
                        </div>
                    </div>
                    <div style="font-size:11px;color:#64748b;display:flex;align-items:center;gap:3px;white-space:nowrap;">
                        <i class="ti ti-map-pin" style="font-size:12px;" aria-hidden="true"></i>
                        @Model.Lokasi@(!string.IsNullOrWhiteSpace(Model.Provinsi) ? ", " + Model.Provinsi : "")
                    </div>
                </div>
            </div>

            <div class="dcard">
                <div class="dinfo-grid">
                    <div class="dinfo-cell" style="border-right:1px solid #e2e8f0;">
                        <div class="detail-row-label">Kondisi</div>
                        <div class="detail-row-value" style="margin-top:4px;">@Model.Kondisi</div>
                    </div>
                    <div class="dinfo-cell">
                        <div class="detail-row-label">Tersedia</div>
                        <div class="detail-row-value" style="margin-top:4px;">@Model.Jumlah pcs</div>
                    </div>
                </div>
            </div>

            <div class="dcard">
                <div class="detail-row-label" style="margin-bottom:6px;">Deskripsi</div>
                <div class="detail-row-value">@Model.Deskripsi</div>
            </div>

            @if (detailTambahan != null && detailTambahan.Any())
            {
                <div class="dcard">
                    <div class="detail-row-label" style="margin-bottom:8px;">Detail Tambahan</div>
                    <div style="display:flex;flex-direction:column;gap:8px;">
                        @foreach (var kv in detailTambahan)
                        {
                            <div style="display:flex;justify-content:space-between;align-items:center;font-size:13px;border-bottom:1px solid #f1f5f9;padding-bottom:6px;">
                                <span style="color:#64748b;">@kv.Key</span>
                                <span style="color:#0f172a;font-weight:600;">@kv.Value</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="dcard">
                @if (isOwner)
                {
                    <button class="detail-btn detail-btn-disabled" disabled>Barang Anda</button>
                }
                else if (hasRequested)
                {
                    <button class="detail-btn detail-btn-disabled" style="margin-bottom:8px;" disabled>Sudah Diminta</button>
                    <form asp-controller="Donasi" asp-action="Chat" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="itemId" value="@Model.Id" />
                        <input type="hidden" name="otherUserId" value="@Model.UserId" />
                        <button type="submit" class="detail-btn-ghost">
                            <i class="ti ti-message-2" aria-hidden="true"></i> Chat dengan Donor
                        </button>
                    </form>
                }
                else if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <form asp-controller="Donasi" asp-action="Request" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="itemId" value="@Model.Id" />

                        @if (Model.Jumlah > 1)
                        {
                            <div style="margin-bottom:14px;">
                                <div class="detail-row-label" style="margin-bottom:8px;">Jumlah yang diminta</div>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <button type="button" class="stepper-btn" onclick="stepDown()">−</button>
                                    <span id="stepperDisplay" style="font-size:18px;font-weight:700;min-width:28px;text-align:center;">1</span>
                                    <button type="button" class="stepper-btn" onclick="stepUp(@Model.Jumlah)">+</button>
                                    <span style="font-size:12px;color:#94a3b8;">maks. @Model.Jumlah pcs</span>
                                </div>
                                <input type="hidden" name="jumlah" id="stepperInput" value="1" />
                            </div>
                        }
                        else
                        {
                            <input type="hidden" name="jumlah" value="1" />
                        }

                        <button type="submit" class="detail-btn">
                            <i class="ti ti-hand-stop" aria-hidden="true"></i> Minta Barang
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="detail-btn">Masuk untuk Meminta</a>
                }

                <div style="display:flex;align-items:center;justify-content:space-between;margin-top:12px;padding-top:12px;border-top:1px solid #e2e8f0;">
                    <div class="detail-timer">
                        <i class="ti ti-clock" aria-hidden="true"></i>
                        Sisa @daysLeft hari
                    </div>
                    <div style="display:flex;gap:8px;">
                        <button class="detail-btn-ghost" style="padding:6px 12px;font-size:12px;" onclick="reportDetail()">
                            <i class="ti ti-flag" aria-hidden="true" style="color:#ef4444;"></i> Lapor
                        </button>
                        <button class="detail-btn-ghost" style="padding:6px 12px;font-size:12px;" onclick="copyDetailLink()">
                            <i class="ti ti-copy" aria-hidden="true"></i> Salin Link
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal-overlay" id="zoomModal">
    <div class="zoom-modal-inner">
        <button onclick="closeZoom()" class="zoom-close-btn">✕</button>
        <img id="zoomImage" src="" class="zoom-img" />
    </div>
</div>

@section Scripts {
    <style>
        .stepper-btn {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            border: 1.5px solid #cbd5e1;
            background: #f1f5f9;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.15s, border-color 0.15s;
            color: #0f172a;
        }
        .stepper-btn:hover {
            background: #e2e8f0;
            border-color: #94a3b8;
        }
    </style>
    <script>
        var images = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(images.Select(i => i.FilePath).ToList()));
        var currentIndex = 0;

        function setImage(index) {
            currentIndex = index;
            document.getElementById('mainImage').src = images[index];
            document.getElementById('imageCounter').textContent = (index + 1) + ' / ' + images.length;
            document.querySelectorAll('[id^="thumb-"]').forEach(function(el, i) {
                el.classList.toggle('active', i === index);
            });
        }

        function slideImage(dir) {
            setImage((currentIndex + dir + images.length) % images.length);
        }

        function openZoom() {
            document.getElementById('zoomImage').src = images[currentIndex];
            document.getElementById('zoomModal').classList.add('open');
        }

        function closeZoom() {
            document.getElementById('zoomModal').classList.remove('open');
        }

        document.getElementById('zoomModal').addEventListener('click', function(e) {
            if (e.target === this) closeZoom();
        });

        function copyDetailLink() {
            navigator.clipboard.writeText(window.location.href);
        }

        function reportDetail() {
            openReportModal(@Model.Id, null);
        }

        var stepperVal = 1;

        function stepDown() {
            if (stepperVal > 1) {
                stepperVal--;
                document.getElementById('stepperDisplay').textContent = stepperVal;
                document.getElementById('stepperInput').value = stepperVal;
            }
        }

        function stepUp(max) {
            if (stepperVal < max) {
                stepperVal++;
                document.getElementById('stepperDisplay').textContent = stepperVal;
                document.getElementById('stepperInput').value = stepperVal;
            }
        }
    </script>
}
