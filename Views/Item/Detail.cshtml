@model DonationApp.Models.Item
@using DonationApp.Models
@using System.Text.Json
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var images = Model.Images.ToList();
    var daysLeft = (Model.ExpiresAt - DateTime.UtcNow).Days;
    var isOwner = (bool)ViewBag.IsOwner;
    var hasRequested = (bool)ViewBag.HasRequested;
    var posterInitial = Model.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
    var posterName = Model.User != null ? Model.User.NamaDepan + " " + Model.User.NamaBelakang : "Unknown";
    var avgRating = ViewBag.AverageRating != null ? (double)ViewBag.AverageRating : 0.0;
    var totalReviews = ViewBag.TotalReviews != null ? (int)ViewBag.TotalReviews : 0;

    Dictionary<string, string>? detailTambahan = null;
    if (!string.IsNullOrWhiteSpace(Model.DetailTambahan))
    {
        try { detailTambahan = JsonSerializer.Deserialize<Dictionary<string, string>>(Model.DetailTambahan); } catch { }
    }
}

<div class="dpage">
    <a class="back-btn" asp-controller="Home" asp-action="Index">
        <i class="ti ti-arrow-left" aria-hidden="true"></i> Kembali
    </a>

    <div class="dpage-grid">

        <div class="dpage-left">
            <div class="dpage-img-wrap">
                <img id="mainImage" src="@images[0].FilePath" class="dpage-main-img" onclick="openZoom()" />
                <button onclick="slideImage(-1)" class="btn-slide left">‹</button>
                <button onclick="slideImage(1)" class="btn-slide right">›</button>
                <span id="imageCounter" class="detail-counter">1 / @images.Count</span>
            </div>
            <div class="detail-thumbs">
                @for (int i = 0; i < images.Count; i++)
                {
                    <div onclick="setImage(@i)" class="detail-thumb @(i == 0 ? "active" : "")" id="thumb-@i">
                        <img src="@images[i].FilePath" />
                    </div>
                }
            </div>
        </div>

        <div class="dpage-right">

            <div class="dcard">
                <div class="dhead-row">
                    <div>
                        <div class="detail-badges mb-8">
                            <span class="badge badge-lg badge-blue">@CategoryHelper.DisplayName(Model.Kategori)</span>
                        </div>
                        <h1 class="dpage-title">@Model.NamaBarang</h1>
                    </div>
                </div>

                <a href="/Profile/View/@Model.UserId" class="duser-row link-plain">
                    <div class="avatar">@posterInitial</div>
                    <div class="flex-min">
                        <div class="detail-poster-name">@posterName</div>
                        <div class="drating-row">
                            @if (totalReviews > 0)
                            {
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <span style="color:@(s <= Math.Round(avgRating) ? "#EF9F27" : "#cbd5e1");font-size:13px;">★</span>
                                }
                                <span class="text-xs-muted">@avgRating.ToString("0.0") · @totalReviews ulasan</span>
                            }
                            else
                            {
                                <span class="text-xs-dim">Belum ada ulasan</span>
                            }
                        </div>
                    </div>
                    <div class="dloc-row">
                        <i class="ti ti-map-pin icon-14" aria-hidden="true"></i>
                        @Model.Lokasi@(!string.IsNullOrWhiteSpace(Model.Provinsi) ? ", " + Model.Provinsi : "")
                    </div>
                </a>
            </div>

            <div class="dcard">
                <div class="dinfo-grid">
                    <div class="dinfo-cell dinfo-cell--border">
                        <div class="detail-row-label">Kondisi</div>
                        <div class="detail-row-value mt-4">@Model.Kondisi</div>
                    </div>
                    <div class="dinfo-cell">
                        <div class="detail-row-label">Tersedia</div>
                        <div class="detail-row-value mt-4">@Model.Jumlah pcs</div>
                    </div>
                </div>
            </div>

            <div class="dcard">
                <div class="detail-row-label mb-6">Deskripsi</div>
                <div class="detail-row-value">@Model.Deskripsi</div>
            </div>

            @if (detailTambahan != null && detailTambahan.Any())
            {
                <div class="dcard">
                    <div class="detail-row-label mb-8">Detail Tambahan</div>
                    <div class="ddetail-tambahan-list">
                        @foreach (var kv in detailTambahan)
                        {
                            <div class="ddetail-tambahan-row">
                                <span class="ddetail-key">@kv.Key</span>
                                <span class="ddetail-val">@kv.Value</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="dcard">
                @if (isOwner)
                {
                    <button class="btn btn-ghost btn-lg btn-block" disabled>Barang Anda</button>
                }
                else if (hasRequested)
                {
                    <button class="btn btn-ghost btn-lg btn-block mb-8" disabled>Sudah Diminta</button>
                    <form asp-controller="Donasi" asp-action="Chat" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="itemId" value="@Model.Id" />
                        <input type="hidden" name="otherUserId" value="@Model.UserId" />
                        <button type="submit" class="btn btn-ghost btn-lg btn-block">
                            <i class="ti ti-message-2" aria-hidden="true"></i> Chat dengan Donor
                        </button>
                    </form>
                }
                else if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <form asp-controller="Donasi" asp-action="Request" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="itemId" value="@Model.Id" />

                        @if (Model.Jumlah > 1)
                        {
                            <div class="mb-14">
                                <div class="detail-row-label mb-8">Jumlah yang diminta</div>
                                <div class="dstepper-row">
                                    <button type="button" class="stepper-btn" onclick="stepDown()">−</button>
                                    <span id="stepperDisplay" class="dstepper-display">1</span>
                                    <button type="button" class="stepper-btn" onclick="stepUp(@Model.Jumlah)">+</button>
                                    <span class="text-xs-dim">maks. @Model.Jumlah pcs</span>
                                </div>
                                <input type="hidden" name="jumlah" id="stepperInput" value="1" />
                            </div>
                        }
                        else
                        {
                            <input type="hidden" name="jumlah" value="1" />
                        }

                        <button type="submit" class="btn btn-primary btn-lg btn-block">
                            <i class="ti ti-hand-stop" aria-hidden="true"></i> Minta Barang
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg btn-block">Masuk untuk Meminta</a>
                }

                <div class="daction-bar">
                    <div class="detail-timer">
                        <i class="ti ti-clock" aria-hidden="true"></i>
                        Sisa @daysLeft hari
                    </div>
                    <div class="dbtn-group">
                        <button class="btn btn-ghost btn-sm" onclick="reportDetail()">
                            <i class="ti ti-flag icon-danger" aria-hidden="true"></i> Lapor
                        </button>
                        <button class="btn btn-ghost btn-sm" onclick="copyDetailLink()">
                            <i class="ti ti-copy" aria-hidden="true"></i> Salin Link
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal-overlay" id="zoomModal">
    <div class="zoom-modal-inner">
        <button onclick="closeZoom()" class="zoom-close-btn">✕</button>
        <img id="zoomImage" src="" class="zoom-img" />
    </div>
</div>

@section Scripts {
    <style>
        .stepper-btn {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            border: 1.5px solid #cbd5e1;
            background: #f1f5f9;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.15s, border-color 0.15s;
            color: #0f172a;
        }
        .stepper-btn:hover {
            background: #e2e8f0;
            border-color: #94a3b8;
        }
    </style>
    <script>
        var images = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(images.Select(i => i.FilePath).ToList()));
        var currentIndex = 0;

        function setImage(index) {
            currentIndex = index;
            document.getElementById('mainImage').src = images[index];
            document.getElementById('imageCounter').textContent = (index + 1) + ' / ' + images.length;
            document.querySelectorAll('[id^="thumb-"]').forEach(function(el, i) {
                el.classList.toggle('active', i === index);
            });
        }

        function slideImage(dir) {
            setImage((currentIndex + dir + images.length) % images.length);
        }

        function openZoom() {
            document.getElementById('zoomImage').src = images[currentIndex];
            document.getElementById('zoomModal').classList.add('open');
        }

        function closeZoom() {
            document.getElementById('zoomModal').classList.remove('open');
        }

        document.getElementById('zoomModal').addEventListener('click', function(e) {
            if (e.target === this) closeZoom();
        });

        function copyDetailLink() {
            navigator.clipboard.writeText(window.location.href);
        }

        function reportDetail() {
            openReportModal(@Model.Id, null);
        }

        var stepperVal = 1;

        function stepDown() {
            if (stepperVal > 1) {
                stepperVal--;
                document.getElementById('stepperDisplay').textContent = stepperVal;
                document.getElementById('stepperInput').value = stepperVal;
            }
        }

        function stepUp(max) {
            if (stepperVal < max) {
                stepperVal++;
                document.getElementById('stepperDisplay').textContent = stepperVal;
                document.getElementById('stepperInput').value = stepperVal;
            }
        }
    </script>
}
