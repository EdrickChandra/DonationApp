<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>IDonasi</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=DM+Sans:wght@400;500&amp;display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/global.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/item.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/profile-mobile-append.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/nprogress/0.2.0/nprogress.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@latest/tabler-icons.min.css" />
</head>
<body>
    <nav>
        <a class="logo" asp-controller="Home" asp-action="Index">IDonasi</a>

        @if (ViewData["HideSearch"] == null)
        {
            <input class="search-bar" type="text" placeholder="Search...">
        }

        <div class="nav-links-desktop" style="margin-left:12px;">
            <a class="nav-page-link" asp-controller="Home" asp-action="Index">Donasi</a>
            <a class="nav-page-link" asp-controller="Request" asp-action="Index">Request</a>
        </div>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <div style="display:flex;align-items:center;gap:8px;margin-left:auto;">
                <a asp-controller="Notifikasi" asp-action="Index" class="nav-bell" title="Notifikasi">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                    </svg>
                    @{
                        var unread = ViewBag.UnreadCount as int? ?? 0;
                    }
                    @if (unread > 0)
                    {
                        <span class="nav-bell-badge">@unread</span>
                    }
                </a>

                <div class="nav-dropdown" id="navDropdown">
                    <div class="nav-user" onclick="toggleDropdown()" style="cursor:pointer;">
                        <div class="avatar">@(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "?")</div>
                        <span class="nav-username">@(User.Identity?.Name ?? "")</span>
                        <span style="font-size:10px;">▼</span>
                    </div>
                    <div class="dropdown-menu" id="dropdownMenu">
                        <a class="dropdown-item" asp-controller="Home" asp-action="Index">Donasi</a>
                        <a class="dropdown-item" asp-controller="Request" asp-action="Index">Request</a>
                        <div class="dropdown-divider"></div>
                        <a class="dropdown-item" asp-controller="Profile" asp-action="Edit">Profil</a>
                        <a class="dropdown-item" asp-controller="Donasi" asp-action="Index">Donasi Saya</a>
                        <a class="dropdown-item" asp-controller="Request" asp-action="MyRequests">Request Saya</a>
                        <a class="dropdown-item" asp-controller="Pesan" asp-action="Index">Pesan</a>
                        <div class="dropdown-divider"></div>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item dropdown-item-danger">Keluar</button>
                        </form>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div style="margin-left:auto;display:flex;gap:8px;">
                <a class="nav-login-btn" asp-controller="Account" asp-action="Login">Masuk</a>
                <a class="nav-btn nav-donasi-btn" asp-controller="Account" asp-action="Register">Daftar</a>
            </div>
        }
    </nav>

    <main id="main-content">
        @RenderBody()
    </main>

    <footer>
        <span class="footer-copyright">©IDonasi, 2026. ALL RIGHTS RESERVED</span>
    </footer>

    <script>
        document.querySelectorAll('.condition-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                this.closest('.condition-group').querySelectorAll('.condition-btn').forEach(b => b.classList.remove('selected'));
                this.classList.add('selected');
                const input = document.getElementById('kondisiInput');
                if (input) input.value = this.dataset.value;
            });
        });

        function toggleDropdown() {
            document.getElementById('dropdownMenu').classList.toggle('open');
        }

        document.addEventListener('click', function(e) {
            var dropdown = document.getElementById('navDropdown');
            if (dropdown && !dropdown.contains(e.target)) {
                document.getElementById('dropdownMenu').classList.remove('open');
            }
        });
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/nprogress/0.2.0/nprogress.min.js"></script>
    <script>
        NProgress.configure({ showSpinner: false, speed: 300 });
        document.querySelectorAll('a[href]').forEach(function(link) {
            link.addEventListener('click', function(e) {
                var href = this.getAttribute('href');
                if (!href || href.startsWith('#') || href.startsWith('javascript') || this.target === '_blank') return;
                NProgress.start();
            });
        });
        window.addEventListener('pageshow', function() {
            NProgress.done();
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
