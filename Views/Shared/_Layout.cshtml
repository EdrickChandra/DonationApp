<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>IDonasi</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=DM+Sans:wght@400;500&amp;display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/global.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/item.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/profile-mobile-append.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/nprogress/0.2.0/nprogress.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@@latest/tabler-icons.min.css" />
    <script src="~/js/location-data.js" asp-append-version="true"></script>
</head>
<body>
    <nav>
        <a class="logo" asp-controller="Home" asp-action="Index">IDonasi</a>

        @if (ViewData["HideSearch"] == null)
        {
            <form action="/Search" method="get" style="flex:1;display:flex;" id="searchForm">
                <input class="search-bar" type="text" name="q" placeholder="Search..."
                       value="@(ViewContext.HttpContext.Request.Query["q"].ToString())"
                       autocomplete="off" />
                <input type="hidden" name="tab" id="searchTabHidden" value="donasi" />
            </form>
        }
        
        <div class="nav-links-desktop" style="margin-left:12px;">
            <a class="nav-page-link" asp-controller="Home" asp-action="Index">Donasi</a>
            <a class="nav-page-link" asp-controller="Request" asp-action="Index">Request</a>
        </div>

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <div style="display:flex;align-items:center;gap:8px;margin-left:auto;">
                
                <a href="/Profile/Notifikasi" class="nav-bell" title="Notifikasi">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                    </svg>
                    @{
                        var unread = ViewBag.UnreadCount as int? ?? 0;
                    }
                    @if (unread > 0)
                    {
                        <span class="nav-bell-badge">@unread</span>
                    }
                </a>

                <div class="nav-dropdown" id="navDropdown">
                    <div class="nav-user" onclick="toggleDropdown()" style="cursor:pointer;">
                        <div class="avatar">@(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "?")</div>
                        <span class="nav-username">@(User.Identity?.Name ?? "")</span>
                        <span style="font-size:10px;">▼</span>
                    </div>

                    <div class="dropdown-menu" id="dropdownMenu">
                        <a class="dropdown-item" asp-controller="Profile" asp-action="Edit">Profil</a>
                        @{
                            var navUser = ViewBag.NavUser as DonationApp.Models.ApplicationUser;
                        }
                        @if (navUser != null && navUser.IsAdmin)
                        {
                            <a class="dropdown-item" asp-controller="Admin" asp-action="Reports">Panel Admin</a>
                        }
                        <a class="dropdown-item" asp-controller="Donasi" asp-action="Index">Donasi Saya</a>
                        <a class="dropdown-item" asp-controller="Request" asp-action="MyRequests">Request Saya</a>
                        <a class="dropdown-item" asp-controller="Pesan" asp-action="Index">Pesan</a>
                        <div class="dropdown-divider"></div>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item dropdown-item-danger">Keluar</button>
                        </form>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div style="margin-left:auto;display:flex;gap:8px;">
                <a class="nav-login-btn" asp-controller="Account" asp-action="Login">Masuk</a>
                <a class="nav-btn nav-donasi-btn" asp-controller="Account" asp-action="Register">Daftar</a>
            </div>
        }
    </nav>

    <main id="main-content">
        @RenderBody()
    </main>

    <footer>
        <span class="footer-copyright">©IDonasi, 2026. ALL RIGHTS RESERVED</span>
    </footer>

    <script>
        document.querySelectorAll('.condition-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                this.closest('.condition-group').querySelectorAll('.condition-btn').forEach(b => b.classList.remove('selected'));
                this.classList.add('selected');
                const input = document.getElementById('kondisiInput');
                if (input) input.value = this.dataset.value;
            });
        });

        function toggleDropdown() {
            document.getElementById('dropdownMenu').classList.toggle('open');
        }

        document.addEventListener('click', function(e) {
            var dropdown = document.getElementById('navDropdown');
            if (dropdown && !dropdown.contains(e.target)) {
                document.getElementById('dropdownMenu').classList.remove('open');
            }
        });

        (function() {
            var path = window.location.pathname.toLowerCase();
            var tab = 'donasi';
            if (path.startsWith('/request')) tab = 'request';
            var hidden = document.getElementById('searchTabHidden');
            if (hidden) hidden.value = tab;
        })();
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/nprogress/0.2.0/nprogress.min.js"></script>
    <script>
        NProgress.configure({ showSpinner: false, speed: 300 });
        document.querySelectorAll('a[href]').forEach(function(link) {
            link.addEventListener('click', function(e) {
                var href = this.getAttribute('href');
                if (!href || href.startsWith('#') || href.startsWith('javascript') || this.target === '_blank') return;
                NProgress.start();
            });
        });
        window.addEventListener('pageshow', function() {
            NProgress.done();
        });
    </script>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div id="reportModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.5);align-items:center;justify-content:center;">
            <div style="background:#fff;border-radius:12px;padding:24px;max-width:420px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.3);">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
                    <h3 style="margin:0;font-size:16px;font-weight:600;color:#0f172a;font-family:'Plus Jakarta Sans',sans-serif;">Laporkan Konten</h3>
                    <button type="button" onclick="closeReportModal()" style="background:none;border:none;font-size:18px;cursor:pointer;color:#94a3b8;padding:4px;">✕</button>
                </div>
                <form id="reportForm" onsubmit="return submitReport(event)">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="reportDonationId" name="donationId" />
                    <input type="hidden" id="reportRequestId" name="requestId" />
                    <div style="margin-bottom:14px;">
                        <label style="display:block;font-size:13px;font-weight:500;color:#334155;margin-bottom:6px;font-family:'Plus Jakarta Sans',sans-serif;">Alasan Laporan</label>
                        <select id="reportAlasan" name="alasan" required style="width:100%;padding:10px 12px;border:1px solid #cbd5e1;border-radius:8px;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif;background:#fff;">
                            <option value="">Pilih alasan...</option>
                            <option value="0">Spam</option>
                            <option value="1">Item Palsu</option>
                            <option value="2">Konten Tidak Pantas</option>
                            <option value="3">Penipuan</option>
                            <option value="4">Lainnya</option>
                        </select>
                    </div>
                    <div style="margin-bottom:16px;">
                        <label style="display:block;font-size:13px;font-weight:500;color:#334155;margin-bottom:6px;font-family:'Plus Jakarta Sans',sans-serif;">Deskripsi Tambahan <span style="color:#94a3b8;font-weight:400;">(opsional)</span></label>
                        <textarea id="reportDeskripsi" name="deskripsi" rows="3" placeholder="Jelaskan masalah yang Anda temukan..." style="width:100%;padding:10px 12px;border:1px solid #cbd5e1;border-radius:8px;font-size:13px;font-family:'Plus Jakarta Sans',sans-serif;resize:vertical;box-sizing:border-box;"></textarea>
                    </div>
                    <div style="display:flex;gap:8px;justify-content:flex-end;">
                        <button type="button" onclick="closeReportModal()" style="padding:8px 16px;border:1px solid #cbd5e1;border-radius:8px;background:#fff;font-size:13px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;color:#334155;">Batal</button>
                        <button type="submit" id="reportSubmitBtn" style="padding:8px 16px;border:none;border-radius:8px;background:#ef4444;color:#fff;font-size:13px;cursor:pointer;font-family:'Plus Jakarta Sans',sans-serif;font-weight:600;">Kirim Laporan</button>
                    </div>
                </form>
            </div>
        </div>

        <script>
            function openReportModal(donationId, requestId) {
                document.getElementById('reportDonationId').value = donationId || '';
                document.getElementById('reportRequestId').value = requestId || '';
                document.getElementById('reportAlasan').value = '';
                document.getElementById('reportDeskripsi').value = '';
                document.getElementById('reportModal').style.display = 'flex';
            }
            function closeReportModal() {
                document.getElementById('reportModal').style.display = 'none';
            }
            document.getElementById('reportModal').addEventListener('click', function(e) {
                if (e.target === this) closeReportModal();
            });
            function submitReport(e) {
                e.preventDefault();
                var form = document.getElementById('reportForm');
                var btn = document.getElementById('reportSubmitBtn');
                if (!document.getElementById('reportAlasan').value) return false;
                btn.disabled = true;
                btn.textContent = 'Mengirim...';
                var formData = new FormData(form);
                fetch('/Report/Submit', { method: 'POST', body: formData })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    btn.disabled = false;
                    btn.textContent = 'Kirim Laporan';
                    if (data.success) {
                        closeReportModal();
                        alert('Laporan berhasil dikirim. Terima kasih atas laporan Anda.');
                    } else {
                        alert(data.error || 'Gagal mengirim laporan.');
                    }
                })
                .catch(function() {
                    btn.disabled = false;
                    btn.textContent = 'Kirim Laporan';
                    alert('Terjadi kesalahan. Coba lagi.');
                });
                return false;
            }
            function reportItem(id) { openReportModal(id, null); }
            function reportRequest(id) { openReportModal(null, id); }
        </script>
    }

    @RenderSection("Scripts", required: false)
</body>
</html>
