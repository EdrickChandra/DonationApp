<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>IDonasi</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --navy: #0f1f3d;
            --navy-light: #1a2f52;
            --blue: #2563eb;
            --blue-hover: #1d4ed8;
            --blue-light: #3b82f6;
            --page-bg: #b8bdc7;
            --card-bg: #c8cdd6;
            --text-dark: #0f172a;
            --text-mid: #334155;
            --text-light: #64748b;
            --white: #ffffff;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--page-bg);
            color: var(--text-dark);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        nav {
            background: var(--navy);
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 12px 32px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 20px;
            font-weight: 800;
            color: var(--white);
            letter-spacing: -0.5px;
            white-space: nowrap;
            text-decoration: none;
        }

        .search-bar {
            flex: 1;
            background: #e2e8f0;
            border: none;
            border-radius: 6px;
            padding: 8px 14px;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            color: var(--text-mid);
            outline: none;
        }

        .search-bar::placeholder { color: #94a3b8; }

        .nav-donasi-btn {
            background: var(--blue);
            color: var(--white);
            border: none;
            border-radius: 6px;
            padding: 8px 16px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
            text-decoration: none;
            transition: background 0.2s;
        }

        .nav-donasi-btn:hover { background: var(--blue-hover); }

        .nav-user {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--white);
            font-size: 13px;
            font-weight: 500;
            white-space: nowrap;
        }

        .avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--blue-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 700;
            font-size: 13px;
            color: white;
        }

        main {
            flex: 1;
            padding: 24px 32px;
        }

        footer {
            background: var(--navy);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .footer-copyright {
            font-size: 11px;
            color: #94a3b8;
            text-align: center;
        }

        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            color: var(--text-mid);
            font-weight: 500;
            text-decoration: none;
            margin-bottom: 16px;
        }

        .back-btn:hover { color: var(--blue); }

        .pill {
            padding: 5px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            font-family: 'Plus Jakarta Sans', sans-serif;
            cursor: pointer;
            border: none;
            text-decoration: none;
            display: inline-block;
            transition: opacity 0.15s;
        }

        .pill.active { background: var(--blue); color: white; }
        .pill.inactive { background: #94a3b8; color: white; }
        .pill:hover { opacity: 0.85; }

        .card-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 14px;
        }

        .item-card {
            background: var(--card-bg);
            border-radius: 10px;
            overflow: hidden;
            cursor: pointer;
            transition: transform 0.15s, box-shadow 0.15s;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            text-decoration: none;
        }

        .item-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.15); }

        .card-image {
            background: #9ca3af;
            height: 110px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card-info {
            background: var(--blue);
            padding: 8px 10px;
        }

        .card-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .card-name {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 12px;
            font-weight: 700;
            color: white;
        }

        .card-lokasi {
            font-size: 11px;
            color: #bfdbfe;
            font-weight: 500;
        }

        .card-timer {
            font-size: 11px;
            color: #bfdbfe;
            margin-top: 2px;
        }

        .section-title {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-mid);
            margin-bottom: 14px;
        }

        .category-label {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 12px;
            font-weight: 700;
            color: var(--text-mid);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .pills {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .add-btn {
            width: 44px;
            height: 44px;
            background: #e2e8f0;
            border: 2px solid #cbd5e1;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 22px;
            color: var(--text-mid);
            margin-bottom: 20px;
            text-decoration: none;
            transition: all 0.15s;
        }

        .add-btn:hover { background: var(--blue); color: white; border-color: var(--blue); }

        .divider {
            height: 1px;
            background: #cbd5e1;
            margin-bottom: 20px;
        }

        .form-card {
            background: #ffffff;
            border-radius: 12px;
            padding: 24px 28px;
            width: 50%;
            min-width: 360px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.1);
        }

        .form-title {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 15px;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--blue);
            display: inline-block;
        }

        .form-group {
            margin-bottom: 16px;
        }

        .form-label {
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-mid);
            margin-bottom: 6px;
            display: block;
        }

        .form-input {
            width: 100%;
            background: #f1f5f9;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            padding: 9px 12px;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            color: var(--text-dark);
            outline: none;
            transition: border-color 0.15s;
        }

        .form-input:focus { border-color: var(--blue); }

        select.form-input { cursor: pointer; }

        .condition-group {
            display: flex;
            gap: 8px;
        }

        .condition-btn {
            flex: 1;
            padding: 8px;
            border-radius: 6px;
            border: 1.5px solid #cbd5e1;
            background: #f1f5f9;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-mid);
            cursor: pointer;
            transition: all 0.15s;
            text-align: center;
        }

        .condition-btn.selected {
            background: var(--navy);
            color: white;
            border-color: var(--navy);
        }

        .condition-btn:hover:not(.selected) { border-color: var(--blue); color: var(--blue); }

        .submit-btn {
            width: 100%;
            background: var(--blue);
            color: white;
            border: none;
            border-radius: 8px;
            padding: 12px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 8px;
            transition: background 0.2s;
            letter-spacing: 0.02em;
        }

        .submit-btn:hover { background: var(--blue-hover); }

        textarea.form-input {
            resize: vertical;
            min-height: 72px;
        }

        .validation-message {
            font-size: 11px;
            color: #ef4444;
            margin-top: 4px;
            display: block;
        }

            .modal-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,0.5);
                z-index: 200;
                align-items: center;
                justify-content: center;
            }

                .modal-overlay.open {
                    display: flex;
                }

            .modal-box {
                background: #d1d5db;
                border-radius: 12px;
                padding: 24px;
                width: 520px;
                max-width: 90vw;
                position: relative;
            }

            .modal-close {
                position: absolute;
                top: 12px;
                right: 16px;
                background: none;
                border: none;
                font-size: 18px;
                cursor: pointer;
                color: var(--text-mid);
            }

            .modal-top {
                display: flex;
                gap: 20px;
                margin-bottom: 16px;
            }

            .modal-image {
                background: #9ca3af;
                border-radius: 8px;
                width: 160px;
                min-width: 160px;
                height: 140px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .modal-info {
                display: flex;
                flex-direction: column;
                gap: 8px;
                flex: 1;
            }

            .modal-info-row {
                background: #e2e8f0;
                border-radius: 6px;
                padding: 7px 12px;
                font-size: 13px;
                font-family: 'Plus Jakarta Sans', sans-serif;
                font-weight: 600;
                color: var(--text-dark);
            }

            .modal-deskripsi {
                font-size: 12px;
                color: var(--text-mid);
                margin-bottom: 16px;
                line-height: 1.6;
            }

            .modal-footer {
                display: flex;
                justify-content: flex-end;
            }

            .modal-btn {
                background: var(--blue);
                color: white;
                border: none;
                border-radius: 8px;
                padding: 10px 28px;
                font-family: 'Plus Jakarta Sans', sans-serif;
                font-size: 13px;
                font-weight: 700;
                cursor: pointer;
                transition: background 0.2s;
            }

                .modal-btn:hover {
                    background: var(--blue-hover);
                }

            .requester-list {
                display: flex;
                flex-direction: column;
                gap: 8px;
                flex: 1;
                max-height: 180px;
                overflow-y: auto;
            }

            .requester-item {
                display: flex;
                align-items: center;
                gap: 10px;
                background: #e2e8f0;
                border-radius: 6px;
                padding: 8px 12px;
            }

            .requester-avatar {
                width: 28px;
                height: 28px;
                border-radius: 50%;
                background: var(--blue-light);
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: 'Plus Jakarta Sans', sans-serif;
                font-weight: 700;
                font-size: 12px;
                color: white;
                min-width: 28px;
            }

            .requester-name {
                font-size: 13px;
                font-family: 'Plus Jakarta Sans', sans-serif;
                font-weight: 600;
                color: var(--text-dark);
                flex: 1;
            }
            .nav-login-btn {
                background: transparent;
                color: white;
                border: 1.5px solid rgba(255,255,255,0.3);
                border-radius: 6px;
                padding: 8px 16px;
                font-family: 'Plus Jakarta Sans', sans-serif;
                font-size: 13px;
                font-weight: 600;
                cursor: pointer;
                text-decoration: none;
                white-space: nowrap;
            }

            .logout-btn {
                background: transparent;
                color: #94a3b8;
                border: none;
                font-size: 12px;
                cursor: pointer;
                padding: 4px 8px;
                border-radius: 4px;
                font-family: 'DM Sans', sans-serif;
            }

                .logout-btn:hover {
                    color: white;
                }

            .auth-card {
                background: #ffffff;
                border-radius: 12px;
                padding: 32px 28px;
                width: 100%;
                max-width: 420px;
                box-shadow: 0 2px 12px rgba(0,0,0,0.1);
            }

            .auth-title {
                font-family: 'Plus Jakarta Sans', sans-serif;
                font-size: 20px;
                font-weight: 800;
                color: var(--text-dark);
                margin-bottom: 4px;
            }

            .auth-subtitle {
                font-size: 13px;
                color: #64748b;
                margin-bottom: 24px;
            }

                .auth-subtitle a {
                    color: var(--blue);
                    font-weight: 600;
                    text-decoration: none;
                }

            .input-row {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 12px;
            }
    </style>
</head>
<body>
    <nav>
        <a class="logo" asp-controller="Home" asp-action="Index">IDonasi</a>

        @if (ViewData["HideSearch"] == null)
        {
            <input class="search-bar" type="text" placeholder="Search...">
        }

        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <a class="nav-donasi-btn" asp-controller="Item" asp-action="MyDonations">🎁 Donasi</a>
            <div class="nav-user">
                @{
                    var userName = User.Identity?.Name ?? "";
                    var avatarLetter = userName.Length > 0 ? userName[0].ToString().ToUpper() : "?";
                }
                @avatarLetter
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-btn">Keluar</button>
                </form>
            </div>
        }
        else
        {
            <div style="margin-left:auto; display:flex; gap:8px;">
                <a class="nav-login-btn" asp-controller="Account" asp-action="Login">Masuk</a>
                <a class="nav-btn nav-donasi-btn" asp-controller="Account" asp-action="Register">Daftar</a>
            </div>
        }
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer>
        <span class="footer-copyright">©IDonasi, 2025. ALL RIGHTS RESERVED</span>
    </footer>

    <script>
        document.querySelectorAll('.condition-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                this.closest('.condition-group').querySelectorAll('.condition-btn').forEach(b => b.classList.remove('selected'));
                this.classList.add('selected');
                const input = document.getElementById('kondisiInput');
                if (input) input.value = this.dataset.value;
            });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
