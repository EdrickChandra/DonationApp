@model DonationApp.Models.ItemRequest
@using DonationApp.Models
@using System.Text.Json
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var images = Model.Images.ToList();
    var daysLeft = (Model.ExpiresAt - DateTime.UtcNow).Days;
    var isOwner = (bool)ViewBag.IsOwner;
    var hasOffered = (bool)ViewBag.HasOffered;
    var avatarLetter = Model.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
    var posterName = Model.User != null ? Model.User.NamaDepan + " " + Model.User.NamaBelakang : "Unknown";
    var avgRating = ViewBag.AverageRating != null ? (double)ViewBag.AverageRating : 0.0;
    var totalReviews = ViewBag.TotalReviews != null ? (int)ViewBag.TotalReviews : 0;

    Dictionary<string, string>? detailTambahan = null;
    if (!string.IsNullOrWhiteSpace(Model.DetailTambahan))
    {
        try { detailTambahan = JsonSerializer.Deserialize<Dictionary<string, string>>(Model.DetailTambahan); } catch { }
    }
}

<div class="dpage">
    <a class="back-btn" asp-controller="Request" asp-action="Index">
        <i class="ti ti-arrow-left" aria-hidden="true"></i> Kembali
    </a>

    <div class="dpage-grid">

        <div class="dpage-left">
            @if (images.Any())
            {
                <div class="dpage-img-wrap">
                    <img id="mainImage" src="@images[0].FilePath" class="dpage-main-img" onclick="openZoom()" />
                    @if (images.Count > 1)
                    {
                        <button onclick="slideImage(-1)" class="btn-slide left">‹</button>
                        <button onclick="slideImage(1)" class="btn-slide right">›</button>
                        <span id="imageCounter" class="detail-counter">1 / @images.Count</span>
                    }
                </div>
                @if (images.Count > 1)
                {
                    <div class="detail-thumbs">
                        @for (int i = 0; i < images.Count; i++)
                        {
                            <div onclick="setImage(@i)" class="detail-thumb @(i == 0 ? "active" : "")" id="thumb-@i">
                                <img src="@images[i].FilePath" />
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="dpage-img-wrap dpage-img-wrap--empty">
                    <i class="ti ti-list-search dempty-icon" aria-hidden="true"></i>
                </div>
            }
        </div>

        <div class="dpage-right">

            <div class="dcard">
                <div class="dhead-row">
                    <div>
                        <div class="detail-badges mb-8">
                            <span class="badge badge-lg badge-sky">Request</span>
                            <span class="badge badge-lg badge-blue">@CategoryHelper.DisplayName(Model.Kategori)</span>
                        </div>
                        <h1 class="dpage-title">@Model.Title</h1>
                    </div>
                </div>

                <a href="/Profile/View/@Model.UserId" class="duser-row link-plain">
                    <div class="avatar">@avatarLetter</div>
                    <div class="flex-min">
                        <div class="detail-poster-name">@posterName</div>
                        <div class="drating-row">
                            @if (totalReviews > 0)
                            {
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <span style="color:@(s <= Math.Round(avgRating) ? "#EF9F27" : "#cbd5e1");font-size:13px;">★</span>
                                }
                                <span class="text-xs-muted">@avgRating.ToString("0.0") · @totalReviews ulasan</span>
                            }
                            else
                            {
                                <span class="text-xs-dim">Belum ada ulasan</span>
                            }
                        </div>
                    </div>
                    <div class="dloc-row">
                        <i class="ti ti-map-pin icon-14" aria-hidden="true"></i>
                        @Model.Lokasi@(!string.IsNullOrWhiteSpace(Model.Provinsi) ? ", " + Model.Provinsi : "")
                    </div>
                </a>
            </div>

            <div class="dcard">
                <div class="dinfo-grid">
                    <div class="dinfo-cell dinfo-cell--border">
                        <div class="detail-row-label">Kondisi Minimum</div>
                        <div class="detail-row-value mt-4">@(Model.KondisiMinimum?.ToString() ?? "Apa saja")</div>
                    </div>
                    <div class="dinfo-cell">
                        <div class="detail-row-label">Jumlah Dibutuhkan</div>
                        <div class="detail-row-value mt-4">@Model.Jumlah pcs</div>
                    </div>
                </div>
            </div>

            <div class="dcard">
                <div class="detail-row-label mb-6">Deskripsi</div>
                <div class="detail-row-value">@Model.Deskripsi</div>
            </div>

            @if (detailTambahan != null && detailTambahan.Any())
            {
                <div class="dcard">
                    <div class="detail-row-label mb-8">Detail Tambahan</div>
                    <div class="ddetail-tambahan-list">
                        @foreach (var kv in detailTambahan)
                        {
                            <div class="ddetail-tambahan-row">
                                <span class="ddetail-key">@kv.Key</span>
                                <span class="ddetail-val">@kv.Value</span>
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="dcard">
                <div class="dflex-between mb-12">
                    <span class="text-muted">@Model.Offers.Count penawaran masuk</span>
                </div>

                @if (!User.Identity!.IsAuthenticated)
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg btn-block">Masuk untuk Menawarkan</a>
                }
                else if (isOwner)
                {
                    <button class="btn btn-ghost btn-lg btn-block" disabled>Request Anda</button>
                }
                else if (Model.Status != ItemRequestStatus.Open)
                {
                    <button class="btn btn-ghost btn-lg btn-block" disabled>Request Sudah Ditutup</button>
                }
                else if (hasOffered)
                {
                    <button class="btn btn-ghost btn-lg btn-block" disabled>Sudah Ditawarkan</button>
                }
                else
                {
                    <button class="btn btn-primary btn-lg btn-block" onclick="toggleOfferForm()">
                        <i class="ti ti-package" aria-hidden="true"></i> Tawarkan Barang
                    </button>
                }

                <div class="daction-bar">
                    <div class="detail-timer">
                        <i class="ti ti-clock" aria-hidden="true"></i>
                        Sisa @daysLeft hari
                    </div>
                    <div class="dbtn-group">
                        <button class="btn btn-ghost btn-sm" onclick="reportDetail()">
                            <i class="ti ti-flag icon-danger" aria-hidden="true"></i> Lapor
                        </button>
                        <button class="btn btn-ghost btn-sm" onclick="copyDetailLink()">
                            <i class="ti ti-copy" aria-hidden="true"></i> Salin Link
                        </button>
                    </div>
                </div>
            </div>

            @* Offer form — no provinsi/kota fields, auto-filled from user *@
            @if (User.Identity!.IsAuthenticated && !isOwner && !hasOffered && Model.Status == ItemRequestStatus.Open)
            {
                <div id="offerForm" style="display:none;">
                    <div class="dcard">
                        <div class="detail-row-label mb-12">Tawarkan Barang</div>
                        <form asp-controller="Request" asp-action="Offer" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="itemRequestId" value="@Model.Id" />

                            <div class="form-group">
                                <label class="form-label">Nama Barang</label>
                                <input class="form-input" name="namaBarang" placeholder="Nama barang yang ditawarkan..." required />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Kondisi</label>
                                <div class="dcondition-row">
                                    <input type="hidden" name="kondisi" id="offerKondisiInput" value="1" />
                                    <button type="button" class="btn-condition" id="offerKondisiBaru" data-value="0" onclick="setOfferKondisi(0)">Baru</button>
                                    <button type="button" class="btn-condition selected" id="offerKondisiBekas" data-value="1" onclick="setOfferKondisi(1)">Bekas</button>
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Jumlah yang bisa ditawarkan</label>
                                <div class="dstepper-row">
                                    <button type="button" class="stepper-btn" onclick="offerStepDown()">−</button>
                                    <span id="offerStepperDisplay" class="dstepper-display">1</span>
                                    <button type="button" class="stepper-btn" onclick="offerStepUp(@Model.Jumlah)">+</button>
                                    <span class="text-xs-dim">maks. @Model.Jumlah pcs</span>
                                </div>
                                <input type="hidden" name="jumlah" id="offerStepperInput" value="1" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Deskripsi Penawaran</label>
                                <textarea class="form-input" name="deskripsi" rows="3" placeholder="Jelaskan kondisi barang yang Anda tawarkan..." required></textarea>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Foto Barang <span class="label-hint">(maks. 3, 5MB, JPG/PNG)</span></label>
                                <input type="file" id="offer-file-input" name="Images" multiple accept=".jpg,.jpeg,.png" style="display:none;" />
                                <div class="upload-zone" onclick="document.getElementById('offer-file-input').click()">
                                    <i class="ti ti-photo-plus" aria-hidden="true"></i> Tambah Foto
                                </div>
                                <div id="offer-preview" class="dupload-preview"></div>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg btn-block btn-sky">Kirim Penawaran</button>
                        </form>
                    </div>
                </div>
            }

        </div>
    </div>
</div>

<div class="modal-overlay" id="zoomModal">
    <div class="zoom-modal-inner">
        <button onclick="closeZoom()" class="zoom-close-btn">✕</button>
        <img id="zoomImage" src="" class="zoom-img" />
    </div>
</div>

@section Scripts {
    <style>
        .stepper-btn {
            width: 34px; height: 34px; border-radius: 8px;
            border: 1.5px solid #cbd5e1; background: #f1f5f9;
            font-size: 18px; font-weight: 700; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: background 0.15s, border-color 0.15s; color: #0f172a;
        }
        .stepper-btn:hover { background: #e2e8f0; border-color: #94a3b8; }
    </style>
    <script src="~/js/image-gallery.js" asp-append-version="true"></script>
    <script src="~/js/form-helpers.js" asp-append-version="true"></script>
    <script>
        var images = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(images.Select(i => i.FilePath).ToList()));
        initImageGallery(images);
        var offerStepperVal = 1;

        function toggleOfferForm() {
            var form = document.getElementById('offerForm');
            if (form) form.style.display = form.style.display === 'none' ? 'block' : 'none';
        }

        function setOfferKondisi(val) {
            document.getElementById('offerKondisiInput').value = val;
            document.getElementById('offerKondisiBaru').classList.toggle('selected', val === 0);
            document.getElementById('offerKondisiBekas').classList.toggle('selected', val === 1);
        }

        function offerStepDown() {
            if (offerStepperVal > 1) {
                offerStepperVal--;
                document.getElementById('offerStepperDisplay').textContent = offerStepperVal;
                document.getElementById('offerStepperInput').value = offerStepperVal;
            }
        }
        function offerStepUp(max) {
            if (offerStepperVal < max) {
                offerStepperVal++;
                document.getElementById('offerStepperDisplay').textContent = offerStepperVal;
                document.getElementById('offerStepperInput').value = offerStepperVal;
            }
        }

        function copyDetailLink() { navigator.clipboard.writeText(window.location.href); }
        function reportDetail() { openReportModal(null, @Model.Id); }

        initImageUploader({
            inputId: 'offer-file-input',
            previewId: 'offer-preview',
            max: 3,
            variant: 'compact'
        });
    </script>
}
