@model IEnumerable<DonationApp.Models.ItemRequest>
@using DonationApp.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var selected = ViewBag.SelectedKategori != null ? (ItemCategory)ViewBag.SelectedKategori : ItemCategory.Semua;
}

<link rel="stylesheet" href="~/css/item.css" asp-append-version="true" />

<div class="category-label">Kategori</div>
<div class="pills">
    @foreach (var cat in CategoryHelper.AllCategories())
    {
        <a class="pill @(selected == cat ? "active" : "inactive")"
           asp-controller="Request" asp-action="Index" asp-route-kategori="@cat">@CategoryHelper.DisplayName(cat)</a>
    }
</div>

<div class="section-title">Permintaan Barang :</div>

<div class="card-grid">
    @foreach (var req in Model)
    {
        var daysLeft = (req.ExpiresAt - DateTime.UtcNow).Days;
        var firstImage = req.Images.FirstOrDefault();
        var avatarLetter = req.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
        <a class="item-card" asp-controller="Request" asp-action="Detail" asp-route-id="@req.Id">
            <div class="card-image">
                @if (firstImage != null)
                {
                    <img src="@firstImage.FilePath" class="card-image-fill" />
                }
                else
                {
                    <div class="card-image-empty">
                        <span class="card-image-empty-icon">?</span>
                    </div>
                }
                <span class="card-badge-request">Request</span>
            </div>
            <div class="card-info">
                <div class="card-row">
                    <span class="card-name">@req.Title</span>
                    <span class="card-lokasi">@CategoryHelper.DisplayName(req.Kategori)</span>
                </div>
                <div class="card-poster-row">
                    <div class="card-poster-avatar">@avatarLetter</div>
                    <span class="card-poster-name">@req.User?.NamaDepan @req.User?.NamaBelakang</span>
                </div>
                <div class="card-timer">@daysLeft hari lagi · @req.Offers.Count penawaran</div>
            </div>
        </a>
    }
    @if (!Model.Any())
    {
        <p class="card-grid-empty">Belum ada permintaan barang.</p>
    }
</div>
