@model IEnumerable<DonationApp.Models.ItemRequest>
@using DonationApp.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var selected = ViewBag.SelectedKategori != null ? (ItemCategory)ViewBag.SelectedKategori : ItemCategory.Semua;
}

<div class="page-header">
    <div class="page-header-inner">
        <div class="pills">
            @foreach (var cat in CategoryHelper.AllCategories())
            {
                var icon = cat switch {
                    ItemCategory.Semua => "ti-layout-grid",
                    ItemCategory.Pakaian => "ti-shirt",
                    ItemCategory.Elektronik => "ti-device-laptop",
                    ItemCategory.Buku => "ti-book",
                    ItemCategory.PerabotRumah => "ti-sofa",
                    ItemCategory.MainanHobi => "ti-fidget-spinner",
                    ItemCategory.AlatTulis => "ti-pencil",
                    ItemCategory.AlatMusik => "ti-guitar-pick",
                    ItemCategory.PeralatanDapur => "ti-tools-kitchen-2",
                    _ => "ti-tag"
                };
                <a class="pill @(selected == cat ? "active" : "")"
                   asp-controller="Request" asp-action="Index" asp-route-kategori="@cat">
                    <i class="ti @icon" aria-hidden="true"></i>
                    @CategoryHelper.DisplayName(cat)
                </a>
            }
        </div>
    </div>
</div>

<div class="feed-wrap">
    <div class="feed-tabs">
        <a class="feed-tab" asp-controller="Home" asp-action="Index">Donasi</a>
        <a class="feed-tab active" asp-controller="Request" asp-action="Index">Request</a>
    </div>

    <div class="feed-header">
        <span class="feed-title">Permintaan Barang</span>
        <span class="feed-count">@Model.Count() request</span>
    </div>

    <div class="card-grid">
        @foreach (var req in Model)
        {
            var daysLeft = (req.ExpiresAt - DateTime.UtcNow).Days;
            var firstImage = req.Images.FirstOrDefault();
            var avatarLetter = req.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
            var posterName = req.User?.NamaDepan ?? "Unknown";
            <a class="item-card" asp-controller="Request" asp-action="Detail" asp-route-id="@req.Id">
                <div class="card-img">
                    @if (firstImage != null)
                    {
                        <img src="@firstImage.FilePath" class="card-img-fill" />
                    }
                    else
                    {
                        <div class="card-img-empty">
                            <i class="ti ti-list-search" aria-hidden="true"></i>
                        </div>
                    }
                    <span class="card-request-badge">Request</span>
                    <span class="card-timer-badge">
                        <i class="ti ti-clock" aria-hidden="true"></i>
                        @daysLeft hari
                    </span>
                </div>
                <div class="card-body">
                    <div class="card-name">@req.Title</div>
                    <div class="card-meta">
                        <span class="card-cat">@CategoryHelper.DisplayName(req.Kategori)</span>
                        @if (req.Offers.Any())
                        {
                            <span class="card-dot">·</span>
                            <span class="card-offers">@req.Offers.Count penawaran</span>
                        }
                    </div>
                </div>
                <div class="card-footer">
                    <div class="card-poster">
                        <div class="card-poster-av">@avatarLetter</div>
                        <span class="card-poster-name">@posterName</span>
                    </div>
                    <span class="card-cta">Lihat →</span>
                </div>
            </a>
        }
        @if (!Model.Any())
        {
            <p class="card-grid-empty">Belum ada permintaan barang.</p>
        }
    </div>
</div>
