@model IEnumerable<DonationApp.Models.Report>
@using DonationApp.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var selectedStatus = ViewBag.SelectedStatus as ReportStatus?;
}

<div class="admin-page">

    <div class="admin-header-row">
        <div>
            <h1 class="admin-page-title">Panel Admin</h1>
            <p class="admin-page-subtitle">Kelola laporan pengguna</p>
        </div>
        <div style="display:flex;align-items:center;gap:8px;">
            <a href="/Admin/ManageUsers" class="admin-filter-btn"><i class="ti ti-users" aria-hidden="true"></i> Kelola Pengguna</a>
            <span class="text-sm-muted">@Model.Count() laporan</span>
        </div>
    </div>

    <div class="admin-filter-row">
        <a href="/Admin/Reports" class="admin-filter-btn @(selectedStatus == null ? "active" : "")">Semua</a>
        <a href="/Admin/Reports?status=0" class="admin-filter-btn @(selectedStatus == ReportStatus.Open ? "active" : "")">
            <span class="admin-status-dot" style="background:#ef4444;"></span> Open
        </a>
        <a href="/Admin/Reports?status=1" class="admin-filter-btn @(selectedStatus == ReportStatus.Reviewing ? "active" : "")">
            <span class="admin-status-dot" style="background:#f59e0b;"></span> Reviewing
        </a>
        <a href="/Admin/Reports?status=2" class="admin-filter-btn @(selectedStatus == ReportStatus.Resolved ? "active" : "")">
            <span class="admin-status-dot" style="background:#22c55e;"></span> Resolved
        </a>
        <a href="/Admin/Reports?status=3" class="admin-filter-btn @(selectedStatus == ReportStatus.Dismissed ? "active" : "")">
            <span class="admin-status-dot" style="background:#94a3b8;"></span> Dismissed
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="admin-empty-card">
            <i class="ti ti-flag-off empty-icon" aria-hidden="true"></i>
            <p class="text-muted">Tidak ada laporan.</p>
        </div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Pelapor</th>
                        <th>Target</th>
                        <th>Alasan</th>
                        <th>Status</th>
                        <th>Tanggal</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        var statusLabel = r.Status switch {
                            ReportStatus.Open => "Open",
                            ReportStatus.Reviewing => "Reviewing",
                            ReportStatus.Resolved => "Resolved",
                            ReportStatus.Dismissed => "Dismissed",
                            _ => "-"
                        };
                        var statusColor = r.Status switch {
                            ReportStatus.Open => "#ef4444",
                            ReportStatus.Reviewing => "#f59e0b",
                            ReportStatus.Resolved => "#22c55e",
                            ReportStatus.Dismissed => "#94a3b8",
                            _ => "#94a3b8"
                        };
                        var statusBg = r.Status switch {
                            ReportStatus.Open => "#fee2e2",
                            ReportStatus.Reviewing => "#fef9c3",
                            ReportStatus.Resolved => "#dcfce7",
                            ReportStatus.Dismissed => "#f1f5f9",
                            _ => "#f1f5f9"
                        };
                        var targetName = r.TargetUser != null
                            ? r.TargetUser.NamaDepan + " " + r.TargetUser.NamaBelakang
                            : r.TargetDonation != null ? r.TargetDonation.NamaBarang
                            : r.TargetRequest != null ? r.TargetRequest.Title
                            : "-";
                        <tr>
                            <td class="admin-cell-id">#@r.Id</td>
                            <td>
                                <div class="text-strong">@(r.Reporter?.NamaDepan + " " + r.Reporter?.NamaBelakang)</div>
                            </td>
                            <td>
                                <div class="admin-cell-target">@targetName</div>
                            </td>
                            <td>
                                <span class="text-sm-muted">@r.Alasan</span>
                            </td>
                            <td>
                                <span class="admin-status-pill" style="background:@statusBg;color:@statusColor;">
                                    @statusLabel
                                </span>
                            </td>
                            <td class="text-sm-muted">@r.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                <a href="/Admin/ReportDetail/@r.Id" class="admin-cell-link">Lihat →</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
