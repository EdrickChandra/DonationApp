@model IEnumerable<DonationApp.Models.Report>
@using DonationApp.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var selectedStatus = ViewBag.SelectedStatus as ReportStatus?;
}

<div style="max-width:1000px;margin:0 auto;padding:24px 0;">

    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
        <div>
            <h1 style="font-size:22px;font-weight:800;color:#0f172a;font-family:'Plus Jakarta Sans',sans-serif;margin:0 0 4px;">Panel Admin</h1>
            <p style="font-size:13px;color:#64748b;margin:0;">Kelola laporan pengguna</p>
        </div>
        <div style="display:flex;align-items:center;gap:8px;">
            <span class="text-sm-muted">@Model.Count() laporan</span>
        </div>
    </div>

    <div style="display:flex;gap:6px;margin-bottom:20px;flex-wrap:wrap;">
        <a href="/Admin/Reports" class="admin-filter-btn @(selectedStatus == null ? "active" : "")">Semua</a>
        <a href="/Admin/Reports?status=0" class="admin-filter-btn @(selectedStatus == ReportStatus.Open ? "active" : "")">
            <span class="admin-status-dot" style="background:#ef4444;"></span> Open
        </a>
        <a href="/Admin/Reports?status=1" class="admin-filter-btn @(selectedStatus == ReportStatus.Reviewing ? "active" : "")">
            <span class="admin-status-dot" style="background:#f59e0b;"></span> Reviewing
        </a>
        <a href="/Admin/Reports?status=2" class="admin-filter-btn @(selectedStatus == ReportStatus.Resolved ? "active" : "")">
            <span class="admin-status-dot" style="background:#22c55e;"></span> Resolved
        </a>
        <a href="/Admin/Reports?status=3" class="admin-filter-btn @(selectedStatus == ReportStatus.Dismissed ? "active" : "")">
            <span class="admin-status-dot" style="background:#94a3b8;"></span> Dismissed
        </a>
    </div>

    @if (!Model.Any())
    {
        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:48px;text-align:center;">
            <i class="ti ti-flag-off" class="empty-icon" aria-hidden="true"></i>
            <p class="text-muted">Tidak ada laporan.</p>
        </div>
    }
    else
    {
        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Pelapor</th>
                        <th>Target</th>
                        <th>Alasan</th>
                        <th>Status</th>
                        <th>Tanggal</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        var statusLabel = r.Status switch {
                            ReportStatus.Open => "Open",
                            ReportStatus.Reviewing => "Reviewing",
                            ReportStatus.Resolved => "Resolved",
                            ReportStatus.Dismissed => "Dismissed",
                            _ => "-"
                        };
                        var statusColor = r.Status switch {
                            ReportStatus.Open => "#ef4444",
                            ReportStatus.Reviewing => "#f59e0b",
                            ReportStatus.Resolved => "#22c55e",
                            ReportStatus.Dismissed => "#94a3b8",
                            _ => "#94a3b8"
                        };
                        var statusBg = r.Status switch {
                            ReportStatus.Open => "#fee2e2",
                            ReportStatus.Reviewing => "#fef9c3",
                            ReportStatus.Resolved => "#dcfce7",
                            ReportStatus.Dismissed => "#f1f5f9",
                            _ => "#f1f5f9"
                        };
                        var targetName = r.TargetUser != null
                            ? r.TargetUser.NamaDepan + " " + r.TargetUser.NamaBelakang
                            : r.TargetDonation != null ? r.TargetDonation.NamaBarang
                            : r.TargetRequest != null ? r.TargetRequest.Title
                            : "-";
                        <tr>
                            <td style="color:#94a3b8;font-size:12px;">#@r.Id</td>
                            <td>
                                <div class="text-strong">@(r.Reporter?.NamaDepan + " " + r.Reporter?.NamaBelakang)</div>
                            </td>
                            <td>
                                <div style="font-size:13px;color:#334155;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@targetName</div>
                            </td>
                            <td>
                                <span class="text-sm-muted">@r.Alasan</span>
                            </td>
                            <td>
                                <span style="font-size:11px;font-weight:600;padding:3px 10px;border-radius:99px;background:@statusBg;color:@statusColor;font-family:'Plus Jakarta Sans',sans-serif;">
                                    @statusLabel
                                </span>
                            </td>
                            <td class="text-sm-muted">@r.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                <a href="/Admin/ReportDetail/@r.Id" style="font-size:12px;color:#2563eb;font-weight:600;text-decoration:none;">Lihat →</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
.admin-filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    color: #334155;
    background: #fff;
    border: 1px solid #e2e8f0;
    text-decoration: none;
    transition: all 0.15s;
    font-family: 'Plus Jakarta Sans', sans-serif;
}
.admin-filter-btn:hover { background: #f8fafc; }
.admin-filter-btn.active { background: #0f1f3d; color: #fff; border-color: #0f1f3d; }
.admin-status-dot { width: 7px; height: 7px; border-radius: 50%; display: inline-block; }
.admin-table { width: 100%; border-collapse: collapse; }
.admin-table th {
    padding: 12px 16px;
    font-size: 11px;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: .05em;
    border-bottom: 1px solid #e2e8f0;
    background: #f8fafc;
    text-align: left;
    font-family: 'Plus Jakarta Sans', sans-serif;
}
.admin-table td {
    padding: 14px 16px;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: middle;
}
.admin-table tr:last-child td { border-bottom: none; }
.admin-table tr:hover td { background: #f8fafc; }
</style>
