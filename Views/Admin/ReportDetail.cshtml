@model DonationApp.Models.Report
@using DonationApp.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isResolved = Model.Status == ReportStatus.Resolved || Model.Status == ReportStatus.Dismissed;
}

<div style="max-width:800px;margin:0 auto;padding:24px 0;">

    <a href="/Admin/Reports" style="display:inline-flex;align-items:center;gap:6px;font-size:13px;color:#64748b;text-decoration:none;margin-bottom:20px;">
        <i class="ti ti-arrow-left" aria-hidden="true"></i> Kembali ke laporan
    </a>

    @if (TempData["AdminSuccess"] != null)
    {
        <div style="background:#dcfce7;border:1px solid #86efac;color:#166534;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-size:13px;display:flex;align-items:center;gap:8px;">
            <i class="ti ti-circle-check" aria-hidden="true"></i>
            @TempData["AdminSuccess"]
        </div>
    }

    <div style="display:grid;grid-template-columns:1fr 320px;gap:16px;align-items:start;">

        <div style="display:flex;flex-direction:column;gap:14px;">

            <div class="admin-card">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
                    <h2 style="font-size:16px;font-weight:700;color:#0f172a;font-family:'Plus Jakarta Sans',sans-serif;margin:0;">
                        Laporan #@Model.Id
                    </h2>
                    @{
                        var statusLabel = Model.Status switch {
                            ReportStatus.Open => "Open",
                            ReportStatus.Reviewing => "Reviewing",
                            ReportStatus.Resolved => "Resolved",
                            ReportStatus.Dismissed => "Dismissed",
                            _ => "-"
                        };
                        var statusColor = Model.Status switch {
                            ReportStatus.Open => "#ef4444",
                            ReportStatus.Reviewing => "#f59e0b",
                            ReportStatus.Resolved => "#22c55e",
                            ReportStatus.Dismissed => "#94a3b8",
                            _ => "#94a3b8"
                        };
                        var statusBg = Model.Status switch {
                            ReportStatus.Open => "#fee2e2",
                            ReportStatus.Reviewing => "#fef9c3",
                            ReportStatus.Resolved => "#dcfce7",
                            ReportStatus.Dismissed => "#f1f5f9",
                            _ => "#f1f5f9"
                        };
                    }
                    <span style="font-size:11px;font-weight:700;padding:4px 12px;border-radius:99px;background:@statusBg;color:@statusColor;font-family:'Plus Jakarta Sans',sans-serif;">
                        @statusLabel
                    </span>
                </div>

                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;">
                    <div>
                        <div class="admin-field-label">Pelapor</div>
                        <div class="admin-field-value">@(Model.Reporter?.NamaDepan + " " + Model.Reporter?.NamaBelakang)</div>
                        <div style="font-size:11px;color:#94a3b8;">@Model.Reporter?.Email</div>
                    </div>
                    <div>
                        <div class="admin-field-label">Tanggal Laporan</div>
                        <div class="admin-field-value">@Model.CreatedAt.ToString("dd MMM yyyy, HH:mm")</div>
                    </div>
                    <div>
                        <div class="admin-field-label">Alasan</div>
                        <div class="admin-field-value">@Model.Alasan</div>
                    </div>
                    @if (Model.ResolvedAt.HasValue)
                    {
                        <div>
                            <div class="admin-field-label">Diselesaikan</div>
                            <div class="admin-field-value">@Model.ResolvedAt.Value.ToString("dd MMM yyyy, HH:mm")</div>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Deskripsi))
                {
                    <div>
                        <div class="admin-field-label" style="margin-bottom:6px;">Deskripsi</div>
                        <div style="font-size:13px;color:#334155;line-height:1.6;background:#f8fafc;padding:12px;border-radius:8px;border:1px solid #e2e8f0;">
                            @Model.Deskripsi
                        </div>
                    </div>
                }
            </div>

            @if (Model.TargetUser != null)
            {
                <div class="admin-card">
                    <div class="admin-section-label">Target: Pengguna</div>
                    <div style="display:flex;align-items:center;gap:12px;margin-top:10px;">
                        <div style="width:40px;height:40px;border-radius:50%;background:#3b82f6;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:#fff;flex-shrink:0;">
                            @(Model.TargetUser.NamaDepan.Substring(0, 1).ToUpper())
                        </div>
                        <div>
                            <div style="font-size:14px;font-weight:600;color:#0f172a;font-family:'Plus Jakarta Sans',sans-serif;">
                                @(Model.TargetUser.NamaDepan + " " + Model.TargetUser.NamaBelakang)
                            </div>
                            <div style="font-size:12px;color:#64748b;">@Model.TargetUser.Email</div>
                        </div>
                        @if (Model.TargetUser.IsBanned)
                        {
                            <span style="margin-left:auto;font-size:11px;font-weight:700;padding:3px 10px;border-radius:99px;background:#fee2e2;color:#991b1b;">Banned</span>
                        }
                    </div>
                </div>
            }

            @if (Model.TargetDonation != null)
            {
                <div class="admin-card">
                    <div class="admin-section-label">Target: Donasi</div>
                    <div style="display:flex;align-items:center;gap:12px;margin-top:10px;">
                        @if (Model.TargetDonation.Images.Any())
                        {
                            <img src="@Model.TargetDonation.Images.First().FilePath"
                                 style="width:60px;height:60px;border-radius:8px;object-fit:cover;flex-shrink:0;" />
                        }
                        <div>
                            <div style="font-size:14px;font-weight:600;color:#0f172a;font-family:'Plus Jakarta Sans',sans-serif;">@Model.TargetDonation.NamaBarang</div>
                            <div style="font-size:12px;color:#64748b;">@Model.TargetDonation.Kategori · @Model.TargetDonation.Lokasi</div>
                        </div>
                        <a href="/Donasi/Detail/@Model.TargetDonation.Id" target="_blank"
                           style="margin-left:auto;font-size:12px;color:#2563eb;text-decoration:none;font-weight:500;">
                            Lihat item →
                        </a>
                    </div>
                </div>
            }

            @if (Model.TargetRequest != null)
            {
                <div class="admin-card">
                    <div class="admin-section-label">Target: Request</div>
                    <div style="display:flex;align-items:center;gap:12px;margin-top:10px;">
                        @if (Model.TargetRequest.Images.Any())
                        {
                            <img src="@Model.TargetRequest.Images.First().FilePath"
                                 style="width:60px;height:60px;border-radius:8px;object-fit:cover;flex-shrink:0;" />
                        }
                        <div>
                            <div style="font-size:14px;font-weight:600;color:#0f172a;font-family:'Plus Jakarta Sans',sans-serif;">@Model.TargetRequest.Title</div>
                            <div style="font-size:12px;color:#64748b;">@Model.TargetRequest.Kategori · @Model.TargetRequest.Lokasi</div>
                        </div>
                        <a href="/Request/Detail/@Model.TargetRequest.Id" target="_blank"
                           style="margin-left:auto;font-size:12px;color:#2563eb;text-decoration:none;font-weight:500;">
                            Lihat request →
                        </a>
                    </div>
                </div>
            }

            @if (Model.AdminActions.Any())
            {
                <div class="admin-card">
                    <div class="admin-section-label">Riwayat Aksi Admin</div>
                    <div style="display:flex;flex-direction:column;gap:8px;margin-top:10px;">
                        @foreach (var a in Model.AdminActions.OrderByDescending(x => x.CreatedAt))
                        {
                            <div style="padding:10px 12px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;">
                                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
                                    <span style="font-size:12px;font-weight:600;color:#0f172a;font-family:'Plus Jakarta Sans',sans-serif;">@a.Action</span>
                                    <span style="font-size:11px;color:#94a3b8;">@a.CreatedAt.ToString("dd MMM yyyy, HH:mm")</span>
                                </div>
                                <div style="font-size:12px;color:#64748b;">oleh @(a.Admin?.NamaDepan + " " + a.Admin?.NamaBelakang)</div>
                                @if (!string.IsNullOrEmpty(a.Note))
                                {
                                    <div style="font-size:12px;color:#334155;margin-top:4px;font-style:italic;">@a.Note</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div style="display:flex;flex-direction:column;gap:14px;">
            @if (!isResolved)
            {
                @if (Model.Status == ReportStatus.Open)
                {
                    <div class="admin-card">
                        <div class="admin-section-label" style="margin-bottom:10px;">Status Laporan</div>
                        <form asp-controller="Admin" asp-action="TakeAction" method="post" onsubmit="return adminSubmit(this)">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="reportId" value="@Model.Id" />
                            <button type="submit" name="actionType" value="Reviewing" class="admin-action-btn" style="background:#fef9c3;color:#854d0e;border-color:#fde68a;">
                                <i class="ti ti-eye" aria-hidden="true"></i> Tandai Sedang Direview
                            </button>
                        </form>
                    </div>
                }

                @if (Model.TargetUser != null && !Model.TargetUser.IsBanned)
                {
                    <div class="admin-card">
                        <div class="admin-section-label" style="margin-bottom:10px;">Aksi Pengguna</div>
                        <div style="margin-bottom:10px;">
                            <label style="font-size:12px;font-weight:600;color:#64748b;display:block;margin-bottom:6px;font-family:'Plus Jakarta Sans',sans-serif;">Catatan (opsional)</label>
                            <textarea id="userActionNote" rows="2" style="width:100%;padding:8px 10px;border:1px solid #e2e8f0;border-radius:6px;font-size:13px;font-family:'DM Sans',sans-serif;resize:vertical;outline:none;box-sizing:border-box;" placeholder="Catatan untuk aksi ini..."></textarea>
                        </div>
                        <div style="display:flex;flex-direction:column;gap:8px;">
                            <form asp-controller="Admin" asp-action="TakeAction" method="post" onsubmit="return adminSubmit(this, 'userActionNote')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="reportId" value="@Model.Id" />
                                <input type="hidden" name="note" class="admin-note-input" />
                                <button type="submit" name="actionType" value="WarnUser" class="admin-action-btn" style="background:#fff7ed;color:#9a3412;border-color:#fed7aa;">
                                    <i class="ti ti-alert-triangle" aria-hidden="true"></i> Beri Peringatan
                                </button>
                            </form>
                            <form asp-controller="Admin" asp-action="TakeAction" method="post" onsubmit="return adminSubmit(this, 'userActionNote')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="reportId" value="@Model.Id" />
                                <input type="hidden" name="note" class="admin-note-input" />
                                <button type="submit" name="actionType" value="BanUser"
                                        class="admin-action-btn" style="background:#fee2e2;color:#991b1b;border-color:#fca5a5;"
                                        onclick="return confirm('Ban pengguna ini? Tindakan ini tidak dapat dibatalkan dengan mudah.')">
                                    <i class="ti ti-ban" aria-hidden="true"></i> Ban Pengguna
                                </button>
                            </form>
                        </div>
                    </div>
                }

                @if (Model.TargetDonation != null || Model.TargetRequest != null)
                {
                    <div class="admin-card">
                        <div class="admin-section-label" style="margin-bottom:10px;">Aksi Item</div>
                        <div style="margin-bottom:10px;">
                            <label style="font-size:12px;font-weight:600;color:#64748b;display:block;margin-bottom:6px;font-family:'Plus Jakarta Sans',sans-serif;">Catatan (opsional)</label>
                            <textarea id="itemActionNote" rows="2" style="width:100%;padding:8px 10px;border:1px solid #e2e8f0;border-radius:6px;font-size:13px;font-family:'DM Sans',sans-serif;resize:vertical;outline:none;box-sizing:border-box;" placeholder="Catatan untuk aksi ini..."></textarea>
                        </div>
                        <form asp-controller="Admin" asp-action="TakeAction" method="post" onsubmit="return adminSubmit(this, 'itemActionNote')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="reportId" value="@Model.Id" />
                            <input type="hidden" name="note" class="admin-note-input" />
                            <button type="submit" name="actionType" value="RemoveItems" class="admin-action-btn" style="background:#fee2e2;color:#991b1b;border-color:#fca5a5;"
                                    onclick="return confirm('Hapus item yang dilaporkan? Item akan ditutup dan pemilik akan diberitahu.')">
                                <i class="ti ti-trash" aria-hidden="true"></i>
                                Hapus @(Model.TargetDonation != null ? "Donasi" : "Request")
                            </button>
                        </form>
                    </div>
                }

                <div class="admin-card">
                    <form asp-controller="Admin" asp-action="TakeAction" method="post" onsubmit="return adminSubmit(this)">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="reportId" value="@Model.Id" />
                        <button type="submit" name="actionType" value="Dismiss" class="admin-action-btn" style="background:#f1f5f9;color:#64748b;border-color:#e2e8f0;">
                            <i class="ti ti-x" aria-hidden="true"></i> Dismiss Laporan
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="admin-card" style="text-align:center;padding:24px;">
                    <i class="ti ti-circle-check" style="font-size:32px;color:#22c55e;display:block;margin-bottom:8px;" aria-hidden="true"></i>
                    <p style="font-size:13px;color:#64748b;margin:0;">Laporan ini sudah diselesaikan.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
.admin-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 18px;
}
.admin-section-label {
    font-size: 11px;
    font-weight: 700;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: .05em;
    font-family: 'Plus Jakarta Sans', sans-serif;
}
.admin-field-label {
    font-size: 11px;
    font-weight: 600;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: .04em;
    margin-bottom: 3px;
    font-family: 'Plus Jakarta Sans', sans-serif;
}
.admin-field-value {
    font-size: 13px;
    font-weight: 500;
    color: #0f172a;
}
.admin-action-btn {
    width: 100%;
    padding: 10px 14px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    transition: opacity 0.15s;
}
.admin-action-btn:hover { opacity: 0.85; }
.admin-action-btn:disabled { opacity: 0.5; cursor: not-allowed; }
@@media (max-width: 768px) {
    div[style*="grid-template-columns:1fr 320px"] {
        display: block !important;
    }
}
</style>

<script>
    function adminSubmit(form, noteFieldId) {
        if (noteFieldId) {
            var noteEl = document.getElementById(noteFieldId);
            var hiddenNote = form.querySelector('.admin-note-input');
            if (noteEl && hiddenNote) hiddenNote.value = noteEl.value;
        }
        var btn = form.querySelector('button[type="submit"]');
        if (btn) {
            btn.disabled = true;
            btn.style.opacity = '0.5';
        }
        return true;
    }
</script>
