@model IEnumerable<DonationApp.Models.Item>
@using DonationApp.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var selected = (ItemCategory)ViewBag.SelectedKategori;
}

<div class="category-label">Kategori</div>
<div class="pills">
    <a class="pill @(selected == ItemCategory.Semua ? "active" : "inactive")"
       asp-controller="Home" asp-action="Index" asp-route-kategori="Semua">Semua</a>
    <a class="pill @(selected == ItemCategory.Pakaian ? "active" : "inactive")"
       asp-controller="Home" asp-action="Index" asp-route-kategori="Pakaian">Pakaian</a>
    <a class="pill @(selected == ItemCategory.Elektronik ? "active" : "inactive")"
       asp-controller="Home" asp-action="Index" asp-route-kategori="Elektronik">Elektronik</a>
    <a class="pill @(selected == ItemCategory.Buku ? "active" : "inactive")"
       asp-controller="Home" asp-action="Index" asp-route-kategori="Buku">Buku</a>
</div>

<div class="section-title">Barang Tersedia :</div>

<div class="card-grid">
    @foreach (var item in Model)
    {
        var daysLeft = (item.ExpiresAt - DateTime.UtcNow).Days;
        <div class="item-card"
             onclick="openItemModal('@item.NamaBarang', '@item.Kondisi', '@item.Lokasi', '@item.Deskripsi')">
            <div class="card-image">
                <svg width="48" height="48" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24">
                    <rect x="3" y="3" width="18" height="18" rx="2" />
                    <path d="m3 9 4-4 4 4 4-4 4 4" />
                    <circle cx="8.5" cy="13.5" r="1.5" />
                    <path d="m21 15-5-5-5 5" />
                </svg>
            </div>
            <div class="card-info">
                <div class="card-row">
                    <span class="card-name">@item.NamaBarang</span>
                    <span class="card-lokasi">@item.Lokasi</span>
                </div>
                <div class="card-timer">⏱ @daysLeft hari lagi</div>
            </div>
        </div>
    }
</div>

<div class="modal-overlay" id="itemModal">
    <div class="modal-box">
        <button class="modal-close" onclick="closeModal('itemModal')">✕</button>
        <div class="modal-top">
            <div class="modal-image">
                <svg width="48" height="48" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24">
                    <rect x="3" y="3" width="18" height="18" rx="2" />
                    <path d="m3 9 4-4 4 4 4-4 4 4" />
                    <circle cx="8.5" cy="13.5" r="1.5" />
                    <path d="m21 15-5-5-5 5" />
                </svg>
            </div>
            <div class="modal-info">
                <div class="modal-info-row" id="modalNama"></div>
                <div class="modal-info-row" id="modalKondisi"></div>
                <div class="modal-info-row" id="modalLokasi"></div>
            </div>
        </div>
        <div class="modal-deskripsi" id="modalDeskripsi"></div>
        <div class="modal-footer">
            <button class="modal-btn">Minta Barang</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openItemModal(nama, kondisi, lokasi, deskripsi) {
            document.getElementById('modalNama').textContent = nama;
            document.getElementById('modalKondisi').textContent = kondisi;
            document.getElementById('modalLokasi').textContent = lokasi;
            document.getElementById('modalDeskripsi').textContent = deskripsi;
            document.getElementById('itemModal').classList.add('open');
        }

        function closeModal(id) {
            document.getElementById(id).classList.remove('open');
        }

        document.getElementById('itemModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal('itemModal');
        });
    </script>
}