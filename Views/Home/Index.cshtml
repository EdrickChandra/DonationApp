@model IEnumerable<DonationApp.Models.Item>
@using DonationApp.Models
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var selected = ViewBag.SelectedKategori as ItemCategory?;
}

<div class="page-header">
    <div class="page-header-inner">
        <div class="pills">
            <a class="pill @(selected == null ? "active" : "")"
               asp-controller="Request" asp-action="Index">
                <i class="ti ti-layout-grid" aria-hidden="true"></i>
                Semua
            </a>
            @foreach (var cat in CategoryHelper.AllCategories())
            {
                var icon = cat switch
                {
                    ItemCategory.Pakaian => "ti-shirt",
                    ItemCategory.Elektronik => "ti-device-laptop",
                    ItemCategory.Buku => "ti-book",
                    ItemCategory.PerabotRumah => "ti-sofa",
                    ItemCategory.MainanHobi => "ti-fidget-spinner",
                    ItemCategory.AlatTulis => "ti-pencil",
                    ItemCategory.AlatMusik => "ti-guitar-pick",
                    ItemCategory.PeralatanDapur => "ti-tools-kitchen-2",
                    _ => "ti-tag"
                };
                <a class="pill @(selected == cat ? "active" : "")"
                   asp-controller="Request" asp-action="Index" asp-route-kategori="@cat">
                    <i class="ti @icon" aria-hidden="true"></i>
                    @CategoryHelper.DisplayName(cat)
                </a>
            }
        </div>
    </div>
</div>

<div class="feed-wrap">
    <div class="feed-tabs">
        <a class="feed-tab active" asp-controller="Home" asp-action="Index">Donasi</a>
        <a class="feed-tab" asp-controller="Request" asp-action="Index">Request</a>
    </div>

    <div class="feed-header">
        <span class="feed-title">Barang Tersedia</span>
        <span class="feed-count">@Model.Count() item</span>
    </div>

    <div class="card-grid">
        @foreach (var item in Model)
        {
            var daysLeft = (item.ExpiresAt - DateTime.UtcNow).Days;
            var images = item.Images.ToList();
            var posterInitial = item.User?.NamaDepan?.Substring(0, 1).ToUpper() ?? "?";
            var posterName = item.User != null ? item.User.NamaDepan : "Unknown";
            var kondisiBadgeClass = item.Kondisi == ItemCondition.Baru ? "card-kondisi-baru" : "card-kondisi-bekas";
            var kondisiLabel = item.Kondisi == ItemCondition.Baru ? "Baru" : "Bekas";
            var cardId = $"card-menu-{item.Id}";
            <div class="item-card" style="position:relative;">
                <a asp-controller="Donasi" asp-action="Detail" asp-route-id="@item.Id" style="text-decoration:none;display:block;">
                    <div class="card-img">
                        <img src="@images.First().FilePath" class="card-img-fill" />
                        <span class="card-timer-badge">
                            <i class="ti ti-clock" aria-hidden="true"></i>
                            @daysLeft hari
                        </span>
                        <span class="@kondisiBadgeClass">@kondisiLabel</span>
                    </div>
                    <div class="card-body">
                        <div class="card-name">@item.NamaBarang</div>
                        <div class="card-meta">
                            <span class="card-cat">@CategoryHelper.DisplayName(item.Kategori)</span>
                            <span class="card-dot">·</span>
                            <span class="card-loc">
                                <i class="ti ti-map-pin" aria-hidden="true"></i>
                                @item.Lokasi
                            </span>
                        </div>
                    </div>
                    <div class="card-footer">
                        <div class="card-poster">
                            <div class="avatar avatar-xs">@posterInitial</div>
                            <span class="card-poster-name">@posterName</span>
                        </div>
                    </div>
                </a>
                <button class="btn-card-menu" onclick="toggleCardMenu('@cardId', event)" aria-label="Opsi">
                    <i class="ti ti-dots-vertical" aria-hidden="true"></i>
                </button>
                <div class="card-menu-dropdown" id="@cardId">
                    <button class="card-menu-item" onclick="reportItem(@item.Id)">
                        <i class="ti ti-flag" aria-hidden="true"></i> Lapor
                    </button>
                    <button class="card-menu-item" onclick="copyLink('/Donasi/Detail/@item.Id')">
                        <i class="ti ti-copy" aria-hidden="true"></i> Salin Link
                    </button>
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <p class="card-grid-empty">Belum ada barang tersedia.</p>
        }
    </div>
</div>

@section Scripts {
    <script>
        function toggleCardMenu(id, e) {
            e.preventDefault(); e.stopPropagation();
            document.querySelectorAll('.card-menu-dropdown').forEach(el => { if (el.id !== id) el.classList.remove('open'); });
            document.getElementById(id).classList.toggle('open');
        }
        document.addEventListener('click', () => document.querySelectorAll('.card-menu-dropdown').forEach(el => el.classList.remove('open')));
        function copyLink(path) { navigator.clipboard.writeText(window.location.origin + path); }
        function reportItem(id) { alert('Laporan untuk item #' + id + ' telah dikirim.'); }
    </script>
}
